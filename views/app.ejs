                z-index:3;
                opacity:1;
                transition:opacity .22s ease;
                pointer-events:none;
            }
            .uav-level2-host.uav2-rendered .uav-level2-fallback{opacity:0}
            .uav-level2-host.uav2-error .uav-level2-loading span{font-size:0}
            .uav-level2-host.uav2-error .uav-level2-loading span:after{content:"Fallback avatar aktif";font-size:10px}
            .uav-level2-host.size-public .uav-level2-loading{display:none}
            .uav-level2-host.size-public .uav-level2-wrap{border-radius:24px}

            .uav-level2-fallback{display:grid;place-items:center;background:transparent}
