            /* ===== Avatar World Level 2: WebGL semi-human 3D avatar ===== */
            .plong-user-avatar{
                --bg1:#dbeafe;
                --bg2:#fff7ed;
                --uav-rx:-4deg;
                --uav-ry:12deg;
                position:relative!important;
                display:grid!important;
                place-items:center!important;
                overflow:visible!important;
                perspective:760px;
                perspective-origin:50% 44%;
                touch-action:none;
                cursor:grab;
                user-select:none;
                -webkit-user-select:none;
            }
            .plong-user-avatar:active{cursor:grabbing}
            .plong-user-avatar.size-xl{width:230px!important;height:285px!important}
            .plong-user-avatar.size-profile{width:280px!important;height:350px!important}
            .plong-user-avatar.size-public{width:150px!important;height:188px!important}

            .uav-human-avatar{
                --skin:#f2b789;
                --hair:#332238;
                --outfit:#ff9349;
                --aura:#14b8a6;
                position:absolute;
                inset:0;
                display:grid;
                place-items:center;
                border-radius:34px;
                isolation:isolate;
                transform-style:preserve-3d;
            }
            .uavh-bg{
                position:absolute;
                inset:0;
                border-radius:34px;
                background:
                    radial-gradient(circle at 50% 18%,rgba(255,255,255,.88),transparent 112px),
                    radial-gradient(circle at 24% 78%,rgba(255,180,109,.18),transparent 90px),
                    radial-gradient(circle at 82% 74%,rgba(118,169,255,.18),transparent 82px),
                    linear-gradient(135deg,var(--bg1),var(--bg2));
                box-shadow:inset 0 1px 0 rgba(255,255,255,.8);
                z-index:0;
            }
            .uavh-aura{
                position:absolute;
                left:50%;
                top:18%;
                width:58%;
                height:54%;
                transform:translateX(-50%);
                border-radius:999px;
                background:var(--aura);
                opacity:.24;
                filter:blur(24px);
                animation:uavhAura 4s ease-in-out infinite;
                z-index:1;
            }
            .uavh-orbit{
                position:absolute;
                left:50%;
                top:44%;
                border:1px solid color-mix(in srgb, var(--aura) 42%, transparent);
                border-radius:50%;
                transform:translate(-50%,-50%) rotateX(68deg) rotateZ(18deg);
                opacity:.32;
                z-index:2;
            }
            .uavh-orbit.one{width:65%;height:30%}
            .uavh-orbit.two{width:48%;height:22%;transform:translate(-50%,-50%) rotateX(68deg) rotateZ(-22deg)}
            @keyframes uavhAura{
                0%,100%{transform:translateX(-50%) scale(.94);opacity:.20}
                50%{transform:translateX(-50%) scale(1.08);opacity:.30}
            }
            .uavh-ground{
                position:absolute;
                left:50%;
                bottom:12%;
                width:62%;
                height:12%;
                transform:translateX(-50%);
                border-radius:50%;
                background:radial-gradient(ellipse at center,rgba(17,24,39,.24),rgba(17,24,39,.04) 68%,transparent 72%);
                filter:blur(1px);
                z-index:2;
            }
            .uavh-stage{
                position:absolute;
                inset:0;
                display:grid;
                place-items:center;
                z-index:4;
                transform-style:preserve-3d;
            }
            .uavh-inner{
                position:relative;
                width:210px;
                height:265px;
                transform-style:preserve-3d;
                transform:translateY(7px) rotateX(var(--uav-rx)) rotateY(var(--uav-ry));
                transition:transform .25s ease;
            }
            .plong-user-avatar.is-dragging .uavh-inner{transition:none}
            .plong-user-avatar.size-xl .uavh-inner{transform:translateY(5px) scale(.9) rotateX(var(--uav-rx)) rotateY(var(--uav-ry))}
            .plong-user-avatar.size-profile .uavh-inner{transform:translateY(10px) scale(1.05) rotateX(var(--uav-rx)) rotateY(var(--uav-ry))}
            .plong-user-avatar.size-public .uavh-inner{transform:translateY(2px) scale(.62) rotateX(var(--uav-rx)) rotateY(var(--uav-ry))}

