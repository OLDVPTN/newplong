            /* GARDEN / TANAM SAYUR */
            function normalizeGardenPlotLocal(plot){
                if(!plot||typeof plot!=="object")return null;
                var seed=String(plot.seed||"carrot").toLowerCase();
                if(!VEGGIES[seed])return null;
                var v=VEGGIES[seed], wc=Math.max(0,Number(plot.waterCount||0));
                var progress=Math.max(0,Math.min(100,Number(plot.progress||0)));
                return {
                    seed:seed,
                    progress:progress,
                    waterCount:wc,
                    growNeed:v.growNeed,
                    stage:Math.min(v.growNeed,Number(plot.stage||wc||0)),
                    ready:!!plot.ready||wc>=v.growNeed||progress>=100,
                    plantedAt:plot.plantedAt||new Date().toISOString(),
                    lastWaterAt:plot.lastWaterAt||null
                };
            }
            function ensureGardenLocal(){
                if(!state.garden)state.garden={activePlot:0,plot:null,plots:[null,null,null,null],inventory:{carrot:0,lettuce:0,tomato:0},history:[],level:1,exp:0,expMax:40,lastIdleAt:new Date().toISOString(),lastBonusAt:null};
                if(!Array.isArray(state.garden.plots))state.garden.plots=[];
                while(state.garden.plots.length<4)state.garden.plots.push(null);
                state.garden.plots=state.garden.plots.slice(0,4).map(normalizeGardenPlotLocal);
                state.garden.activePlot=Math.max(0,Math.min(3,Math.floor(Number(state.garden.activePlot||0))));
                var oldPlot=normalizeGardenPlotLocal(state.garden.plot);
                if(oldPlot&&!state.garden.plots[state.garden.activePlot])state.garden.plots[state.garden.activePlot]=oldPlot;
                state.garden.plot=state.garden.plots[state.garden.activePlot]||null;
                if(!state.garden.inventory)state.garden.inventory={carrot:0,lettuce:0,tomato:0};
                Object.keys(VEGGIES).forEach(function(k){state.garden.inventory[k]=Math.max(0,Number(state.garden.inventory[k]||0));});
                if(!Array.isArray(state.garden.history))state.garden.history=[];
                state.garden.level=Math.max(1,Math.floor(Number(state.garden.level||1)));
                state.garden.exp=Math.max(0,Math.floor(Number(state.garden.exp||0)));
                state.garden.expMax=Math.max(40,Math.floor(Number(state.garden.expMax||40)));
                state.garden.lastIdleAt=state.garden.lastIdleAt||new Date().toISOString();
                state.garden.lastBonusAt=state.garden.lastBonusAt||null;
                state.garden.waterDrops=Math.max(0,Math.floor(Number(state.garden.waterDrops==null?20:state.garden.waterDrops)));
                var today=new Date().toISOString().slice(0,10);
                if(!state.garden.daily||state.garden.daily.date!==today)state.garden.daily={date:today,planted:0,watered:0,harvested:0,claimed:false};
                state.garden.daily.planted=Math.max(0,Math.floor(Number(state.garden.daily.planted||0)));
                state.garden.daily.watered=Math.max(0,Math.floor(Number(state.garden.daily.watered||0)));
                state.garden.daily.harvested=Math.max(0,Math.floor(Number(state.garden.daily.harvested||0)));
                state.garden.daily.claimed=!!state.garden.daily.claimed;
                return state.garden;
            }
            function getActivePlotIndex(){
                var g=ensureGardenLocal();
                return Math.max(0,Math.min(3,Math.floor(Number(g.activePlot||0))));
            }
            function selectGardenPlot(i){
                var g=ensureGardenLocal();
                g.activePlot=Math.max(0,Math.min(3,Math.floor(Number(i||0))));
                g.plot=g.plots[g.activePlot]||null;
                save();
                renderGarden();
            }
            function gardenEmojiFor(plot){
                if(!plot)return '🌱';
                var v=VEGGIES[plot.seed]||VEGGIES.carrot;
                var p=Number(plot.progress||0);
                if(plot.ready)return v.icon;
                if(p<35)return '🌱';
                if(p<75)return '🌿';
                return '🪴';
            }
            function gardenStageFor(plot){
                if(!plot)return 'seedling';
                if(plot.ready)return 'ready';
                var p=Math.max(0,Math.min(100,Number(plot.progress||0)));
                if(p<35)return 'seedling';
                if(p<75)return 'mid';
                return 'ready';
            }
            function gardenAssetFor(type,stage){
                var safeType=VEGGIES[type]?type:'carrot';
                var safeStage=(stage==='seedling'||stage==='mid'||stage==='ready')?stage:'seedling';
                return GARDEN_ASSETS.base+'/premium-'+safeType+'-'+safeStage+'.svg';
            }
            function gardenSeedAssetFor(type){
                var safeType=VEGGIES[type]?type:'carrot';
                return GARDEN_ASSETS.base+'/premium-seed-'+safeType+'.svg';
            }
            function gardenPlotBase(plot,active){
                if(plot&&plot.ready)return GARDEN_ASSETS.plotReady;
                if(plot&&Number(plot.waterCount||0)>0&&!plot.ready)return GARDEN_ASSETS.plotWet;
                return active?GARDEN_ASSETS.plotActive:GARDEN_ASSETS.plotEmpty;
            }
            function gardenMainAssetHtml(plot){
                if(!plot)return '<img class="garden-main-asset idle" src="'+gardenSeedAssetFor('carrot')+'" alt="Bibit kebun" />';
                var stage=gardenStageFor(plot), type=plot.seed||'carrot';
                return '<img class="garden-main-asset is-'+escH(type)+' '+(plot.ready?'ready':'growing')+' stage-'+stage+'" src="'+gardenAssetFor(type,stage)+'" alt="'+escH((VEGGIES[type]||VEGGIES.carrot).name)+'" />';
            }
            function gardenPlotAssetHtml(plot,active){
