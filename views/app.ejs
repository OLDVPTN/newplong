                var cap=state.pet.avatarCapsule||(state.pet.avatarCapsule={lastOpenAt:null,totalOpened:0});
                var today=new Date().toISOString().slice(0,10);
                if(cap.lastOpenAt&&String(cap.lastOpenAt).slice(0,10)===today){
                    toast('Kapsul harian sudah dibuka. Coba lagi besok ya.');
                    return;
                }
                randomAvatar();
                cap.lastOpenAt=new Date().toISOString();
                cap.totalOpened=Math.max(0,Number(cap.totalOpened||0))+1;
                state.coins=Math.max(0,Math.floor(Number(state.coins||0))+3);
                if(state.pet){
                    state.pet.bond=Math.max(0,Math.min(100,Number(state.pet.bond||0)+1));
                    state.pet.exp=Math.max(0,Number(state.pet.exp||0)+4);
                    while(state.pet.exp>=state.pet.expMax){
                        state.pet.exp-=state.pet.expMax;
                        state.pet.level+=1;
                        state.pet.expMax=Math.max(30,Math.floor(state.pet.expMax*1.35));
                    }
                }
                save();
                refreshUI();
                syncStateToPostgreSQL();
                toast('Kapsul terbuka: +3 coins, +4 EXP, +1 bond');
