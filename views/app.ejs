/* ===== Readability & friends upgrade ===== */
:root{--nav-h:64px}
#tbar .lw{font-size:16px}
.pt{font-size:22px;font-weight:800;letter-spacing:-.35px}
.ps,.pm{font-size:12.5px;line-height:1.6}
.pn{font-size:20px}
.sb{font-size:14px;font-weight:700;padding:10px 12px}
.nb{font-size:10.5px;font-weight:800;gap:2px;padding:6px 10px;min-height:46px;min-width:52px}
.nb span{line-height:1.18}
.sb .nav-img{width:25px;height:25px}
.nb .nav-img{width:28px;height:28px}
.cp,.cpill{font-size:12px}
.home-soft-btn,.home-primary-btn,.foku-primary-btn,.pet-act,.friend-btn{font-size:13px}
.foku-greet span{font-size:15px}
.foku-greet strong{font-size:28px;line-height:1.14}
.foku-greet small{font-size:13px;line-height:1.6}
.foku-message-bubble span{font-size:12px}
.foku-message-bubble strong{font-size:15px;line-height:1.45}
.foku-pet-card-top h2{font-size:26px}
.foku-status{font-size:13px;line-height:1.6}
.foku-pet-stat label{font-size:12px}
.foku-pet-stat strong{font-size:25px}
.foku-side-head span,.foku-section-head span{font-size:11px}
.foku-side-head strong,.foku-section-head strong{font-size:19px}
.foku-quick-btn{font-size:12px;min-height:86px}
.foku-focus-item p,.foku-side-card p,.foku-bottom-card p{font-size:13px;line-height:1.65}
.pp-hero-logo{font-size:30px}
.pp-hero-sub{font-size:14px;line-height:1.6}
.pp-input-box textarea{font-size:15.5px}
.pp-msg-user .pp-bbl,.pp-msg-bot .pp-bbl{font-size:14.5px}
.st-title strong{font-size:24px}
.st-title span{font-size:12px;line-height:1.55}
.st-card-head strong{font-size:15px}
.st-card-head span{font-size:12px;line-height:1.55}
.st-wallet-item strong{font-size:14px}
.st-wallet-item span{font-size:12px}

#pg-friends{gap:12px;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior-y:contain;padding-bottom:calc(var(--nav-h) + var(--s-b) + 18px)}
.friend-shell{display:flex;flex-direction:column;gap:12px;max-width:1100px;margin:0 auto}
.friend-hero{position:relative;overflow:hidden;padding:18px;border-radius:26px;background:linear-gradient(135deg,#fff7ef 0%,#f2fff5 46%,#f7f4ff 100%);border:1px solid rgba(255,255,255,.9);box-shadow:0 16px 40px rgba(91,121,90,.10);display:grid;grid-template-columns:minmax(0,1fr) 120px;gap:14px;align-items:center}
.friend-kicker{display:inline-flex;align-items:center;gap:8px;padding:7px 11px;border-radius:999px;background:rgba(255,255,255,.85);border:1px solid rgba(160,196,155,.25);font-size:11px;font-weight:900;color:#507155;width:max-content;margin-bottom:10px}
.friend-kicker img{width:18px;height:18px;object-fit:contain}
.friend-hero h2{margin:0 0 6px;font-size:26px;color:#21374d;line-height:1.15}
.friend-hero p{margin:0;color:#6a748e;line-height:1.7;font-size:13px;max-width:58ch}
.friend-hero-art{display:flex;justify-content:center;align-items:center}
.friend-hero-art img{width:min(112px,100%);height:auto;filter:drop-shadow(0 10px 18px rgba(93,126,87,.18))}
.friend-search-card,.friend-section-card{background:rgba(255,255,255,.92);border:1px solid rgba(221,229,240,.95);border-radius:24px;padding:14px;box-shadow:0 10px 26px rgba(62,80,114,.06)}
.friend-search-box{display:flex;gap:10px;align-items:center;background:#f7fbff;border:1px solid #e2ecff;border-radius:18px;padding:10px 12px}
.friend-search-box i{color:#6a86d8}
#friend-search{flex:1;border:0;background:transparent;outline:0;color:#23314e;font-size:14px}
.friend-chip-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.friend-chip{border:1px solid #e5ecfb;background:#fff;border-radius:999px;padding:8px 12px;font-size:11px;font-weight:800;color:#5e6e96;cursor:pointer;transition:.15s}
.friend-chip.active,.friend-chip:hover{background:#eef5ff;border-color:#bfd6ff;color:#335dc7}
.friend-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.friend-card{background:linear-gradient(180deg,#ffffff,#f8fbff);border:1px solid #e7eefc;border-radius:22px;padding:14px;display:flex;flex-direction:column;gap:12px;box-shadow:0 10px 22px rgba(84,106,160,.06)}
.friend-card-head{display:flex;align-items:center;gap:12px}
.friend-avatar{width:58px;height:58px;border-radius:18px;background:linear-gradient(135deg,#fff6e8,#eef8ff);border:1px solid #e7effc;display:grid;place-items:center;overflow:hidden;flex:0 0 58px}
.friend-avatar img{width:42px;height:42px;object-fit:contain}
