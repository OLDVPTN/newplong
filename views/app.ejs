            function gardenActivePlantCountLocal(g){
                return (g&&Array.isArray(g.plots)?g.plots:[]).filter(Boolean).length;
            }
            function gardenIdleRateLocal(g){
                var level=Math.max(1,Math.floor(Number(g&&g.level||1)));
                return Math.max(1,gardenActivePlantCountLocal(g)+Math.floor(level/2));
            }
            function gardenIdleCoinsLocal(g){
                if(!g)return 0;
                var last=g.lastIdleAt?Date.parse(g.lastIdleAt):Date.now();
                if(!Number.isFinite(last))last=Date.now();
                var mins=Math.floor(Math.min(Date.now()-last,12*60*60*1000)/60000);
                return Math.max(0,Math.floor(mins*gardenIdleRateLocal(g)));
            }
            function gardenWaterPowerLocal(g){
                var level=Math.max(1,Math.floor(Number(g&&g.level||1)));
                return Math.max(1,1+Math.floor((level-1)/3));
            }
            function gardenUpgradeCostLocal(g){
                var level=Math.max(1,Math.floor(Number(g&&g.level||1)));
                return 24+level*18;
            }
            function renderGarden(){
                var g=ensureGardenLocal(), active=getActivePlotIndex(), plot=g.plots[active]||null;
                g.plot=plot;
                if(typeof g.waterDrops!=="number")g.waterDrops=20;
