        <script>
            window.__VKM_PAGE_ID="<%= pageId %>";
            

            var PAGE_LOADER_MIN_MS=5000;
            var pageLoaderStartedAt=Date.now();
            var pageLoaderTimer=null;
            var pageLoaderPercentTimer=null;
            var pageLoaderMessages=[
                "Menyiapkan ruang Plong...",
                "Memuat pet companion...",
                "Merapikan kebun emosimu...",
                "Menyinkronkan progress...",
                "Hampir selesai..."
            ];

            function updatePageLoaderProgress(percent){
                percent=Math.max(0,Math.min(100,Math.round(percent||0)));
                var bar=document.getElementById("page-loader-bar");
                var pct=document.getElementById("page-loader-percent");
                if(bar)bar.style.width=percent+"%";
                if(pct)pct.textContent=percent+"%";
            }

            function startPageLoader(text){
                var loader=document.getElementById("page-loader");
                if(!loader)return;
                pageLoaderStartedAt=Date.now();
                clearTimeout(pageLoaderTimer);
                clearInterval(pageLoaderPercentTimer);
                loader.classList.remove("hide");
                loader.classList.add("show");
                var title=document.getElementById("page-loader-title");
                var subtitle=document.getElementById("page-loader-subtitle");
                if(title)title.textContent=text||"Memuat halaman...";
                if(subtitle)subtitle.textContent="Plong sedang menyiapkan ruangmu";
                updatePageLoaderProgress(0);

                var start=Date.now();
                var msgIndex=0;
                pageLoaderPercentTimer=setInterval(function(){
                    var elapsed=Date.now()-start;
                    var fake=Math.min(96,(elapsed/PAGE_LOADER_MIN_MS)*96);
                    updatePageLoaderProgress(fake);
                    var nextIndex=Math.min(pageLoaderMessages.length-1,Math.floor(elapsed/1000));
                    if(nextIndex!==msgIndex){
                        msgIndex=nextIndex;
                        if(subtitle)subtitle.textContent=pageLoaderMessages[msgIndex];
                    }
                },120);
            }

            function finishPageLoader(){
                var loader=document.getElementById("page-loader");
                if(!loader)return;
                var elapsed=Date.now()-pageLoaderStartedAt;
                var wait=Math.max(0,PAGE_LOADER_MIN_MS-elapsed);
                clearTimeout(pageLoaderTimer);
                pageLoaderTimer=setTimeout(function(){
                    clearInterval(pageLoaderPercentTimer);
                    updatePageLoaderProgress(100);
                    var title=document.getElementById("page-loader-title");
                    var subtitle=document.getElementById("page-loader-subtitle");
                    if(title)title.textContent="Selesai!";
                    if(subtitle)subtitle.textContent="Ruangmu sudah siap dibuka";
                    setTimeout(function(){
                        loader.classList.remove("show");
                        loader.classList.add("hide");
                    },360);
                },wait);
            }

            function navigateWithLoader(url){
                if(!url)return;
                var targetPath=new URL(url,window.location.origin).pathname;
                if(window.location.pathname===targetPath)return;
                startPageLoader("Membuka halaman...");
                setTimeout(function(){
                    window.location.href=url;
                },520);
            }

            window.addEventListener("load",finishPageLoader);
            window.addEventListener("pageshow",function(event){
                if(event.persisted){
                    startPageLoader("Membuka halaman...");
                    finishPageLoader();
                }
            });
            window.addEventListener("beforeunload",function(){
                startPageLoader("Membuka halaman...");
            });

            startPageLoader("Memuat halaman...");

var EMO={marah:{label:"Marah",color:"#DC2626",hue:0,icon:"fa-fire",desc:"Api Chaos"},sedih:{label:"Sedih",color:"#2563EB",hue:220,icon:"fa-droplet",desc:"Aqua Tears"},galau:{label:"Galau",color:"#9333EA",hue:280,icon:"fa-hurricane",desc:"Wind Void"},stres:{label:"Stres",color:"#D97706",hue:35,icon:"fa-bolt",desc:"Spark Friction"},excited:{label:"Excited",color:"#CA8A04",hue:50,icon:"fa-star",desc:"Solar Burst"},tenang:{label:"Tenang",color:"#0D9488",hue:170,icon:"fa-leaf",desc:"Calm Pulse"}};
            var PRODS=[{id:"p1",name:"Coklat Virtual",desc:"Naikkan kenyang dan bahagia Plong",price:50,icon:"🍫",type:"consumable"},{id:"p2",name:"Taman Mimpi",desc:"Background eksklusif baru",price:120,icon:"🌸",type:"unlock",key:"bg_dream_garden"},{id:"p3",name:"Mahkota Emosi",desc:"Aksesoris mahkota untuk Plong",price:80,icon:"👑",type:"unlock",key:"acc_crown"},{id:"p4",name:"Bola Kristal",desc:"Refleksi mood ringan",price:90,icon:"🔮",type:"consumable"},{id:"p5",name:"Sayap Emas",desc:"Evolusi visual karakter",price:350,icon:"✨",type:"unlock",key:"acc_wings"}];
