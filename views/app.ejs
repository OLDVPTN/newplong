            function productButtonLabel(p,can,owned){if(owned)return "Pakai";if(can)return p.type==="consumable"?"Redeem":"Unlock";return "Kurang"}
            function clampLocal(v,min,max){v=Number(v);if(!Number.isFinite(v))v=min;return Math.max(min,Math.min(max,v))}
            function ensurePetWorkerLocal(){
                var p=state.pet||(state.pet={});
                var today=new Date().toISOString().slice(0,10);
                if(!p.worker)p.worker={};
                if(!p.worker.essence)p.worker.essence={};
                ["marah","sedih","galau","stres","excited","tenang"].forEach(function(m){p.worker.essence[m]=Math.max(0,Math.floor(Number(p.worker.essence[m]||0)))});
                p.worker.lastClaimAt=p.worker.lastClaimAt||new Date().toISOString();
                p.worker.totalEarned=Math.max(0,Math.floor(Number(p.worker.totalEarned||0)));
                if(!p.worker.today||p.worker.today.date!==today)p.worker.today={date:today,vent:0,chat:0,garden:0,care:0,bonusClaimed:false};
                ["vent","chat","garden","care"].forEach(function(k){p.worker.today[k]=Math.max(0,Math.floor(Number(p.worker.today[k]||0)))});
                p.worker.today.bonusClaimed=!!p.worker.today.bonusClaimed;
                p.energy=clampLocal(p.energy==null?70:p.energy,0,100);
                p.bond=clampLocal(p.bond==null?0:p.bond,0,100);
                return p.worker;
            }
            function petWorkerEssenceTotal(){
                var w=ensurePetWorkerLocal();
                return Object.keys(w.essence).reduce(function(a,k){return a+Number(w.essence[k]||0)},0);
            }
            function petPassiveEstimate(){
                var p=state.pet,w=ensurePetWorkerLocal(),last=Date.parse(w.lastClaimAt||new Date().toISOString());
                if(!Number.isFinite(last))last=Date.now();
                var mins=Math.floor(Math.min(Date.now()-last,8*60*60*1000)/60000);
                if(mins<10)return 0;
                var lvl=Math.max(1,Number(p.level||1)), bond=Number(p.bond||0), energy=Number(p.energy||70), happy=Number(p.happy||50);
                var hourly=Math.max(1,Math.floor((1+lvl*.35+bond*.025)*(0.55+((happy+energy)/200)*.65)*.9));
                return Math.max(0,Math.floor((mins/60)*hourly));
            }
