              #bnav{justify-content:flex-start;gap:2px;overflow-x:auto;overflow-y:hidden;padding-left:6px;padding-right:6px;scrollbar-width:none}
              #bnav::-webkit-scrollbar{display:none}
              .nb{flex:0 0 58px;min-width:58px;padding:4px 4px;font-size:8px}
              .nb i{font-size:16px}.nb .nav-img{width:25px;height:25px}.nb span{max-width:54px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
              #pg-home{gap:8px;padding-bottom:calc(var(--nav-h) + var(--s-b) + 16px)}
              .pet-h{min-height:auto;padding:14px 10px 12px;border-radius:14px}
              #pet-canvas{width:min(230px,66vw)!important;height:min(230px,66vw)!important;margin:-8px auto 0!important}
              .pn{font-size:17px}.pm{font-size:10px}.xptr{width:min(170px,58vw);margin-left:auto;margin-right:auto}
              .pet-actions{display:grid;grid-template-columns:1fr 1fr;gap:6px;width:100%;margin-top:10px}
              .pet-actions .pet-act{justify-content:center;width:100%;min-height:34px;font-size:10px;padding:6px 8px}
              .pet-actions .pet-act-primary{grid-column:1 / -1}
              .sr{gap:6px}.sc,.es{padding:9px;border-radius:10px}
              .eg{max-height:64px;overflow-y:auto}
              #pg-avatar .pet-custom{padding:12px;border-radius:14px}
              #pg-avatar .pet-custom-head{align-items:flex-start;flex-direction:column;gap:8px}
              #pg-avatar .pet-custom-head .pet-custom-btn{width:100%;justify-content:center}
              #pg-avatar .pet-custom-grid{gap:12px}
              #pg-avatar .pet-custom-section{gap:7px}
              .pet-picks{gap:6px}.pet-pick{min-height:34px;font-size:10px;padding:6px 9px}.pet-color{width:32px;height:32px}
              .pet-custom-actions{display:grid;grid-template-columns:1fr 1fr;gap:6px}
              .pet-custom-actions .pet-custom-btn{justify-content:center;width:100%}
              .acct-grid{grid-template-columns:1fr 1fr}
            }

            @media(max-width:380px){
              .nb{flex-basis:54px;min-width:54px}.pet-actions{grid-template-columns:1fr}.pet-actions .pet-act-primary{grid-column:auto}
              #pet-canvas{width:min(210px,70vw)!important;height:min(210px,70vw)!important}
              .sr{grid-template-columns:1fr}
            }

            @supports(-webkit-touch-callout:none){
              #main{height:-webkit-fill-available}
              #pg-home,#pg-garden,#pg-avatar,#pg-account,#pg-vent{overscroll-behavior-y:contain}
              #pet-canvas{transform:translate3d(0,-4px,0)!important;image-rendering:auto}
            }


            /* ═══════ GARDEN PAGE — LEMO-LIKE CUTE FARM ═══════ */
            #pg-garden{
                gap:12px;
                overflow-y:auto;
                -webkit-overflow-scrolling:touch;
                overscroll-behavior-y:contain;
                padding-bottom:calc(var(--nav-h) + var(--s-b) + 18px);
            }
            .garden-layout{display:flex;flex-direction:column;gap:12px}
            .garden-card{
                background:rgba(255,255,255,.86);
                border:1px solid rgba(212,212,216,.78);
                border-radius:22px;
                padding:14px;
                box-shadow:0 14px 34px rgba(15,23,42,.06),0 1px 3px rgba(15,23,42,.04);
                position:relative;
                overflow:hidden;
            }
            .garden-card::after{
                content:'';
                position:absolute;
                inset:auto -28px -48px auto;
                width:120px;height:120px;
                background:radial-gradient(circle,rgba(132,204,22,.12),transparent 65%);
                pointer-events:none;
            }
            .garden-hero-card{
                padding:0;
                background:linear-gradient(180deg,#E9FFF4 0%,#FFF7DD 100%);
                border-color:#BDF7D1;
                overflow:hidden;
            }
            .garden-topbar{
                display:flex;
                align-items:center;
                justify-content:space-between;
                gap:10px;
                padding:14px 14px 4px;
                position:relative;
                z-index:3;
            }
            .garden-chip{
                display:inline-flex;
                align-items:center;
                gap:6px;
                padding:6px 10px;
                border-radius:999px;
                font-size:11px;
                font-weight:800;
                color:#047857;
                background:rgba(255,255,255,.72);
                border:1px solid rgba(153,246,228,.8);
                box-shadow:0 5px 14px rgba(13,148,136,.08);
                white-space:nowrap;
            }
            .garden-chip.coin{color:var(--ac);border-color:var(--ac-bd);background:rgba(255,247,237,.82)}
            .garden-stage{
                min-height:248px;
                border-radius:0;
                background:
                    radial-gradient(circle at 20% 22%,rgba(255,255,255,.95) 0 4px,transparent 5px),
                    radial-gradient(circle at 78% 18%,rgba(255,255,255,.8) 0 6px,transparent 7px),
                    linear-gradient(180deg,#DFFEF0 0%,#F3FFE7 56%,#FFF1C8 100%);
                border:0;
                display:flex;
                align-items:center;
                justify-content:center;
                position:relative;
                overflow:hidden;
                margin-bottom:0;
            }
            .garden-stage::before{
                content:'';
                position:absolute;
                left:-18%;right:-18%;bottom:-38px;
                height:126px;
                background:linear-gradient(180deg,#7DDC80,#3DA856);
                border-radius:50% 50% 0 0;
                opacity:.95;
                box-shadow:0 -14px 36px rgba(22,163,74,.18) inset;
            }
            .garden-stage::after{
                content:'';
                position:absolute;
                left:0;right:0;bottom:30px;
                height:42px;
                background:
                    radial-gradient(ellipse at 14% 65%,rgba(255,255,255,.45) 0 4px,transparent 5px),
                    radial-gradient(ellipse at 35% 70%,rgba(255,255,255,.35) 0 3px,transparent 4px),
                    radial-gradient(ellipse at 66% 63%,rgba(255,255,255,.42) 0 5px,transparent 6px),
                    radial-gradient(ellipse at 85% 70%,rgba(255,255,255,.38) 0 4px,transparent 5px);
                pointer-events:none;
                opacity:.9;
            }
            .garden-cloud{
                position:absolute;
                width:82px;height:24px;
                border-radius:999px;
                background:rgba(255,255,255,.78);
                box-shadow:20px -8px 0 rgba(255,255,255,.62),-16px -4px 0 rgba(255,255,255,.55);
                filter:blur(.1px);
                opacity:.7;
                animation:gCloud 8s ease-in-out infinite;
            }
            .garden-cloud.c1{left:18px;top:58px}
            .garden-cloud.c2{right:28px;top:88px;transform:scale(.72);animation-delay:-3s}
            @keyframes gCloud{0%,100%{transform:translateX(0)}50%{transform:translateX(10px)}}
            .garden-plant{
                position:relative;
                z-index:2;
                text-align:center;
                transform:translateY(16px);
                width:190px;
                height:158px;
                display:flex;
                flex-direction:column;
                align-items:center;
                justify-content:flex-end;
            }
            .garden-emoji{
                font-size:72px;
                filter:drop-shadow(0 12px 15px rgba(22,101,52,.24));
                transition:transform .25s;
                transform-origin:50% 100%;
                animation:gIdle 2.8s ease-in-out infinite;
                line-height:1;
                position:relative;
                z-index:3;
            }
            .garden-emoji.grow{animation:gHappy .75s cubic-bezier(.2,1.4,.35,1) 1}
            @keyframes gIdle{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-5px) rotate(1deg)}}
            @keyframes gHappy{0%{transform:scale(.95) translateY(0)}35%{transform:scale(1.18) translateY(-10px)}70%{transform:scale(.98) translateY(2px)}100%{transform:scale(1) translateY(0)}}
            .garden-soil{
                position:relative;
                z-index:2;
                width:142px;height:38px;
                background:linear-gradient(180deg,#B45309,#78350F);
                border-radius:50%;
                margin:-4px auto 0;
                box-shadow:inset 0 7px 0 rgba(255,255,255,.12),0 8px 18px rgba(69,26,3,.20);
            }
            .garden-soil::before{
                content:'';
                position:absolute;
                left:22px;right:22px;top:7px;height:7px;
                border-radius:999px;
                background:rgba(255,255,255,.14);
            }
            .garden-water-drop{
                position:absolute;
                z-index:4;
                top:54px;left:50%;
                color:#38BDF8;
                font-size:18px;
                opacity:0;
                pointer-events:none;
            }
            .garden-stage.watering .garden-water-drop{
                animation:gDrop .9s ease-out 1;
            }
            @keyframes gDrop{0%{opacity:0;transform:translate(-20px,-20px) scale(.7)}30%{opacity:1}100%{opacity:0;transform:translate(26px,70px) scale(1.2)}}
            .garden-meter{
                padding:12px 14px 14px;
                background:rgba(255,255,255,.74);
                position:relative;
                z-index:4;
                border-top:1px solid rgba(255,255,255,.7);
            }
            .garden-meta{
                display:flex;
                align-items:flex-end;
                justify-content:space-between;
                gap:10px;
                margin-bottom:8px;
            }
            .garden-title-mini{
                font-size:10px;
                font-weight:900;
                letter-spacing:.7px;
                text-transform:uppercase;
                color:#059669;
            }
            .garden-note{
                font-size:11px;
                color:var(--t3);
                line-height:1.55;
                margin-top:5px;
            }
            #garden-status{font-size:12px;color:#365045;font-weight:700;margin-top:2px}
            #garden-percent{
                font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                font-size:22px!important;
                color:#059669!important;
                line-height:1;
                min-width:54px;
                text-align:right;
            }
            .garden-progress{
                height:12px;
                background:rgba(229,231,235,.9);
                border-radius:999px;
                overflow:hidden;
                box-shadow:inset 0 2px 4px rgba(0,0,0,.06);
            }
            .garden-progress span{
                display:block;
                height:100%;
                width:0%;
                background:linear-gradient(90deg,#10B981,#84CC16,#FACC15);
                border-radius:999px;
                transition:width .35s cubic-bezier(.2,.8,.2,1);
                position:relative;
            }
            .garden-progress span::after{
                content:'';
                position:absolute;
                inset:2px 4px auto auto;
                height:3px;width:36%;
                background:rgba(255,255,255,.42);
                border-radius:999px;
            }
            .garden-actions{
                display:grid;
                grid-template-columns:1fr 1fr;
                gap:8px;
                margin-top:12px;
            }
            .garden-btn{
                display:inline-flex;
                align-items:center;
                justify-content:center;
                gap:7px;
                border-radius:14px;
                min-height:42px;
                padding:9px 12px;
                font-size:12px;
                font-weight:900;
                border:1px solid rgba(212,212,216,.8);
                background:#fff;
                color:var(--t2);
                transition:transform .12s,box-shadow .12s,background .12s;
                box-shadow:0 6px 14px rgba(15,23,42,.05);
            }
            .garden-btn:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 10px 20px rgba(15,23,42,.08)}
            .garden-btn.primary{background:linear-gradient(135deg,#10B981,#34D399);border-color:#10B981;color:#fff}
            .garden-btn.warn{background:linear-gradient(135deg,var(--ac),#FB923C);border-color:var(--ac);color:#fff}
            .garden-btn:disabled{opacity:.45;cursor:not-allowed;transform:none;box-shadow:none}
            .garden-section-title{
                display:flex;
                align-items:center;
                justify-content:space-between;
                gap:8px;
                margin-bottom:10px;
            }
            .garden-section-title .acct-title{margin:0}
            .garden-pill{
                font-size:9px;
                font-weight:900;
                color:#059669;
                background:#ECFDF5;
                border:1px solid #A7F3D0;
                border-radius:999px;
                padding:3px 8px;
                white-space:nowrap;
            }
            .garden-grid,.garden-inv{
                display:grid;
                grid-template-columns:repeat(3,1fr);
                gap:8px;
            }
            .garden-seed,.garden-feed{
                border:1px solid rgba(212,212,216,.84);
                background:linear-gradient(180deg,#fff,#F8FAFC);
                border-radius:18px;
                padding:10px 8px;
                text-align:center;
                transition:all .14s;
                min-height:92px;
                box-shadow:0 8px 18px rgba(15,23,42,.045);
                position:relative;
                overflow:hidden;
            }
            .garden-seed::before,.garden-feed::before{
                content:'';
                position:absolute;
                inset:0;
                background:radial-gradient(circle at 70% 18%,rgba(16,185,129,.10),transparent 38%);
                pointer-events:none;
            }
            .garden-seed:hover:not(:disabled),.garden-feed:hover:not(:disabled){
                transform:translateY(-2px);
                border-color:#86EFAC;
                box-shadow:0 13px 24px rgba(22,163,74,.10);
            }
            .garden-seed:disabled,.garden-feed:disabled{opacity:.48;cursor:not-allowed}
            .garden-seed span,.garden-feed span{
                display:flex;
                align-items:center;
                justify-content:center;
                width:40px;height:40px;
                margin:0 auto 5px;
                font-size:24px;
                line-height:1;
                border-radius:14px;
                background:#F0FDF4;
                box-shadow:inset 0 1px 0 rgba(255,255,255,.75);
                position:relative;
                z-index:1;
            }
            .garden-seed strong,.garden-feed strong{
                display:block;
                font-size:11px;
                color:var(--t2);
                line-height:1.25;
                position:relative;
                z-index:1;
            }
            .garden-seed small,.garden-feed small{
                display:block;
                font-size:9px;
                color:var(--t4);
                margin-top:3px;
                line-height:1.25;
                position:relative;
                z-index:1;
            }
            .garden-feed strong{color:#047857}
            .garden-history{
                display:flex;
                flex-direction:column;
                gap:7px;
                max-height:190px;
                overflow-y:auto;
                -webkit-overflow-scrolling:touch;
            }
            .garden-history-item{
                font-size:11px;
                color:var(--t3);
                background:linear-gradient(180deg,#fff,#F9FAFB);
                border:1px solid var(--bd1);
                border-radius:14px;
                padding:8px 10px;
                display:flex;
                gap:7px;
                align-items:flex-start;
            }
            .garden-history-item::before{
                content:'🌿';
                flex-shrink:0;
            }
            .garden-empty-mini{
                text-align:center;
                padding:14px 8px;
                color:var(--t4);
                font-size:11px;
                border:1px dashed var(--bd2);
                border-radius:16px;
                background:rgba(255,255,255,.55);
            }
            .garden-plots{
                display:grid;
                grid-template-columns:repeat(4,1fr);
                gap:8px;
                padding:0 14px 14px;
                position:relative;
                z-index:5;
                background:rgba(255,255,255,.74);
                border-top:1px solid rgba(255,255,255,.55);
            }
            .garden-plot-btn{
                min-height:82px;
                border-radius:18px;
                border:1.5px solid rgba(212,212,216,.86);
                background:linear-gradient(180deg,#fff,#F9FAFB);
                box-shadow:0 8px 18px rgba(15,23,42,.05);
                padding:8px 6px;
                display:flex;
                flex-direction:column;
                align-items:center;
                justify-content:center;
                gap:3px;
                transition:transform .12s,box-shadow .12s,border-color .12s,background .12s;
                position:relative;
                overflow:hidden;
            }
            .garden-plot-btn::before{
                content:'';
                position:absolute;
                inset:auto 10px 8px 10px;
                height:15px;
                border-radius:50%;
                background:linear-gradient(180deg,#B45309,#78350F);
                opacity:.72;
            }
            .garden-plot-btn:hover{transform:translateY(-1px);box-shadow:0 12px 22px rgba(22,163,74,.10)}
            .garden-plot-btn.on{
                border-color:#10B981;
                background:linear-gradient(180deg,#ECFDF5,#fff);
                box-shadow:0 0 0 3px rgba(16,185,129,.12),0 12px 24px rgba(22,163,74,.12);
            }
            .garden-plot-btn.ready{
                border-color:#F59E0B;
                background:linear-gradient(180deg,#FFFBEB,#fff);
                animation:gReadyPulse 1.4s ease-in-out infinite;
            }
            @keyframes gReadyPulse{0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.16)}50%{box-shadow:0 0 0 5px rgba(245,158,11,.08)}}
            .garden-plot-emoji{
                position:relative;
                z-index:1;
                font-size:26px;
                line-height:1;
                filter:drop-shadow(0 5px 7px rgba(22,101,52,.18));
            }
            .garden-plot-name{
                position:relative;
                z-index:1;
                font-size:9px;
                font-weight:900;
                color:var(--t3);
                line-height:1;
            }
            .garden-plot-bar{
                position:relative;
                z-index:1;
                width:100%;
                height:5px;
                border-radius:999px;
                background:#E5E7EB;
                overflow:hidden;
                margin-top:3px;
            }
            .garden-plot-bar span{
                display:block;
                height:100%;
                width:0;
                border-radius:999px;
                background:linear-gradient(90deg,#10B981,#84CC16,#FACC15);
            }
            @media(max-width:480px){
                .avatar-preview-card{align-items:center;flex-direction:column;text-align:center}
                .avatar-preview-stage{width:150px;height:150px}
                #avatar-preview-canvas{width:146px;height:146px}
                .garden-grid,.garden-inv{grid-template-columns:repeat(3,minmax(0,1fr));gap:6px}.garden-plots{grid-template-columns:repeat(2,1fr)}.garden-plot-btn{min-height:76px}
                .garden-seed,.garden-feed{padding:8px 5px;min-height:88px;border-radius:16px}
                .garden-seed span,.garden-feed span{width:34px;height:34px;font-size:21px}
                .garden-actions{grid-template-columns:1fr 1fr}
