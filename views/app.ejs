function initUserAvatar3DRotation(){
    var active=null,startX=0,startY=0,startRx=-10,startRy=24;
    function nearestAvatar(target){return target&&target.closest?target.closest('.plong-user-avatar'):null}
    document.addEventListener('pointerdown',function(e){
        var el=nearestAvatar(e.target);
        if(!el||(!el.querySelector('.uav3d-avatar')&&!el.querySelector('.uav-human-avatar')))return;
        active=el;
        startX=e.clientX;startY=e.clientY;
        startRx=parseFloat(el.dataset.rx||'-4')||-4;
        startRy=parseFloat(el.dataset.ry||'12')||12;
        el.classList.add('is-dragging');
        try{el.setPointerCapture&&el.setPointerCapture(e.pointerId)}catch(_){}
    },{passive:true});
    document.addEventListener('pointermove',function(e){
        if(!active)return;
        var dx=e.clientX-startX,dy=e.clientY-startY;
        var ry=Math.max(-42,Math.min(42,startRy+dx*.32));
        var rx=Math.max(-14,Math.min(12,startRx-dy*.18));
        active.dataset.ry=String(ry);
        active.dataset.rx=String(rx);
        active.style.setProperty('--uav-ry',ry+'deg');
        active.style.setProperty('--uav-rx',rx+'deg');
    },{passive:true});
    function endDrag(){
        if(active)active.classList.remove('is-dragging');
        active=null;
    }
    document.addEventListener('pointerup',endDrag,{passive:true});
    document.addEventListener('pointercancel',endDrag,{passive:true});
}

