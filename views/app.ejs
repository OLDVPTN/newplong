            /* SEPARATE GARDEN SHEETS + CLEANER GARDEN */
            .garden-sheet{
                position:fixed;
                inset:0;
                z-index:9500;
                display:none;
                align-items:flex-end;
                justify-content:center;
            }
            .garden-sheet.show{display:flex}
            .garden-sheet-backdrop{
                position:absolute;
                inset:0;
                background:rgba(17,17,19,.34);
                -webkit-backdrop-filter:blur(8px);
                backdrop-filter:blur(8px);
            }
            .garden-sheet-panel{
                position:relative;
                z-index:1;
                width:min(720px,100%);
                max-height:min(78dvh,620px);
                overflow:auto;
                -webkit-overflow-scrolling:touch;
                background:var(--bg2);
                border:1px solid var(--bd1);
                border-radius:24px 24px 0 0;
                padding:14px;
                box-shadow:0 -18px 60px rgba(15,23,42,.18);
                animation:gSheetIn .18s ease both;
            }
            @keyframes gSheetIn{from{transform:translateY(18px);opacity:.8}to{transform:translateY(0);opacity:1}}
            .garden-sheet-head{
                display:flex;
                align-items:flex-start;
                justify-content:space-between;
                gap:12px;
                margin-bottom:12px;
            }
            .garden-sheet-head strong{
                display:block;
                font-size:14px;
                font-weight:900;
                color:var(--t1);
            }
            .garden-sheet-head span{
                display:block;
                font-size:11px;
                color:var(--t3);
                margin-top:2px;
            }
            .garden-sheet-close{
                width:36px;height:36px;
                border-radius:12px;
                display:flex;
                align-items:center;
                justify-content:center;
                background:var(--bg3);
                border:1px solid var(--bd1);
                color:var(--t3);
                flex-shrink:0;
            }
            .garden-sheet-grid{
                grid-template-columns:repeat(3,1fr)!important;
            }
            .garden-tycoon-actions{
                grid-template-columns:1fr 1fr!important;
            }
            @media(min-width:900px){
                .garden-sheet{
                    align-items:center;
                    padding-left:var(--side-w);
                }
                .garden-sheet-panel{
                    border-radius:24px;
                    max-width:620px;
                }
            }
            @media(max-width:640px){
                .garden-sheet-panel{
                    max-height:74dvh;
                    padding:12px;
                    border-radius:20px 20px 0 0;
                }
                .garden-sheet-grid{
                    display:grid!important;
                    grid-template-columns:repeat(3,minmax(0,1fr))!important;
                    overflow:visible!important;
                    gap:7px!important;
                }
                .garden-sheet-grid .garden-seed,
                .garden-sheet-grid .garden-feed{
                    min-width:0!important;
                    max-width:none!important;
                    width:100%!important;
                }
                .garden-actions{
                    grid-template-columns:repeat(3,1fr)!important;
                }
                .garden-tycoon-actions{
                    grid-template-columns:1fr 1fr!important;
                }
            }
            @media(max-width:370px){
                .garden-sheet-grid{
                    grid-template-columns:1fr 1fr!important;
                }
            }



            
