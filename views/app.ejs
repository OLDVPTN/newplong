function initSocialFeatures(){
    document.querySelectorAll('.mood-option').forEach(function(btn){btn.addEventListener('click',function(){document.querySelectorAll('.mood-option').forEach(function(x){x.classList.remove('active')});btn.classList.add('active');socialState.mood=btn.dataset.mood||'tenang';});});
    var moodSave=document.getElementById('mood-save');if(moodSave)moodSave.addEventListener('click',saveMoodCheckin);
    var notifRefresh=document.getElementById('notif-refresh');if(notifRefresh)notifRefresh.addEventListener('click',function(){loadNotifications(false)});
    var notifAll=document.getElementById('notif-read-all');if(notifAll)notifAll.addEventListener('click',markAllNotificationsRead);
    document.addEventListener('click',function(e){
        var n=e.target.closest('[data-notif-read]');if(n){markNotificationRead(n.dataset.notifRead);return;}
        var sc=e.target.closest('[data-support-close]');if(sc){closeSupportModal();return;}
        var tpl=e.target.closest('[data-support-message]');if(tpl){var m=document.getElementById('support-message');if(m)m.value=tpl.dataset.supportMessage||'';return;}
    });
    var send=document.getElementById('support-send');if(send)send.addEventListener('click',sendSupportMessage);
    document.querySelectorAll('.calm-duration-btn').forEach(function(btn){btn.addEventListener('click',function(){if(socialState.calmRunning)return;document.querySelectorAll('.calm-duration-btn').forEach(function(x){x.classList.remove('active')});btn.classList.add('active');setCalmDuration(Number(btn.dataset.duration||60));});});
    var calmStart=document.getElementById('calm-start');if(calmStart)calmStart.addEventListener('click',startCalmSession);
    var achievementRefresh=document.getElementById('achievement-refresh');if(achievementRefresh)achievementRefresh.addEventListener('click',function(){loadAchievements(false)});
    setCalmDuration(60);
    loadNotifications(true);loadMoodSummary(true);loadCalmStats(true);loadAchievements(true);
    clearInterval(socialState.notifTimer);
    socialState.notifTimer=setInterval(function(){if(!document.hidden)loadNotifications(true)},10000);
}


var growthState={
    safety:null,
    reportTarget:null,
    reportName:'',
    quests:[],
    summaries:[],
    introRemoved:true
};
function petReactionForMood(mood){
    var map={
        tenang:['😌','Pet kamu ikut tenang. Aura hijau lembut aktif dan energi pulih pelan-pelan.'],
        senang:['😊','Pet kamu happy dan lebih aktif. Hari ini cocok buat rawat kebun.'],
        sedih:['🤗','Pet kamu mendekat seperti ingin menemani. Coba kirim dukungan ke teman atau buka Ruang Tenang.'],
        marah:['🫧','Pet kamu mengajak napas pelan. Energi panas diarahkan jadi EXP kecil.'],
        galau:['🌧️','Pet kamu duduk di sampingmu. Tidak harus langsung selesai, pelan-pelan dulu.'],
        stres:['😵‍💫','Pet kamu menyalakan mode tenang. Saran: sesi napas 60 detik.'],
        capek:['🥱','Pet kamu ikut istirahat. Hari ini cukup rawat hal kecil saja.'],
        kosong:['🫥','Pet kamu memberi sinyal hangat. Mulai dari satu check-in kecil sudah cukup.'],
        overthinking:['🌀','Pet kamu mengajak grounding 5-4-3-2-1 agar pikiran lebih pelan.']
    };
    return map[mood]||['🐾','Pet kamu menunggu mood check-in berikutnya.'];
}
function applyPetReaction(mood){
    if(!state.pet)state.pet={name:'Plong'};
    var r=petReactionForMood(mood);
    state.pet.moodReaction={mood:mood,emoji:r[0],text:r[1],at:new Date().toISOString()};
    if(['senang','tenang'].includes(mood))state.pet.happy=Math.min(100,(Number(state.pet.happy||50)+4));
    if(['stres','marah','overthinking'].includes(mood))state.pet.energy=Math.max(0,(Number(state.pet.energy||70)-3));
    if(['sedih','kosong','galau'].includes(mood))state.pet.bond=Math.min(100,(Number(state.pet.bond||0)+3));
    if(typeof save==='function')save();
}
function renderPetReaction(today){
    var box=document.getElementById('pet-reaction-box');if(!box)return;
    var mood=(today&&today.mood)||(state.pet&&state.pet.moodReaction&&state.pet.moodReaction.mood)||null;
    if(!mood){box.textContent='🐾 Pet menunggu check-in mood.';return;}
    var r=petReactionForMood(mood);
    box.innerHTML='<strong style="font-size:22px">'+r[0]+' '+friendEsc(mood)+'</strong><p style="margin:8px 0 0">'+friendEsc(r[1])+'</p>';
}

