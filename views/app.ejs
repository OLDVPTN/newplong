function setCalmDuration(n){
    socialState.calmDuration=n;socialState.calmRemaining=n;
    var timer=document.getElementById('calm-timer');if(timer)timer.textContent=n;
}
function setCalmInstruction(){
    var i=document.getElementById('calm-instruction');
    if(!i)return;
    var phase=socialState.calmRemaining%12;
    i.textContent=phase>6?'Hembuskan napas pelan':'Tarik napas pelan';
}
async function completeCalmSession(){
    try{
        var r=await apiFetch('/api/calm/complete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mode:'breathing',durationSeconds:socialState.calmDuration})});
        var d=await r.json();if(!r.ok||!d.ok)throw new Error(d.error||'Gagal menyimpan sesi.');
        toast('Sesi Ruang Tenang selesai.');
        await loadCalmStats(true);await loadAchievements(true);await loadNotifications(true);if(typeof loadQuests==='function')await loadQuests(true);
    }catch(e){toast(e.message||'Gagal menyimpan sesi tenang.')}
}
function startCalmSession(){
    if(socialState.calmRunning)return;
    socialState.calmRunning=true;socialState.calmRemaining=socialState.calmDuration;
    var btn=document.getElementById('calm-start'),orb=document.getElementById('calm-orb'),timer=document.getElementById('calm-timer');
    if(btn)btn.innerHTML='<i class="fas fa-hourglass-half"></i> Sesi berjalan';
    if(orb)orb.classList.add('breathe');
    clearInterval(socialState.calmTimer);
    socialState.calmTimer=setInterval(function(){
        socialState.calmRemaining-=1;
        if(timer)timer.textContent=Math.max(0,socialState.calmRemaining);
        setCalmInstruction();
        if(socialState.calmRemaining<=0){
            clearInterval(socialState.calmTimer);socialState.calmRunning=false;
            if(btn)btn.innerHTML='<i class="fas fa-play"></i> Mulai Sesi';
            if(orb)orb.classList.remove('breathe');
            completeCalmSession();
        }
    },1000);
}
