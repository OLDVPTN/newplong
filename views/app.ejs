var lifeState={data:null,loading:false,timer:null};
function renderLifeLoop(data){
    if(!data)return;
    lifeState.data=data;
    var routine=data.routine||{},journey=data.journey||{},event=data.event||{},recap=data.recap||{},surprise=data.surprise||{};
    var setText=function(id,text){var el=document.getElementById(id);if(el)el.textContent=text;};

    setText('life-routine-phase',(routine.phase||'pet routine').toUpperCase());
    setText('life-routine-title',routine.title||'Pet menunggumu');
    setText('life-routine-body',routine.body||'Ceritakan satu hal kecil hari ini.');
    setText('home-pet-bubble-small',routine.mood?('Mood: '+routine.mood):'Ready to listen!');
    setText('home-pet-bubble-strong',routine.body||'Let’s make today lighter.');

    setText('life-journey-title',(journey.icon||'🫧')+' '+(journey.title||'Misi emosi hari ini'));
    setText('life-journey-body',journey.body||'Satu langkah kecil sudah cukup.');
    var journeyBtn=document.getElementById('life-journey-action');
    if(journeyBtn){journeyBtn.textContent=journey.action||'Mulai';journeyBtn.dataset.page=journey.page||'pg-mood';}

    setText('life-event-icon',event.icon||'🌼');
    setText('life-event-title',event.title||'Event Bunga Emosi');
    setText('life-event-body',event.body||'Setiap mood harian memberi warna berbeda.');
    setText('life-event-bonus',event.bonus||'Surprise reward harian aktif');

    setText('life-recap-title','Progress minggu ini');
    setText('life-recap-body',recap.message||'Minggu ini masih menunggu langkah kecil pertamamu.');
    setText('life-recap-mood',recap.moodCheckins||0);
    setText('life-recap-calm',recap.calmSessions||0);
    setText('life-recap-support',recap.supportsSent||0);
    setText('life-recap-badge',recap.badgesUnlocked||0);

    var sTitle=document.getElementById('life-surprise-title'),sBody=document.getElementById('life-surprise-body'),sBtn=document.getElementById('life-surprise-claim');
    if(surprise.claimed){
        var reward=surprise.reward||{};
        if(sTitle)sTitle.textContent=(reward.icon||'🎁')+' '+(reward.title||'Hadiah sudah dibuka');
        if(sBody)sBody.textContent='Kamu sudah membuka surprise reward hari ini. Balik lagi besok ya.';
        if(sBtn){sBtn.disabled=true;sBtn.innerHTML='<i class="fas fa-check"></i> Sudah dibuka';}
    }else{
        if(sTitle)sTitle.textContent='Hadiah kejutan hari ini';
        if(sBody)sBody.textContent='Buka satu hadiah kecil. Isinya bisa coins, EXP, air kebun, atau seed bonus.';
        if(sBtn){sBtn.disabled=false;sBtn.innerHTML='<i class="fas fa-gift"></i> Buka hadiah';}
    }
}
async function loadLifeLoop(silent){
    if(!authToken||lifeState.loading)return;
    lifeState.loading=true;
    try{
        var r=await apiFetch('/api/life/home');var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Gagal memuat life loop.');
        renderLifeLoop(d);
    }catch(e){if(!silent)toast(e.message||'Gagal memuat life loop.')}
    finally{lifeState.loading=false;}
}
async function claimLifeSurprise(){
    if(!authToken){showAuth('Silakan login dulu.');return;}
    var btn=document.getElementById('life-surprise-claim');if(btn)btn.disabled=true;
    try{
        var r=await apiFetch('/api/life/surprise/claim',{method:'POST'});var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Gagal membuka hadiah.');
        if(d.state)applyStateFromServer(d.state);
        toast(d.message||'Surprise reward terbuka.');
        await loadLifeLoop(true);await loadNotifications(true);if(typeof loadQuests==='function')await loadQuests(true);
    }catch(e){toast(e.message||'Gagal membuka hadiah.');if(btn)btn.disabled=false;}
}
function initLifeLoop(){
    var btn=document.getElementById('life-surprise-claim');if(btn)btn.addEventListener('click',claimLifeSurprise);
    loadLifeLoop(true);
    clearInterval(lifeState.timer);
    lifeState.timer=setInterval(function(){if(!document.hidden)loadLifeLoop(true)},30000);
    document.addEventListener('visibilitychange',function(){if(!document.hidden)loadLifeLoop(true)});
}


var dashboardState={loading:false,data:null,timer:null};
function formatDurationSeconds(seconds){
    seconds=Number(seconds||0);
    if(seconds<60)return seconds+' detik';
    var m=Math.floor(seconds/60),h=Math.floor(m/60);
    if(h>0)return h+' jam '+(m%60)+' menit';
    return m+' menit';
}
