            /* ═══════ SMOOTH 5S PAGE LOADER ═══════ */
            .page-loader{
                position:fixed;
                inset:0;
                z-index:999999;
                display:flex;
                align-items:center;
                justify-content:center;
                padding:24px;
                background:
                    radial-gradient(circle at 50% 18%,rgba(255,255,255,.96) 0,rgba(255,247,237,.94) 34%,rgba(240,253,244,.96) 100%),
                    linear-gradient(180deg,#fff7ed,#f0fdf4);
                opacity:0;
                visibility:hidden;
                pointer-events:none;
                transform:translateZ(0);
                transition:opacity .38s ease,visibility .38s ease;
            }
            .page-loader.show{
                opacity:1;
                visibility:visible;
                pointer-events:auto;
            }
            .page-loader.hide{
                opacity:0;
                visibility:hidden;
                pointer-events:none;
            }
            .page-loader-card{
                width:min(310px,calc(100vw - 48px));
                padding:28px 24px 24px;
                border-radius:32px;
                background:rgba(255,255,255,.88);
                border:1px solid rgba(255,255,255,.92);
                box-shadow:0 28px 90px rgba(120,72,32,.18);
                text-align:center;
                backdrop-filter:blur(18px);
                -webkit-backdrop-filter:blur(18px);
                transform:translateY(10px) scale(.98);
                animation:loaderCardIn .55s cubic-bezier(.22,1,.36,1) both;
            }
            .page-loader-logo{
                width:68px;
                height:68px;
                margin:0 auto 14px;
                border-radius:24px;
                display:grid;
                place-items:center;
                font-size:34px;
                background:linear-gradient(180deg,#fff7ed,#dcfce7);
                box-shadow:inset 0 2px 0 rgba(255,255,255,.95),0 14px 30px rgba(34,197,94,.18);
                animation:loaderFloat 1.45s ease-in-out infinite;
            }
            .page-loader-ring{
                width:42px;
                height:42px;
                margin:0 auto 14px;
                border-radius:50%;
                position:relative;
                background:conic-gradient(from 0deg,#f97316,#22c55e,#38bdf8,#f97316);
                animation:loaderSpin 1s linear infinite;
            }
            .page-loader-ring::after{
                content:'';
                position:absolute;
                inset:5px;
                border-radius:50%;
                background:rgba(255,255,255,.96);
            }
            .page-loader-ring span{
                position:absolute;
                inset:0;
                border-radius:50%;
                filter:blur(8px);
                opacity:.38;
                background:inherit;
            }
            .page-loader-card strong{
                display:block;
                font-size:16px;
                color:#7c2d12;
                font-weight:900;
                letter-spacing:-.2px;
            }
            .page-loader-card > span{
                display:block;
                margin-top:6px;
                font-size:11px;
                line-height:1.45;
                color:#9a6d4b;
                font-weight:800;
            }
            .page-loader-progress{
                height:10px;
                margin-top:18px;
                border-radius:999px;
                background:#ffedd5;
                overflow:hidden;
                box-shadow:inset 0 1px 3px rgba(124,45,18,.08);
            }
            .page-loader-progress span{
                display:block;
                width:0%;
                height:100%;
                border-radius:999px;
                background:linear-gradient(90deg,#f97316,#22c55e);
                box-shadow:0 0 16px rgba(34,197,94,.28);
                transition:width .25s ease;
            }
            .page-loader-card small{
                display:block;
                margin-top:9px;
                font-size:10px;
                color:#c05621;
                font-weight:900;
                letter-spacing:.35px;
            }
            @keyframes loaderSpin{to{transform:rotate(360deg)}}
            @keyframes loaderFloat{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-6px) scale(1.04)}}
            @keyframes loaderCardIn{from{opacity:0;transform:translateY(18px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
            @media(prefers-reduced-motion:reduce){
                .page-loader-card,.page-loader-logo,.page-loader-ring{animation:none!important}
                .page-loader,.page-loader-progress span{transition:none!important}
            }

        

