            function initials(name){name=(name||"VokaMon User").trim();var parts=name.split(/\s+/).filter(Boolean);return ((parts[0]||"V")[0]+(parts[1]?parts[1][0]:"")).toUpperCase()}
            function totalVents(){return Object.values(state.emotions||{}).reduce(function(a,b){return a+(Number(b)||0)},0)}
            function renderAccount(){
                var acc=state.account||{name:"VokaMon User",username:"@vokamon.user",bio:"Lagi belajar memahami emosi pelan-pelan."};
                accTxt("acct-avatar",initials(acc.name));
                accTxt("acct-name-display",acc.name||"VokaMon User");
                accTxt("acct-username-display",acc.username||"@vokamon.user");
                accTxt("acct-bio-display",acc.bio||"Lagi belajar memahami emosi pelan-pelan.");
                accTxt("acct-coins",state.coins||0);
                accTxt("acct-level",state.pet&&state.pet.level?state.pet.level:1);
                accTxt("acct-vent",totalVents());
                accTxt("acct-art",state.art?state.art.length:0);
                accTxt("acct-model",ML2[state.gm]||state.gm||"Curhat Santai");
                accTxt("acct-lang",AL[state.al]?AL[state.al].label:"Indonesia santai");
                accTxt("acct-chat",(state.ch?state.ch.length:0)+" pesan");
                accVal("acc-name",acc.name||"");
                accVal("acc-username",acc.username||"");
                accVal("acc-bio",acc.bio||"");
            }
            function initAccount(){
                var saveBtn=document.getElementById("acc-save"),clearBtn=document.getElementById("acc-clear-chat"),logoutBtn=document.getElementById("acc-logout"),resetBtn=document.getElementById("acc-reset");
                if(saveBtn)saveBtn.addEventListener("click",function(){
                    var n=document.getElementById("acc-name"),u=document.getElementById("acc-username"),b=document.getElementById("acc-bio");
                    var username=(u&&u.value.trim())||"@vokamon.user";
                    if(username.charAt(0)!=="@")username="@"+username;
                    state.account={name:(n&&n.value.trim())||"VokaMon User",username:username,bio:(b&&b.value.trim())||"Lagi belajar memahami emosi pelan-pelan."};
                    save();
                    apiFetch("/api/user/profile",{method:"PUT",headers:{"Content-Type":"application/json"},body:JSON.stringify({name:state.account.name,username:state.account.username,bio:state.account.bio})}).then(function(r){return r.json()}).then(function(data){if(data&&data.user)authUser=data.user;if(data&&data.state)applyRemoteState(data.state)}).catch(function(){});
                    renderAccount();toast("Profil disimpan");
                });
                if(clearBtn)clearBtn.addEventListener("click",function(){
                    if(!confirm("Hapus semua riwayat chat?"))return;
                    state.ch=[];save();
                    if(chatMsgs)chatMsgs.innerHTML="";
                    chatStarted=false;
                    var hero=document.getElementById("pp-hero"),chat=document.getElementById("pp-chat");
                    if(hero)hero.classList.remove("hide");
                    if(chat)chat.classList.remove("on");
                    renderAccount();toast("Riwayat chat dihapus");
                });
                if(logoutBtn)logoutBtn.addEventListener("click",function(){
                    if(!confirm("Logout dari akun ini?"))return;
                    logout(false);
                });
                if(resetBtn)resetBtn.addEventListener("click",function(){
                    if(!confirm("Reset semua data VokaMon di akun ini? Coins, galeri, profil, dan chat akan direset."))return;
                    state=defaultStateForUser(authUser);
                    save();
                    syncStateToPostgreSQL().finally(function(){location.reload()});
                });
                renderAccount();
            }

            /* ═══════ SELECTORS ═══════ */
            var hero=document.getElementById("pp-hero"),chat=document.getElementById("pp-chat");
            var heroInput=document.getElementById("hero-input"),heroSend=document.getElementById("hero-send");
            var chatInput=document.getElementById("chat-input"),chatSendBtn=document.getElementById("chat-send");
            var chatMsgs=document.getElementById("chat-msgs");

            var isBusy=false,chatStarted=false;
            var selPairs=[{t:"s-m0",d:"d-m0",w:"w-m0",l:"l-m0",type:"model"},{t:"s-l0",d:"d-l0",w:"w-l0",l:"l-l0",type:"lang"}];

            function cloneDropdowns(){var srcM=document.getElementById("d-m0"),srcL=document.getElementById("d-l0"),wM1=document.getElementById("w-m1"),wL1=document.getElementById("w-l1");if(srcM&&wM1&&!wM1.querySelector(".pp-drop")){var cl=srcM.cloneNode(true);cl.id="d-m1";wM1.appendChild(cl);cl.querySelectorAll(".pp-opt").forEach(function(o){o.addEventListener("click",function(e){e.stopPropagation();if(o.disabled){toast("Model maintenance");return}setM(o.dataset.model)})});cl.addEventListener("click",function(e){e.stopPropagation()});selPairs.push({t:"s-m1",d:"d-m1",w:"w-m1",l:"l-m1",type:"model"})}if(srcL&&wL1&&!wL1.querySelector(".pp-drop")){var cl2=srcL.cloneNode(true);cl2.id="d-l1";wL1.appendChild(cl2);cl2.querySelectorAll(".pp-opt").forEach(function(o){o.addEventListener("click",function(e){e.stopPropagation();setL(o.dataset.lang)})});cl2.addEventListener("click",function(e){e.stopPropagation()});selPairs.push({t:"s-l1",d:"d-l1",w:"w-l1",l:"l-l1",type:"lang"})}}

            function posDrop(trig,drop){var pr=trig.getBoundingClientRect();drop.style.position="fixed";drop.style.left=Math.max(6,Math.min(pr.left,window.innerWidth-drop.offsetWidth-6))+"px";var top=pr.bottom+5;if(top+drop.offsetHeight>window.innerHeight-6)drop.style.top=Math.max(6,pr.top-drop.offsetHeight-5)+"px";else drop.style.top=top+"px"}
            function closeD(exW){selPairs.forEach(function(p){if(!p.d||p.w===exW)return;var d=document.getElementById(p.d),t=document.getElementById(p.t);if(d)d.classList.remove("show");if(t){t.classList.remove("open");t.setAttribute("aria-expanded","false")}})}
            function togD(p){var d=document.getElementById(p.d),t=document.getElementById(p.t);if(!d||!t)return;var will=!d.classList.contains("show");closeD(will?p.w:null);if(will){d.classList.add("show");d.style.visibility="hidden";posDrop(t,d);d.style.visibility="";t.classList.add("open");t.setAttribute("aria-expanded","true")}else{d.classList.remove("show");t.classList.remove("open");t.setAttribute("aria-expanded","false")}}
            function syncM(v){selPairs.filter(function(p){return p.type==="model"}).forEach(function(p){var d=document.getElementById(p.d);if(!d)return;d.querySelectorAll(".pp-opt[data-model]").forEach(function(o){var on=o.dataset.model===v;o.classList.toggle("on",on);o.setAttribute("aria-selected",on?"true":"false")});var l=document.getElementById(p.l);if(l)l.textContent=ML2[v]||v})}
            function syncL(v){selPairs.filter(function(p){return p.type==="lang"}).forEach(function(p){var d=document.getElementById(p.d);if(!d)return;d.querySelectorAll(".pp-opt[data-lang]").forEach(function(o){var on=o.dataset.lang===v;o.classList.toggle("on",on);o.setAttribute("aria-selected",on?"true":"false")});var l=document.getElementById(p.l);if(l)l.textContent=AL[v]?AL[v].label:"Indonesia santai"})}
            function setM(v,s){if(s===undefined)s=true;var opts=document.querySelectorAll('.pp-opt[data-model="'+v+'"]');var ok=false;opts.forEach(function(o){if(!o.disabled)ok=true});var fv=ok?v:"qwen2.5:3b";state.gm=fv;syncM(fv);save();closeD();if(s)toast("Model: "+(ML2[fv]||fv))}
            function setL(v,s){if(s===undefined)s=true;var fv=AL[v]?v:"id";state.al=fv;syncL(fv);save();closeD();if(s)toast("Bahasa: "+(AL[fv]?AL[fv].label:v))}

            function initSel(){selPairs.forEach(function(p){var t=document.getElementById(p.t);if(t)t.addEventListener("click",function(e){e.stopPropagation();togD(p)})});document.querySelectorAll("#d-m0 .pp-opt[data-model]").forEach(function(o){o.addEventListener("click",function(e){e.stopPropagation();if(o.disabled){toast("Model maintenance");return}setM(o.dataset.model)})});document.querySelectorAll("#d-l0 .pp-opt[data-lang]").forEach(function(o){o.addEventListener("click",function(e){e.stopPropagation();setL(o.dataset.lang)})});document.addEventListener("click",function(e){if(!e.target.closest(".pp-sel-btn")&&!e.target.closest(".pp-drop"))closeD()});document.addEventListener("keydown",function(e){if(e.key==="Escape")closeD()});window.addEventListener("resize",function(){selPairs.forEach(function(p){var d=document.getElementById(p.d),t=document.getElementById(p.t);if(d&&d.classList.contains("show"))posDrop(t,d)})});setM(state.gm||"qwen2.5:3b",false);setL(gLK(),false)}
            initSel();

            function autoR(ta){ta.style.height="auto";ta.style.height=Math.min(ta.scrollHeight,140)+"px"}
            heroInput.addEventListener("input",function(){autoR(heroInput)});
            chatInput.addEventListener("input",function(){autoR(chatInput)});

            function scrollToBottom(){
                if(!chatMsgs)return;
                // Use requestAnimationFrame to ensure DOM has updated
                requestAnimationFrame(function(){
                    chatMsgs.scrollTop=chatMsgs.scrollHeight;
                });
            }

            function toChat(){if(chatStarted)return;chatStarted=true;cloneDropdowns();hero.classList.add("hide");chat.classList.add("on");setTimeout(function(){chatInput.focus();scrollToBottom()},60)}

            heroSend.addEventListener("click",function(){sendFrom(heroInput)});
            chatSendBtn.addEventListener("click",function(){sendFrom(chatInput)});
            heroInput.addEventListener("keydown",function(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();sendFrom(heroInput)}});
            chatInput.addEventListener("keydown",function(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();sendFrom(chatInput)}});

            document.querySelectorAll(".pp-sug").forEach(function(s){
                s.addEventListener("click",function(){
                    heroInput.value=s.dataset.q;
                    sendFrom(heroInput);
                });
            });

            function sendFrom(input){
                if(!authToken){showAuth("Silakan login dulu sebelum menggunakan asisten.");return;}
                if(isBusy)return;
                var msg=input.value.trim();
                if(!msg)return;
                input.value="";
                input.style.height="auto";
                if(!chatStarted)toChat();
                addMsg(msg,"user");
                state.ch.push({role:"user",parts:[{text:msg}]});
                state.ch=state.ch.slice(-10);
                save();
                setBusy(true);
                var tp=document.createElement("div");
                tp.className="pp-msg";
                tp.id="typing";
                tp.innerHTML='<div class="pp-msg-bot"><div class="pp-msg-ava"><i class="fas fa-comment-dots"></i></div><div class="pp-msg-body"><div class="pp-msg-name">Plong</div><div class="pp-bbl-bot" style="color:var(--t4)">Mengetik...</div></div></div>';
                chatMsgs.appendChild(tp);
                scrollToBottom();
                fetch("/api/chat",{method:"POST",headers:Object.assign({"Content-Type":"application/json"},authHeaders()),body:JSON.stringify({message:msg,model:state.gm||"qwen2.5:3b",language:state.al||"id",history:state.ch})})
                .then(function(r){return r.json()})
                .then(function(data){
                    tp.remove();
                    var reply=data.reply||"Aku belum bisa jawab sekarang.";
                    addMsg(reply,"bot");
                    if(data.state)applyStateFromServer(data.state);
                    state.ch.push({role:"model",parts:[{text:reply}]});
                    state.ch=state.ch.slice(-10);
                    save();
                    if(data.reward&&data.reward.coins)toast("Plong menghasilkan +"+data.reward.coins+" Soul Coins");
                    addFollowUps();
                })
                .catch(function(){
                    tp.remove();
                    addMsg("Ups, server AI lokal bermasalah. Pastikan Ollama dan Node.js aktif ya.","bot");
                })
                .finally(function(){setBusy(false);chatInput.focus()});
            }

            function addMsg(text,role){
                var div=document.createElement("div");
                div.className="pp-msg";
                if(role==="user"){
                    div.classList.add("pp-msg-user");
                    div.innerHTML='<div class="pp-bbl">'+escH(text)+"</div>";
                }else{
                    div.classList.add("pp-msg-bot");
                    div.innerHTML='<div class="pp-msg-ava"><i class="fas fa-comment-dots"></i></div><div class="pp-msg-body"><div class="pp-msg-name">Plong</div><div class="pp-bbl-bot">'+escH(text)+"</div></div>";
                }
                chatMsgs.appendChild(div);
                scrollToBottom();
            }

            function addFollowUps(){
                var wrap=document.createElement("div");
                wrap.className="pp-msg pp-msg-bot";
                var shuffled=FOLLOWS.slice().sort(function(){return Math.random()-0.5}).slice(0,3);
                wrap.innerHTML='<div class="pp-msg-ava" style="visibility:hidden"><i class="fas fa-comment-dots"></i></div><div class="pp-msg-body"><div class="pp-fu">'+
                    shuffled.map(function(q){return '<button class="pp-fu-btn" data-q="'+escA(q)+'">'+escH(q)+"</button>"}).join("")+"</div></div>";
                chatMsgs.appendChild(wrap);
                wrap.querySelectorAll(".pp-fu-btn").forEach(function(b){
                    b.addEventListener("click",function(){
                        chatInput.value=b.dataset.q;
                        sendFrom(chatInput);
                    });
                });
                scrollToBottom();
            }

            function setBusy(b){isBusy=b;heroInput.disabled=b;chatInput.disabled=b;heroSend.disabled=b;chatSendBtn.disabled=b;chatInput.placeholder=b?"Plong sedang mengetik...":"Tanya lagi...";heroInput.placeholder=b?"Plong sedang mengetik...":"Ceritakan apa yang kamu rasakan..."}
            function escH(s){return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")}
            function escA(s){return s.replace(/"/g,"&quot;").replace(/'/g,"&#39;")}

            var petPlayBtn=document.getElementById("pet-play"),petCalmBtn=document.getElementById("pet-calm");
            if(petPlayBtn)petPlayBtn.addEventListener("click",function(){petAction("play")});
            if(petCalmBtn)petCalmBtn.addEventListener("click",function(){petAction("calm")});
            var pwClaim=document.getElementById("pet-worker-claim"),pwConvert=document.getElementById("pet-worker-convert"),pwDaily=document.getElementById("pet-worker-daily");
            if(pwClaim)pwClaim.addEventListener("click",function(){petWorkerAction("/api/pet/claim-passive",{})});
            if(pwConvert)pwConvert.addEventListener("click",function(){petWorkerAction("/api/pet/convert-essence",{mood:"all"})});
            if(pwDaily)pwDaily.addEventListener("click",function(){petWorkerAction("/api/pet/daily-bonus",{})});
            setInterval(function(){renderPetWorker()},30000);



function defaultUserAvatar(){
    return {skin:"warm",hair:"soft",face:"smile",outfit:"hoodie",accessory:"none",aura:"tenang",background:"sky",pose:"idle"};
}
function ensureUserAvatar(){
    if(!state.userAvatar)state.userAvatar=defaultUserAvatar();
    var d=defaultUserAvatar();
    Object.keys(d).forEach(function(k){if(!state.userAvatar[k])state.userAvatar[k]=d[k];});
    return state.userAvatar;
}
function userAvatarVars(av){
    av=Object.assign(defaultUserAvatar(),av||{});
    var skin={warm:'#f2b789',fair:'#ffd9bd',tan:'#c78555',deep:'#8b573b'}[av.skin]||'#f2b789';
    var hair={soft:'#3b243f',short:'#1f2937',wavy:'#4a2c2a',cap:'#3158d4'}[av.hair]||'#3b243f';
    var outfit={hoodie:'#ff9349',jacket:'#2563eb',robe:'#7c3aed',tee:'#0d9488'}[av.outfit]||'#ff9349';
    var aura={tenang:'#14b8a6',senang:'#facc15',sedih:'#60a5fa',galau:'#a78bfa',stres:'#fb923c',marah:'#ef4444'}[av.aura]||'#14b8a6';
    var bg={
        sky:['#dbeafe','#fff7ed'],
        garden:['#dcfce7','#f0fdf4'],
        night:['#c7d2fe','#1e1b4b'],
        studio:['#f5f3ff','#f8fafc']
    }[av.background]||['#dbeafe','#fff7ed'];
    return {skin:skin,hair:hair,outfit:outfit,aura:aura,bg1:bg[0],bg2:bg[1]};
}
function userAvatarHumanFaceHtml(face){
    face=String(face||'smile');
    return '<div class="uavh-face-ui face-'+friendEsc(face)+'">'+
        '<span class="uavh-brow left"></span><span class="uavh-brow right"></span>'+
        '<span class="uavh-eye left"></span><span class="uavh-eye right"></span>'+
        '<span class="uavh-nose"></span><span class="uavh-mouth"></span>'+
        '<span class="uavh-blush left"></span><span class="uavh-blush right"></span>'+
    '</div>';
}
function userAvatarHumanHairHtml(av){
    var h=String(av.hair||'soft');
    if(h==='short'){
        return '<div class="uavh-hair hair-short"><span></span><b></b></div>';
    }
    if(h==='wavy'){
        return '<div class="uavh-hair hair-wavy"><span></span><b></b><i></i></div><div class="uavh-side-lock left"></div><div class="uavh-side-lock right"></div>';
    }
    if(h==='cap'){
        return '<div class="uavh-hair hair-cap"><span></span><b></b></div>';
    }
    return '<div class="uavh-hair hair-soft"><span></span><b></b><i></i></div>';
}
function userAvatarHumanAccessoryHtml(av){
    var a=String(av.accessory||'none');
    if(a==='glasses')return '<div class="uavh-glasses"><span></span><span></span><b></b></div>';
    if(a==='headset')return '<div class="uavh-headset"><span></span><span></span><b></b></div>';
    if(a==='halo')return '<div class="uavh-halo"></div>';
    return '';
}
function userAvatarHumanOutfitHtml(av){
    var outfit=String(av.outfit||'hoodie');
    var collar=outfit==='robe'?'uavh-collar robe':outfit==='jacket'?'uavh-collar jacket':outfit==='tee'?'uavh-collar tee':'uavh-collar hoodie';
    return '<div class="uavh-body outfit-'+friendEsc(outfit)+'">'+
        '<div class="'+collar+'"></div>'+
        '<span class="uavh-body-highlight"></span>'+
        '<span class="uavh-emblem"></span>'+
    '</div>';
}
function userAvatarHtml(av){
    av=Object.assign(defaultUserAvatar(),av||{});
    var vars=userAvatarVars(av);
    var cls=[
        'uav-human-avatar',
        'skin-'+av.skin,
        'hair-'+av.hair,
        'face-'+av.face,
        'outfit-'+av.outfit,
        'accessory-'+av.accessory,
        'aura-'+av.aura,
        'bg-'+av.background,
        'pose-'+av.pose
    ].join(' ');
    var style='--skin:'+vars.skin+';--hair:'+vars.hair+';--outfit:'+vars.outfit+';--aura:'+vars.aura+';--bg1:'+vars.bg1+';--bg2:'+vars.bg2+';';
    return '<div class="'+cls+'" style="'+style+'" aria-hidden="true">'+
        '<div class="uavh-bg"></div><div class="uavh-aura"></div><div class="uavh-orbit one"></div><div class="uavh-orbit two"></div><div class="uavh-ground"></div>'+
        '<div class="uavh-stage">'+
            '<div class="uavh-inner">'+
                '<div class="uavh-leg left"></div><div class="uavh-leg right"></div>'+
                '<div class="uavh-shoe left"></div><div class="uavh-shoe right"></div>'+
                userAvatarHumanOutfitHtml(av)+
                '<div class="uavh-arm left"><span></span></div><div class="uavh-arm right"><span></span></div>'+
                '<div class="uavh-neck"></div>'+
                '<div class="uavh-ear left"></div><div class="uavh-ear right"></div>'+
                '<div class="uavh-head">'+userAvatarHumanFaceHtml(av.face)+'</div>'+
                userAvatarHumanHairHtml(av)+
                userAvatarHumanAccessoryHtml(av)+
            '</div>'+
        '</div>'+
        '<div class="uav3d-drag-hint"><i class="fas fa-arrows-rotate"></i> drag</div>'+
    '</div>';
}
function renderUserAvatarInto(el,av){
    if(!el)return;
    av=Object.assign(defaultUserAvatar(),av||{});
    var vars=userAvatarVars(av);
    el.innerHTML='<div class="uav-level2-wrap">'+
        '<canvas class="uav-level2-canvas" aria-label="Avatar 3D"></canvas>'+
        '<div class="uav-level2-loading"><i class="fas fa-cube"></i><span>Memuat avatar 3D...</span></div>'+
        '<div class="uav-level2-fallback"></div>'+
    '</div>';
    el.style.setProperty('--bg1',vars.bg1);
    el.style.setProperty('--bg2',vars.bg2);
    el.style.setProperty('--uav-rx',el.dataset.rx||'-4deg');
    el.style.setProperty('--uav-ry',el.dataset.ry||'12deg');
    var wrap=el.querySelector('.uav-level2-wrap');
    var canvas=el.querySelector('.uav-level2-canvas');
    var fallback=el.querySelector('.uav-level2-fallback');
    if(wrap){
        wrap.style.setProperty('--skin',vars.skin);
        wrap.style.setProperty('--hair',vars.hair);
        wrap.style.setProperty('--outfit',vars.outfit);
        wrap.style.setProperty('--aura',vars.aura);
        wrap.style.setProperty('--bg1',vars.bg1);
        wrap.style.setProperty('--bg2',vars.bg2);
    }
    if(fallback)fallback.innerHTML='<div class="uav-level2-placeholder"><span>3D</span></div><div class="uav-level2-error"></div>';
    if(canvas)canvas.dataset.avatar=JSON.stringify(av);
    el.classList.add('uav-level2-host');
    if(window.PlAvatar3D&&typeof window.PlAvatar3D.render==='function'){
        window.PlAvatar3D.render(el,av);
    }else{
        el.classList.add('uav-level2-pending');
    }
}

function updateUserAvatarButtons(){
    var av=ensureUserAvatar();
    document.querySelectorAll('[data-user-avatar-option]').forEach(function(btn){
        var p=String(btn.dataset.userAvatarOption||'').split(':');
        btn.classList.toggle('active',av[p[0]]===p[1]);
    });
}
function renderUserAvatarWorld(){
    var av=ensureUserAvatar();
    renderUserAvatarInto(document.getElementById('user-avatar-preview'),av);
    renderUserAvatarInto(document.getElementById('user-avatar-profile-preview'),av);
    var name=(state.account&&state.account.name)||'VokaMon User',username=(state.account&&state.account.username)||'@vokamon.user',bio=(state.account&&state.account.bio)||'Bio user akan tampil bersama avatar virtual ini.';
    var set=function(id,v){var el=document.getElementById(id);if(el)el.textContent=v;};
    set('user-avatar-name',name);set('user-avatar-username',username);
    set('avatar-profile-name',name);set('avatar-profile-bio',bio);
    set('avatar-profile-level',state.pet&&state.pet.level?state.pet.level:1);
    set('avatar-profile-aura',(av.aura||'tenang').replace(/^./,function(c){return c.toUpperCase()}));
    var cover=document.getElementById('avatar-profile-cover');
    if(cover){var vars=userAvatarVars(av);cover.style.background='radial-gradient(circle at 50% 20%,rgba(255,255,255,.78),transparent 130px),linear-gradient(135deg,'+vars.bg1+','+vars.bg2+')';}
    updateUserAvatarButtons();
}
function initUserAvatarWorld(){
    ensureDefaults();
    renderUserAvatarWorld();
}
function saveUserAvatarWorld(){
    ensureUserAvatar();
    save();
    renderUserAvatarWorld();
    toast('Avatar user disimpan.');
}

