            async function loadGardenFromServer(){
                if(!authToken)return;
                try{
                    var res=await apiFetch('/api/garden');
                    var data=await res.json();
                    if(res.ok&&data.ok&&data.state){
                        applyStateFromServer(data.state);
                    }else if(data&&data.garden){
                        state.garden=data.garden;
                        ensureDefaults();
                        renderGarden();
                    }
                }catch(e){
                    console.warn('Load garden gagal:',e.message||e);
                }
            }
            async function gardenRequest(url,body){
                if(gardenBusy)return null;
                if(!authToken){showAuth('Silakan login dulu.');return null;}
                setGardenBusy(true);
                try{
                    var res=await apiFetch(url,{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify(body||{})});
                    var text=await res.text();
                    var data={};
                    try{data=text?JSON.parse(text):{};}catch(parseErr){data={error:text||'Response server tidak valid.'};}
                    if(!res.ok||!data.ok){
                        console.warn('Garden request failed',url,res.status,data);
                        throw new Error(data.error||('Aksi kebun gagal. Status '+res.status));
                    }
                    if(data.state)applyStateFromServer(data.state);
                    else if(data.garden){state.garden=data.garden;ensureDefaults();refreshUI();renderGarden();}
                    toast(data.message||'Kebun diperbarui');
                    sP(getPetMood());
                    setTimeout(function(){pullRemoteState(true)},250);
                    return data;
                }catch(e){
                    toast(e.message||'Kebun lagi bermasalah');
                    return null;
                }finally{
                    setGardenBusy(false);
                }
            }
            function gardenPlant(seed){
                var g=ensureGardenLocal(), idx=getActivePlotIndex(), plot=g.plots[idx]||null;
