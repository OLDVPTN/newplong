            .auth-btn{width:100%;min-height:44px;border-radius:12px;background:var(--ac);color:#fff;font-size:14px;font-weight:800;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 14px rgba(232,77,26,.18);transition:transform .12s,background .12s,opacity .12s;margin-top:4px}
