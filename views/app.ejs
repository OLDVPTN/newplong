                .garden-stage{min-height:292px}
                .garden-card{padding:16px}
                .garden-hero-card{padding:0}
                .garden-emoji{font-size:84px}
            }

            
            /* HIFAMI-LIKE GARDEN TYCOON PANEL */
            .garden-tycoon{
                display:grid;
                grid-template-columns:repeat(3,1fr);
                gap:7px;
                margin-bottom:10px;
            }
            .garden-tycoon-stat{
                background:linear-gradient(180deg,#fff,#F8FAFC);
                border:1px solid rgba(212,212,216,.82);
                border-radius:16px;
                padding:9px 8px;
                box-shadow:0 8px 18px rgba(15,23,42,.045);
                min-width:0;
            }
            .garden-tycoon-stat span{
                display:flex;
                align-items:center;
                gap:5px;
                font-size:9px;
                font-weight:900;
                color:var(--t4);
                text-transform:uppercase;
                letter-spacing:.45px;
                white-space:nowrap;
            }
            .garden-tycoon-stat strong{
                display:block;
                font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                font-size:17px;
                font-weight:800;
                color:var(--t1);
                line-height:1.15;
                margin-top:3px;
                overflow:hidden;
                text-overflow:ellipsis;
                white-space:nowrap;
            }
            .garden-tycoon-actions{
                display:grid;
                grid-template-columns:1fr;
                gap:7px;
            }
            .garden-claim-card{
                background:linear-gradient(135deg,#FFFBEB,#ECFDF5);
                border-color:#FDE68A;
            }
            .garden-claim-head{
                display:flex;
                align-items:center;
                justify-content:space-between;
                gap:10px;
                margin-bottom:10px;
            }
            .garden-claim-title{
                display:flex;
                align-items:center;
                gap:8px;
                min-width:0;
            }
            .garden-claim-icon{
                width:38px;height:38px;
                border-radius:14px;
                display:flex;
                align-items:center;
                justify-content:center;
                background:linear-gradient(135deg,#F59E0B,#FB923C);
                color:#fff;
                box-shadow:0 8px 18px rgba(245,158,11,.18);
                flex-shrink:0;
            }
            .garden-claim-title strong{
                display:block;
                font-size:13px;
                color:var(--t1);
                line-height:1.2;
            }
            .garden-claim-title small{
                display:block;
                font-size:10px;
                color:var(--t3);
                line-height:1.35;
                margin-top:2px;
