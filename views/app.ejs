        const outfitMap={hoodie:0xff9349,jacket:0x2563eb,robe:0x7c3aed,tee:0x0d9488};
        const outfitBottomMap={hoodie:0x334155,jacket:0x1e3a8a,robe:0x4c1d95,tee:0x14532d};
        const auraMap={tenang:0x14b8a6,senang:0xfacc15,sedih:0x60a5fa,galau:0xa78bfa,stres:0xfb923c,marah:0xef4444};
        const defaultGlbColors={skin:"#F5E6D3",hair:"#1A1A1A",top:"#2980B9",bottom:"#2C3E50",shoe:"#1A1A1A",aura:"#14b8a6"};

        function getColor(map,key,fb){return map[key] ?? fb}
        function hexToNumber(value, fallback){
            if(typeof value==="number")return value;
            if(typeof value==="string"){
                const clean=value.trim().replace(/^#/,"");
                if(/^[0-9a-fA-F]{6}$/.test(clean))return parseInt(clean,16);
            }
            return fallback;
        }
        function colorToCss(value,fallback="#ffffff"){
            if(typeof value==="string" && /^#[0-9a-fA-F]{6}$/.test(value.trim()))return value.trim();
            return fallback;
        }
        function cloneMaterial(mat){
            if(Array.isArray(mat))return mat.map(m=>m.clone());
            return mat&&mat.clone?mat.clone():mat;
        }
        function tintMaterial(material,color,amount=.35){
            const apply=(m)=>{
                if(!m)return;
                if(m.color&&typeof m.color.lerp==="function"){
                    m.color.lerp(new THREE.Color(color),amount);
                    m.needsUpdate=true;
                }
                if("roughness" in m)m.roughness=Math.min(1,Math.max(.45,m.roughness||.65));
                if("metalness" in m)m.metalness=Math.min(.08,Math.max(0,m.metalness||0));
            };
            if(Array.isArray(material))material.forEach(apply); else apply(material);
        }
        function findState(){
            try{
                const raw=localStorage.getItem("vkm");
                return raw?JSON.parse(raw):{};
            }catch(_){return {}}
        }
        function saveStatePatch(patch){
            try{
                const current=findState();
                const next=Object.assign({},current,patch);
                localStorage.setItem("vkm",JSON.stringify(next));
                if(window.state){
                    Object.keys(patch).forEach((k)=>{window.state[k]=patch[k];});
                    if(typeof window.queueSyncState==="function")window.queueSyncState();
                }
            }catch(_){}
        }
        function normalizeGlbConfig(config){
            const saved=findState();
            const fromState=(window.state&&window.state.userAvatarGLB)||saved.userAvatarGLB||{};
            const av=(window.state&&window.state.userAvatar)||saved.userAvatar||{};
            return Object.assign(
                {},
                defaultGlbColors,
                {
                    skin: av.skinColor || fromState.skin,
                    hair: av.hairColor || fromState.hair,
                    top: av.topColor || fromState.top,
                    bottom: av.bottomColor || fromState.bottom,
                    shoe: av.shoeColor || fromState.shoe,
                    aura: av.auraColor || fromState.aura
                },
                config||{}
            );
        }
        function makeAura(config){
            const aura=hexToNumber(config.aura,getColor(auraMap,config.aura,0x14b8a6));
            const group=new THREE.Group();
            const auraMesh=new THREE.Mesh(
                new THREE.SphereGeometry(1.45,42,20),
                new THREE.MeshBasicMaterial({color:aura,transparent:true,opacity:.13,depthWrite:false})
            );
            auraMesh.scale.set(1.1,1.2,.58);
            auraMesh.position.set(0,.74,-.18);
            group.add(auraMesh);

            const ringMat=new THREE.MeshBasicMaterial({color:aura,transparent:true,opacity:.22,side:THREE.DoubleSide,depthWrite:false});
            const ring1=new THREE.Mesh(new THREE.TorusGeometry(1.05,.012,8,96),ringMat);
            ring1.rotation.set(Math.PI/2.7,.22,.16);
            ring1.scale.y=.55;
            ring1.position.y=.05;
            group.add(ring1);

            const ring2=new THREE.Mesh(new THREE.TorusGeometry(.74,.010,8,96),ringMat);
            ring2.rotation.set(Math.PI/2.8,-.35,-.22);
            ring2.scale.y=.52;
            ring2.position.y=.55;
            group.add(ring2);

            const floor=new THREE.Mesh(
                new THREE.CircleGeometry(1.38,72),
                new THREE.MeshBasicMaterial({color:0x0f172a,transparent:true,opacity:.10,depthWrite:false})
            );
            floor.rotation.x=-Math.PI/2;
            floor.position.set(0,-1.08,.08);
            group.add(floor);
            return group;
        }
        function normalizeModel(model){
            model.updateMatrixWorld(true);
            const box=new THREE.Box3().setFromObject(model);
            const size=new THREE.Vector3();
            const center=new THREE.Vector3();
            box.getSize(size);
            box.getCenter(center);
            model.position.sub(center);
            const scale=size.y>0?2.78/size.y:1;
            model.scale.setScalar(scale);
            model.position.y+=.28;
            model.rotation.y=Math.PI;
            return model;
        }
        function buildCap(color){
            const g=new THREE.Group();
            const mat=new THREE.MeshStandardMaterial({color,roughness:.58,metalness:.03});
            const dome=new THREE.Mesh(new THREE.SphereGeometry(.22,24,16,0,Math.PI*2,0,Math.PI*.58),mat);
            dome.position.y=.03;
            dome.scale.set(1.2,.8,1.2);
            const visor=new THREE.Mesh(new THREE.BoxGeometry(.20,.035,.14),mat);
            visor.position.set(0,-.02,.22);
            visor.rotation.x=.12;
            g.add(dome,visor);
            return g;
        }
        function buildGlasses(){
            const g=new THREE.Group();
            const mat=new THREE.MeshStandardMaterial({color:0x111827,roughness:.45,metalness:.03});
            const left=new THREE.Mesh(new THREE.TorusGeometry(.082,.01,10,24),mat);
            const right=new THREE.Mesh(new THREE.TorusGeometry(.082,.01,10,24),mat);
            left.scale.y=.72; right.scale.y=.72;
            left.position.x=-.12; right.position.x=.12;
            const bridge=new THREE.Mesh(new THREE.BoxGeometry(.07,.012,.012),mat);
            g.add(left,right,bridge);
            return g;
        }
        function buildHeadset(){
            const g=new THREE.Group();
            const mat=new THREE.MeshStandardMaterial({color:0x111827,roughness:.48,metalness:.03});
            const band=new THREE.Mesh(new THREE.TorusGeometry(.33,.018,10,40,Math.PI),mat);
            band.rotation.z=Math.PI;
            band.rotation.y=Math.PI/2;
            band.position.y=.12;
            const left=new THREE.Mesh(new THREE.BoxGeometry(.08,.16,.09),mat);
            const right=new THREE.Mesh(new THREE.BoxGeometry(.08,.16,.09),mat);
            left.position.set(-.28,-.02,.02);
            right.position.set(.28,-.02,.02);
            const mic=new THREE.Mesh(new THREE.BoxGeometry(.18,.015,.015),mat);
            mic.position.set(.20,-.15,.16);
            mic.rotation.z=-.45;
            g.add(band,left,right,mic);
            return g;
        }
        function buildHalo(){
            const mat=new THREE.MeshBasicMaterial({color:0xfacc15});
            const halo=new THREE.Mesh(new THREE.TorusGeometry(.20,.012,10,48),mat);
            halo.rotation.x=Math.PI/2;
            halo.scale.y=.45;
            return halo;
        }
        function attachExtras(root,config){
            const saved=findState();
            const av=(window.state&&window.state.userAvatar)||saved.userAvatar||{};
            const hairMode=av.hair || "soft";
            const accessory=av.accessory || "none";
            const hairColor=hexToNumber(config.hair,0x1a1a1a);

            const headBone=root.getObjectByName("Head") || root;
            const headMount=new THREE.Group();
            headMount.position.set(0,.09,.02);
            headBone.add(headMount);

            const hairMesh=root.getObjectByName("Wolf3D_Hair");
            if(hairMesh){
                hairMesh.visible=true;
                hairMesh.scale.set(1,1,1);
                if(hairMode==="short"){
                    hairMesh.scale.set(.92,.82,.92);
                    hairMesh.position.y=-.01;
                }else if(hairMode==="wavy"){
                    hairMesh.scale.set(1.05,1.12,1.02);
                    const mat=new THREE.MeshStandardMaterial({color:hairColor,roughness:.62,metalness:.02});
                    const left=new THREE.Mesh(new THREE.CapsuleGeometry(.04,.18,8,16),mat);
                    const right=new THREE.Mesh(new THREE.CapsuleGeometry(.04,.18,8,16),mat);
                    left.position.set(-.18,-.02,.10);
                    right.position.set(.18,-.02,.10);
                    left.rotation.z=.18;
                    right.rotation.z=-.18;
                    headMount.add(left,right);
                }else if(hairMode==="cap"){
                    hairMesh.visible=false;
                    const cap=buildCap(hairColor);
                    cap.position.set(0,.14,.02);
                    headMount.add(cap);
                }
            }

            if(accessory==="glasses"){
                const glasses=buildGlasses();
                glasses.position.set(0,.02,.30);
                headMount.add(glasses);
            }else if(accessory==="headset"){
                const headset=buildHeadset();
                headset.position.set(0,.12,.04);
                headMount.add(headset);
            }else if(accessory==="halo"){
                const halo=buildHalo();
                halo.position.set(0,.46,0);
                headMount.add(halo);
            }
        }
        function applyMorph(root,name,value){
            root.traverse((o)=>{
                if(!o.isMesh||!o.morphTargetDictionary||!o.morphTargetInfluences)return;
                const idx=o.morphTargetDictionary[name];
                if(typeof idx==="number")o.morphTargetInfluences[idx]=value;
            });
        }
        function setBone(root,name,rx,ry,rz){
            const bone=root.getObjectByName(name);
            if(bone)bone.rotation.set(rx||0,ry||0,rz||0);
        }
        function resetPose(root){
            ["Head","Neck","Spine","Spine1","Spine2","LeftShoulder","LeftArm","LeftForeArm","LeftHand","RightShoulder","RightArm","RightForeArm","RightHand"].forEach((name)=>{
                const bone=root.getObjectByName(name);
                if(bone)bone.rotation.set(0,0,0);
            });
        }
        function applyFaceAndPose(root){
            const saved=findState();
            const av=(window.state&&window.state.userAvatar)||saved.userAvatar||{};
            const face=String(av.face||"smile");
            const pose=String(av.pose||"idle");

            applyMorph(root,"mouthSmile",0);
            applyMorph(root,"mouthOpen",0);
            if(face==="smile"){
                applyMorph(root,"mouthSmile",0.95);
                applyMorph(root,"mouthOpen",0.08);
            }else if(face==="calm"){
                applyMorph(root,"mouthSmile",0.15);
            }else if(face==="focus"){
                applyMorph(root,"mouthOpen",0.03);
                const head=root.getObjectByName("Head");
                if(head)head.rotation.x=-0.03;
            }else if(face==="shy"){
                applyMorph(root,"mouthSmile",0.45);
                applyMorph(root,"mouthOpen",0.16);
                const head=root.getObjectByName("Head");
                if(head)head.rotation.z=-0.05;
            }

            resetPose(root);
            if(pose==="wave"){
                setBone(root,"RightShoulder",0,0,-0.2);
                setBone(root,"RightArm",0,0,-1.18);
                setBone(root,"RightForeArm",0,0,-0.45);
                setBone(root,"Head",0,.12,0);
            }else if(pose==="peace"){
                setBone(root,"LeftShoulder",0,0,.18);
                setBone(root,"LeftArm",0,0,1.1);
                setBone(root,"LeftForeArm",0,0,.35);
                setBone(root,"Head",0,-.10,0);
            }else if(pose==="focus"){
                setBone(root,"LeftArm",0,0,.55);
                setBone(root,"LeftForeArm",0,0,.75);
                setBone(root,"RightArm",0,0,-.55);
                setBone(root,"RightForeArm",0,0,-.75);
                setBone(root,"Head",-.06,0,0);
                setBone(root,"Spine2",-.04,0,0);
            }else{
                setBone(root,"LeftArm",0,0,.06);
                setBone(root,"RightArm",0,0,-.06);
            }
        }
        function applyAvatarCustomization(root,config){
            const skin=hexToNumber(config.skin,0xf2b789);
            const hair=hexToNumber(config.hair,0x1a1a1a);
            const top=hexToNumber(config.top,0x2980b9);
            const bottom=hexToNumber(config.bottom,0x2c3e50);
            const shoe=hexToNumber(config.shoe,0x1a1a1a);

            root.traverse((o)=>{
                if(!o.isMesh)return;
                o.castShadow=true;
                o.receiveShadow=true;
                o.material=cloneMaterial(o.material);
                const n=String(o.name||"").toLowerCase();
                if(n.includes("hair")){
                    tintMaterial(o.material,hair,.82);
                }else if(n.includes("outfit_top")){
                    tintMaterial(o.material,top,.72);
                }else if(n.includes("outfit_bottom")){
                    tintMaterial(o.material,bottom,.72);
                }else if(n.includes("footwear")){
                    tintMaterial(o.material,shoe,.72);
                }else if(n.includes("head") || n.includes("body")){
                    tintMaterial(o.material,skin,.32);
                }
            });

            applyFaceAndPose(root);
            attachExtras(root,config);
        }
        async function buildAvatarGroup(config){
            const loader=new GLTFLoader();
            const gltf=await loader.loadAsync(DREX_AVATAR_URL);
            const root=gltf.scene;
            applyAvatarCustomization(root,config);
            normalizeModel(root);

            const group=new THREE.Group();
            group.add(makeAura(config));
            group.add(root);
            return group;
        }
        function setupRenderer(host,canvas){
            const scene=new THREE.Scene();
            const camera=new THREE.PerspectiveCamera(30,1,.1,100);
            camera.position.set(0,.58,4.85);

            const renderer=new THREE.WebGLRenderer({canvas,alpha:true,antialias:true,powerPreference:"high-performance"});
            renderer.setPixelRatio(Math.min(window.devicePixelRatio||1,2));
            renderer.outputColorSpace=THREE.SRGBColorSpace;
            renderer.shadowMap.enabled=true;
            renderer.shadowMap.type=THREE.PCFSoftShadowMap;

            scene.add(new THREE.HemisphereLight(0xffffff,0x8aa0c7,2.9));
            const key=new THREE.DirectionalLight(0xffffff,2.9);
            key.position.set(3,4.5,5);
            key.castShadow=true;
            scene.add(key);
            const fill=new THREE.DirectionalLight(0x9ec5ff,1.5);
            fill.position.set(-3,2,4);
            scene.add(fill);

            let avatar=null, disposed=false, raf=0, t=0;
            let targetY=.18,targetX=.02,dragging=false,sx=0,sy=0,baseY=targetY,baseX=targetX;
            let autoRotate=false;

            function resize(){
                const rect=host.getBoundingClientRect();
                const w=Math.max(80,Math.floor(rect.width));
                const h=Math.max(100,Math.floor(rect.height));
                renderer.setSize(w,h,false);
                camera.aspect=w/h;
                camera.updateProjectionMatrix();
            }
            const ro=new ResizeObserver(resize);
            ro.observe(host);
            resize();

            canvas.onpointerdown=(e)=>{
                dragging=true;
                sx=e.clientX; sy=e.clientY;
                baseY=targetY; baseX=targetX;
                try{ canvas.setPointerCapture(e.pointerId); }catch(_){}
            };
            canvas.onpointermove=(e)=>{
                if(!dragging)return;
                targetY=Math.max(-1.25,Math.min(1.25,baseY+(e.clientX-sx)*.008));
                targetX=Math.max(-.30,Math.min(.24,baseX-(e.clientY-sy)*.004));
            };
            const end=()=>dragging=false;
            canvas.onpointerup=end;
            canvas.onpointercancel=end;
            canvas.onpointerleave=()=>{dragging=false;};
            canvas.onwheel=(e)=>{
                e.preventDefault();
                camera.position.z=Math.max(3.2,Math.min(6.4,camera.position.z+e.deltaY*.003));
            };

            function animate(){
                if(disposed)return;
                t+=.016;
                if(autoRotate && !dragging)targetY+=.006;
                if(avatar){
                    avatar.rotation.y+=(targetY-avatar.rotation.y)*.11;
                    avatar.rotation.x+=(targetX-avatar.rotation.x)*.11;
                    avatar.position.y=Math.sin(t*1.55)*.018;
                }
                renderer.render(scene,camera);
                raf=requestAnimationFrame(animate);
            }
            animate();

            return {
                setAvatar(group){
                    if(avatar)scene.remove(avatar);
                    avatar=group;
                    scene.add(avatar);
                },
                setAutoRotate(v){autoRotate=!!v;},
                dispose(){
                    disposed=true;
                    cancelAnimationFrame(raf);
                    ro.disconnect();
                    scene.traverse((o)=>{
                        if(o.geometry)o.geometry.dispose();
                        if(o.material){
                            if(Array.isArray(o.material))o.material.forEach(m=>m.dispose&&m.dispose());
                            else o.material.dispose&&o.material.dispose();
                        }
                    });
                    renderer.dispose();
                }
            };
        }

        function renderAvatar3D(host,av){
            const canvas=host.querySelector(".uav-level2-canvas");
            if(!canvas)return;
            const config=normalizeGlbConfig(av);
            const signature=JSON.stringify(config)+(JSON.stringify((window.state&&window.state.userAvatar)||{}));
            if(host.dataset.uavHydrated===signature&&host.__plAvatar3D)return;

            if(!host.__plAvatar3DRenderer){
                host.__plAvatar3DRenderer=setupRenderer(host,canvas);
            }
            host.dataset.uavHydrated=signature;
            buildAvatarGroup(config).then((group)=>{
                host.__plAvatar3DRenderer.setAvatar(group);
                host.classList.remove("uav2-error","uav-level2-pending");
                host.classList.add("uav2-rendered");
            }).catch((error)=>{
                console.error("GLB avatar gagal dimuat:", error);
                host.classList.add("uav2-error");
            });
            host.__plAvatar3D={dispose(){ if(host.__plAvatar3DRenderer){host.__plAvatar3DRenderer.dispose();host.__plAvatar3DRenderer=null;} }};
        }

        function mountZaiAvatarWorld(){
            const container=document.getElementById("avatar-3d-canvas-container");
            if(!container)return;
            if(container.dataset.zaiMounted==="1")return;
            container.dataset.zaiMounted="1";
            container.innerHTML='<canvas class="avatar-3d-webgl-canvas"></canvas><div class="avatar-3d-error" id="avatar-3d-error"></div>';
            const canvas=container.querySelector("canvas");
            const renderer=setupRenderer(container,canvas);

            let config=normalizeGlbConfig();
            let activeRequest=0;
            function setLoading(text){
                const err=document.getElementById("avatar-3d-error");
                if(err)err.textContent=text||"";
            }
            function renderNow(){
                activeRequest++;
                const req=activeRequest;
                setLoading("Memuat model GLB...");
                buildAvatarGroup(config).then((group)=>{
                    if(req!==activeRequest)return;
                    renderer.setAvatar(group);
                    container.classList.add("loaded");
                    setLoading("");
                    updatePreview();
                }).catch((error)=>{
                    console.error("Avatar 3D gagal dimuat:",error);
                    setLoading("Model GLB gagal dimuat. Cek path /assets/models/drex-avatar/Default.glb");
                });
            }
            function updatePreview(){
                const preview=document.getElementById("avatar-3d-config-preview");
                if(!preview)return;
                preview.innerHTML=["skin","hair","top","bottom","shoe"].map((key)=>{
                    const color=colorToCss(config[key],"#ffffff");
                    return '<span class="avatar-3d-config-chip"><b style="background:'+color+'"></b>'+key+'</span>';
                }).join("");
            }
            function setActiveButtons(){
                document.querySelectorAll(".avatar-3d-color-btn").forEach((btn)=>{
                    const color=String(btn.dataset.color||"").toLowerCase();
                    const type=String(btn.dataset.type||"");
                    btn.style.background=color||"#fff";
                    btn.classList.toggle("active",String(config[type]||"").toLowerCase()===color);
                });
            }
            function applyColor(type,color){
                if(!type||!color)return;
                config[type]=color;
                setActiveButtons();
                renderNow();
            }

            document.querySelectorAll(".avatar-3d-color-btn").forEach((btn)=>{
                btn.style.background=btn.dataset.color||"#fff";
                btn.addEventListener("click",()=>applyColor(btn.dataset.type,btn.dataset.color));
            });

            document.querySelectorAll(".avatar-3d-tab").forEach((tab)=>{
                tab.addEventListener("click",()=>{
                    const name=tab.dataset.tab;
                    document.querySelectorAll(".avatar-3d-tab").forEach((t)=>t.classList.toggle("active",t===tab));
                    document.querySelectorAll(".avatar-3d-tab-content").forEach((content)=>{
                        content.style.display=content.id==="avatar-3d-tab-"+name?"block":"none";
                    });
                });
            });

            const rotateBtn=document.getElementById("avatar-3d-rotate-toggle");
            if(rotateBtn){
                let rot=false;
                rotateBtn.addEventListener("click",()=>{
                    rot=!rot;
                    rotateBtn.classList.toggle("active",rot);
                    renderer.setAutoRotate(rot);
                });
            }
            const saveBtn=document.getElementById("avatar-3d-save");
            if(saveBtn){
                saveBtn.addEventListener("click",()=>{
                    saveStatePatch({userAvatarGLB:config});
                    if(typeof window.toast==="function")window.toast("Avatar GLB disimpan.");
                    else alert("Avatar GLB disimpan.");
                });
            }
            const resetBtn=document.getElementById("avatar-3d-reset");
            if(resetBtn){
                resetBtn.addEventListener("click",()=>{
                    config=normalizeGlbConfig(defaultGlbColors);
                    setActiveButtons();
                    renderNow();
                });
            }
            const randomBtn=document.getElementById("avatar-3d-random");
            if(randomBtn){
                randomBtn.addEventListener("click",()=>{
                    const palette={
                        skin:["#F5E6D3","#E8D4C4","#D4B896","#C4A484","#A67B5B","#8B6914","#5C3A21"],
                        hair:["#1A1A1A","#2C1810","#5D4037","#8D6E63","#D4AF37","#C0392B","#A52A2A","#808080","#C0C0C0","#2980B9","#8E44AD","#E91E63"],
                        top:["#2C3E50","#1A1A1A","#FFFFFF","#808080","#C0392B","#2980B9","#27AE60","#F39C12","#8E44AD","#E91E63","#16A085","#E67E22"],
                        bottom:["#2C3E50","#1A1A1A","#FFFFFF","#808080","#C0392B","#2980B9","#27AE60","#F39C12","#8E44AD","#E91E63","#16A085","#E67E22"],
                        shoe:["#2C3E50","#1A1A1A","#FFFFFF","#808080","#C0392B","#2980B9","#27AE60","#F39C12","#8E44AD","#E91E63","#16A085","#E67E22"]
                    };
                    Object.keys(palette).forEach((key)=>{
                        config[key]=palette[key][Math.floor(Math.random()*palette[key].length)];
                    });
                    setActiveButtons();
                    renderNow();
                });
            }

            setActiveButtons();
            updatePreview();
            renderNow();
            window.PlAvatar3D_ZAI={render:renderNow,getConfig:()=>config,setConfig:(c)=>{config=normalizeGlbConfig(c);setActiveButtons();renderNow();}};
        }

        window.PlAvatar3D={render:renderAvatar3D};

        function hydrateLegacyHosts(){
            document.querySelectorAll(".uav-level2-host").forEach((host)=>{
                const canvas=host.querySelector(".uav-level2-canvas");
                if(!canvas)return;
                let av={};
                try{ av=JSON.parse(canvas.dataset.avatar||"{}"); }catch(_){}
                try{ renderAvatar3D(host,av); }
                catch(error){
                    console.error("Avatar 3D error:", error);
                    host.classList.add("uav2-error");
                }
            });
        }
        function bootAvatar3D(){
            mountZaiAvatarWorld();
            hydrateLegacyHosts();
        }
        if(document.readyState==="loading"){
            document.addEventListener("DOMContentLoaded",bootAvatar3D);
        }else{
            bootAvatar3D();
        }
        new MutationObserver(()=>bootAvatar3D()).observe(document.documentElement,{childList:true,subtree:true});
        </script>







        
        <script type="module">
        import { AvatarSpeaker } from '/dist/index.esm.js';

        const VENT_AVATAR_PATH = '/assets/avatars/F_AVA.vrm';
        const VENT_IDLE_ANIMATION = '/assets/animations/VRMA_01(全身を見せる).vrma';
        const VENT_GREETING_ANIMATION = '/assets/animations/VRMA_02(挨拶).vrma';
        const VENT_IDLE_DELAY = 8000;
        const VENT_IDLE_LOOP_GAP = 1200;

        let ventAvatar = null;
        let ventReady = false;
        let ventStarting = false;
        let ventSpeaking = false;
        let ventCurrentAudio = null;
        let ventIdleTimer = null;
        let ventIdleMode = false;
        let ventIdleAnimating = false;
        let ventResizeObserver = null;

        function sleep(ms){return new Promise(resolve=>setTimeout(resolve,ms))}
        function byId(id){return document.getElementById(id)}
        function setText(id,text){const el=byId(id);if(el)el.textContent=text||''}

        function isVentVisible(){
            const page=byId('pg-vent');
            const container=byId('vent-avatar-container');
            if(!page||!container)return false;
            const pageVisible=page.classList.contains('on') || window.__VKM_PAGE_ID==='pg-vent';
            const rect=container.getBoundingClientRect();
            return pageVisible && rect.width>120 && rect.height>180;
        }

        function isIOSVentViewport(){
            return /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform==='MacIntel' && navigator.maxTouchPoints>1);
        }

        function applyVentFullBodyFraming(){
            try{
                const renderer=ventAvatar&&ventAvatar.renderer;
                if(!renderer)return;
                const ios=isIOSVentViewport();
                const small=window.matchMedia&&window.matchMedia('(max-width:899px)').matches;

                if(renderer.camera){
                    if(ios&&small){
                        renderer.camera.fov=30;
                        renderer.camera.position.set(0,1.16,4.15);
                        renderer.camera.lookAt(0,0.72,0);
                    }else{
                        renderer.camera.fov=32;
                        renderer.camera.position.set(0,1.02,3.05);
                        renderer.camera.lookAt(0,0.78,0);
                    }
                    renderer.camera.updateProjectionMatrix();
                }

                const vrm=renderer.vrm;
                if(vrm&&vrm.scene){
                    if(ios&&small){
                        vrm.scene.scale.set(1.04,1.04,1.04);
                        vrm.scene.position.set(0,-0.82,0);
                    }else{
                        vrm.scene.scale.set(1.22,1.22,1.22);
                        vrm.scene.position.set(0,-1.04,0);
                    }
                    vrm.scene.rotation.y=Math.PI;
                }

                if(renderer.controls&&renderer.controls.target){
                    renderer.controls.target.set(0,ios&&small?0.72:0.78,0);
                    renderer.controls.update&&renderer.controls.update();
                }
            }catch(error){
                console.warn('Vent full body framing gagal:',error);
            }
        }

        function forceVentAvatarCanvasLayout(){
            const container=byId('vent-avatar-container');
            if(!container)return;
            container.querySelectorAll('canvas:not(#wave-canvas)').forEach((canvas)=>{
                canvas.style.position='absolute';
                canvas.style.inset='0';
                canvas.style.width='100%';
                canvas.style.height='100%';
                canvas.style.display='block';
                canvas.style.zIndex='1';
                canvas.style.background='transparent';
                canvas.style.pointerEvents='auto';
                canvas.style.transform='translateZ(0)';
                canvas.style.webkitTransform='translateZ(0)';
            });
            try{
                applyVentFullBodyFraming();
                if(ventAvatar&&ventAvatar.renderer&&typeof ventAvatar.renderer.resize==='function'){
                    ventAvatar.renderer.resize();
                    applyVentFullBodyFraming();
                }
            }catch(error){
                console.warn('Vent avatar resize gagal:',error);
            }
            window.dispatchEvent(new Event('resize'));
            setTimeout(()=>{try{applyVentFullBodyFraming()}catch(_){}} ,160);
            setTimeout(()=>{try{applyVentFullBodyFraming()}catch(_){}} ,520);
        }

        function setVentModuleButtons(disabled){
            ['rec-btn','vent-test-voice','vent-play-idle'].forEach((id)=>{
                const el=byId(id);
                if(el)el.disabled=!!disabled;
            });
        }
        function hideVentLoading(){
            const loading=byId('vent-avatar-loading');
            if(loading){
                loading.classList.add('hidden');
                loading.setAttribute('aria-hidden','true');
                setTimeout(()=>{
                    if(loading.classList.contains('hidden'))loading.style.display='none';
                },260);
            }
            setVentModuleButtons(false);
        }
        function showVentLoadError(message){
            const loading=byId('vent-avatar-loading');
            const loadingText=byId('vent-loading-text');
            if(loadingText)loadingText.textContent=message;
            if(loading){
                loading.style.display='flex';
                loading.classList.remove('hidden');
                loading.setAttribute('aria-hidden','false');
            }
            setVentModuleButtons(true);
        }
        function clearVentIdleTimer(){
            if(ventIdleTimer){
                clearTimeout(ventIdleTimer);
                ventIdleTimer=null;
            }
        }
        function stopVentIdleMode(){
            ventIdleMode=false;
            clearVentIdleTimer();
        }
        function resetVentIdleTimer(){
            if(!ventAvatar||!ventReady)return;
            ventIdleMode=false;
            clearVentIdleTimer();
            if(!ventSpeaking){
                ventIdleTimer=setTimeout(()=>startVentIdleLoop(),VENT_IDLE_DELAY);
            }
        }
        async function startVentIdleLoop(){
            if(!ventAvatar||!ventReady)return;
            if(ventSpeaking||ventIdleAnimating){
                resetVentIdleTimer();
                return;
            }
            ventIdleMode=true;
            ventIdleAnimating=true;
            try{
                while(ventIdleMode&&!ventSpeaking){
                    forceVentAvatarCanvasLayout();
                    await ventAvatar.animate(VENT_IDLE_ANIMATION);
                    await sleep(VENT_IDLE_LOOP_GAP);
                }
            }catch(error){
                console.warn('Animasi idle Vent gagal:',error);
            }finally{
                ventIdleAnimating=false;
                if(!ventSpeaking)resetVentIdleTimer();
            }
        }
        function registerVentActivity(){
            if(window.__ventActivityRegistered)return;
            window.__ventActivityRegistered=true;
            ['mousemove','mousedown','keydown','touchstart','scroll','click'].forEach((eventName)=>{
                window.addEventListener(eventName,()=>resetVentIdleTimer(),{passive:true});
            });
        }
        function stopVentSpeech(){
            try{speechSynthesis.cancel()}catch(_){}
            if(ventCurrentAudio){
                try{ventCurrentAudio.pause();ventCurrentAudio.currentTime=0}catch(_){}
                ventCurrentAudio=null;
            }
            ventSpeaking=false;
            resetVentIdleTimer();
        }
        async function browserSpeechFallback(text){
            return new Promise((resolve)=>{
                if(!('speechSynthesis' in window)){
                    try{ventAvatar&&ventAvatar.say(text)}catch(_){}
                    resolve();
                    return;
                }
                try{speechSynthesis.cancel()}catch(_){}
                const utter=new SpeechSynthesisUtterance(text);
                utter.lang=(window.state&&window.state.al)==='en'?'en-US':'id-ID';
                utter.rate=.96;
                utter.pitch=1.04;
                utter.volume=1;
                utter.onstart=()=>{
                    ventSpeaking=true;
                    try{ventAvatar&&ventAvatar.say(text)}catch(_){}
                };
                utter.onend=utter.onerror=()=>{
                    ventSpeaking=false;
                    resolve();
                };
                speechSynthesis.speak(utter);
            });
        }
        async function speakVentAvatar(text,audioUrl){
            if(!ventAvatar||!ventReady)return browserSpeechFallback(text);
            const clean=String(text||'').trim();
            if(!clean)return;
            stopVentIdleMode();
            stopVentSpeech();
            setText('vent-subtitle-container',clean);
            ventSpeaking=true;
            forceVentAvatarCanvasLayout();
            try{
                if(audioUrl){
                    const audio=new Audio(audioUrl);
                    ventCurrentAudio=audio;
                    try{
                        await ventAvatar.say(clean,{audio});
                    }catch(error){
                        console.warn('AvatarSpeaker ai.say audio gagal, fallback manual:',error);
                        try{ventAvatar.say(clean)}catch(_){}
                        await audio.play();
                        await new Promise((resolve)=>{audio.onended=resolve;audio.onerror=resolve;});
                    }
                }else{
                    await browserSpeechFallback(clean);
                }
            }finally{
                ventCurrentAudio=null;
                ventSpeaking=false;
                forceVentAvatarCanvasLayout();
                resetVentIdleTimer();
            }
        }
        async function animateVentAvatar(path){
            if(!ventAvatar||!ventReady)return;
            try{
                stopVentIdleMode();
                forceVentAvatarCanvasLayout();
                await ventAvatar.animate(path||VENT_GREETING_ANIMATION);
            }catch(error){
                console.warn('Animasi Vent gagal:',error);
            }finally{
                forceVentAvatarCanvasLayout();
                resetVentIdleTimer();
            }
        }

        function watchVentResize(){
            const container=byId('vent-avatar-container');
            if(!container||ventResizeObserver)return;
            ventResizeObserver=new ResizeObserver(()=>{
                if(ventReady)forceVentAvatarCanvasLayout();
            });
            ventResizeObserver.observe(container);
        }

        async function startVentAvatarSpeaker(){
            const container=byId('vent-avatar-container');
            const subtitle=byId('vent-subtitle-container');
            if(!container)return;

            if(ventReady){
                forceVentAvatarCanvasLayout();
                return;
            }
            if(ventStarting)return;

            if(!isVentVisible()){
                setTimeout(startVentAvatarSpeaker,300);
                return;
            }

            ventStarting=true;
            container.dataset.avatarSpeakerMounted='1';
            const loading=byId('vent-avatar-loading');
            if(loading){
                loading.style.display='flex';
                loading.classList.remove('hidden');
                loading.setAttribute('aria-hidden','false');
            }
            setVentModuleButtons(true);
            setText('vent-loading-text','Memuat avatar 3D...');

            try{
                ventAvatar=new AvatarSpeaker({
                    avatar: VENT_AVATAR_PATH,
                    canvas: container,
                    subtitleContainer: subtitle
                });

                watchVentResize();
                await ventAvatar.ready();
                await sleep(250);

                ventReady=true;
                ventStarting=false;

                forceVentAvatarCanvasLayout();
                setTimeout(forceVentAvatarCanvasLayout,120);
                setTimeout(forceVentAvatarCanvasLayout,450);
                hideVentLoading();
                setText('vent-subtitle-container','Aku siap mendengarkan ceritamu. Tekan mic dan mulai bicara.');
                setText('vent-status-text','Avatar siap mendengarkan.');

                await sleep(120);
                forceVentAvatarCanvasLayout();
                try{await animateVentAvatar(VENT_GREETING_ANIMATION)}catch(_){}

                registerVentActivity();
                resetVentIdleTimer();
            }catch(error){
                ventStarting=false;
                console.error('Gagal memuat AvatarSpeaker Vent:',error);
                showVentLoadError('Gagal memuat avatar. Cek AvatarTest.vrm, /dist/index.esm.js, atau CORS.');
                setText('vent-status-text','Avatar gagal dimuat.');
            }
        }

        window.PlongVentAvatarSpeaker={
            ready:()=>ventReady,
            speak:speakVentAvatar,
            animate:animateVentAvatar,
            stop:stopVentSpeech,
            resetIdle:resetVentIdleTimer,
            forceResize:forceVentAvatarCanvasLayout,
            fullBody:applyVentFullBodyFraming,
            isSpeaking:()=>ventSpeaking
        };
function bootVentAvatarWhenReady(){
            startVentAvatarSpeaker();
            if(isVentVisible())forceVentAvatarCanvasLayout();
        }

        if(document.readyState==='loading'){
            document.addEventListener('DOMContentLoaded',bootVentAvatarWhenReady);
        }else{
            bootVentAvatarWhenReady();
        }

        document.addEventListener('click',(event)=>{
            if(event.target&&event.target.closest&&event.target.closest('[data-page="pg-vent"]')){
                setTimeout(bootVentAvatarWhenReady,120);
                setTimeout(bootVentAvatarWhenReady,450);
            }
        });

        new MutationObserver(()=>bootVentAvatarWhenReady()).observe(document.documentElement,{childList:true,subtree:true,attributes:true,attributeFilter:['class']});
        setInterval(()=>{if(isVentVisible())bootVentAvatarWhenReady()},1200);
        </script>



        <script>
            window.__VKM_PAGE_ID="<%= pageId %>";
            window.__VKM_PROFILE_KEY="<%= typeof profileKey !== 'undefined' ? profileKey : '' %>";
            

            var PAGE_LOADER_MIN_MS=5000;
            var pageLoaderStartedAt=Date.now();
            var pageLoaderTimer=null;
            var pageLoaderPercentTimer=null;
            var pageLoaderMessages=[
                "Menyiapkan ruang Plong...",
                "Memuat pet companion...",
                "Merapikan kebun emosimu...",
                "Menyinkronkan progress...",
                "Hampir selesai..."
            ];

            function updatePageLoaderProgress(percent){
                percent=Math.max(0,Math.min(100,Math.round(percent||0)));
                var bar=document.getElementById("page-loader-bar");
                var pct=document.getElementById("page-loader-percent");
                if(bar)bar.style.width=percent+"%";
                if(pct)pct.textContent=percent+"%";
            }

            function startPageLoader(text){
                var loader=document.getElementById("page-loader");
                if(!loader)return;
                pageLoaderStartedAt=Date.now();
                clearTimeout(pageLoaderTimer);
                clearInterval(pageLoaderPercentTimer);
                loader.classList.remove("hide");
                loader.classList.add("show");
                var title=document.getElementById("page-loader-title");
                var subtitle=document.getElementById("page-loader-subtitle");
                if(title)title.textContent=text||"Memuat halaman...";
                if(subtitle)subtitle.textContent="Plong sedang menyiapkan ruangmu";
                updatePageLoaderProgress(0);

                var start=Date.now();
                var msgIndex=0;
                pageLoaderPercentTimer=setInterval(function(){
                    var elapsed=Date.now()-start;
                    var fake=Math.min(96,(elapsed/PAGE_LOADER_MIN_MS)*96);
                    updatePageLoaderProgress(fake);
                    var nextIndex=Math.min(pageLoaderMessages.length-1,Math.floor(elapsed/1000));
                    if(nextIndex!==msgIndex){
                        msgIndex=nextIndex;
                        if(subtitle)subtitle.textContent=pageLoaderMessages[msgIndex];
                    }
                },120);
            }

            function finishPageLoader(){
                var loader=document.getElementById("page-loader");
                if(!loader)return;
                var elapsed=Date.now()-pageLoaderStartedAt;
                var wait=Math.max(0,PAGE_LOADER_MIN_MS-elapsed);
                clearTimeout(pageLoaderTimer);
                pageLoaderTimer=setTimeout(function(){
                    clearInterval(pageLoaderPercentTimer);
                    updatePageLoaderProgress(100);
                    var title=document.getElementById("page-loader-title");
                    var subtitle=document.getElementById("page-loader-subtitle");
                    if(title)title.textContent="Selesai!";
                    if(subtitle)subtitle.textContent="Ruangmu sudah siap dibuka";
                    setTimeout(function(){
                        loader.classList.remove("show");
                        loader.classList.add("hide");
                    },360);
                },wait);
            }

            function navigateWithLoader(url){
                if(!url)return;
                var targetPath=new URL(url,window.location.origin).pathname;
                if(window.location.pathname===targetPath)return;
                startPageLoader("Membuka halaman...");
                setTimeout(function(){
                    window.location.href=url;
                },520);
            }

            window.addEventListener("load",finishPageLoader);
            window.addEventListener("pageshow",function(event){
                if(event.persisted){
                    startPageLoader("Membuka halaman...");
                    finishPageLoader();
                }
            });
            window.addEventListener("beforeunload",function(){
                startPageLoader("Membuka halaman...");
            });

            startPageLoader("Memuat halaman...");

