function moodEmoji(m){
    return {tenang:'😌',senang:'😊',sedih:'😢',marah:'😡',galau:'🌧️',stres:'😵‍💫',capek:'🥱',kosong:'🫥',overthinking:'🌀'}[m]||'🌤️';
}
function renderMoodSummary(data){
    var today=data.today,counts=data.counts||[],recent=data.recent||[];
    var total=recent.length;
    var dominant=document.getElementById('emotion-dominant'),streak=document.getElementById('emotion-streak'),totalEl=document.getElementById('emotion-total'),todayEl=document.getElementById('emotion-today'),status=document.getElementById('mood-today-status'),bars=document.getElementById('emotion-bars'),history=document.getElementById('mood-history');
    if(dominant)dominant.textContent=data.dominant?(moodEmoji(data.dominant)+' '+data.dominant):'-';
    if(streak)streak.textContent=(data.streak||0)+' hari';
    if(totalEl)totalEl.textContent=total;
    if(todayEl)todayEl.textContent=today?(moodEmoji(today.mood)+' '+today.mood):'Belum';
    if(status)status.textContent=today?('Hari ini: '+today.mood+' · intensitas '+today.intensity):'Belum check-in';
    if(today){
        var moodBtn=document.querySelector('.mood-option[data-mood="'+today.mood+'"]');
        if(moodBtn){document.querySelectorAll('.mood-option').forEach(function(b){b.classList.remove('active')});moodBtn.classList.add('active');socialState.mood=today.mood;}
        var range=document.getElementById('mood-intensity'),note=document.getElementById('mood-note');
        if(range)range.value=today.intensity||3;
        if(note)note.value=today.note||'';
    }
    var max=counts.reduce(function(a,b){return Math.max(a,Number(b.total||0))},1);
    if(bars)bars.innerHTML=counts.slice(0,8).map(function(c){
        var pct=Math.round((Number(c.total||0)/max)*100);
        return '<div class="emotion-bar"><span>'+moodEmoji(c.mood)+' '+friendEsc(c.mood)+'</span><div class="emotion-bar-track"><i style="width:'+pct+'%"></i></div><strong>'+friendEsc(c.total)+'</strong></div>';
    }).join('') || '<div class="feature-empty show">Belum ada data emosi.</div>';
    if(history)history.innerHTML=recent.slice(0,12).map(function(x){
        return '<div class="mood-history-item"><strong>'+moodEmoji(x.mood)+' '+friendEsc(x.mood)+' · '+friendEsc(x.intensity)+'/5</strong><span>'+fmtTimeAgo(x.createdAt)+'</span>'+(x.note?'<p>'+friendEsc(x.note)+'</p>':'')+'</div>';
    }).join('') || '<div class="feature-empty show">Belum ada riwayat mood.</div>';
    if(typeof renderPetReaction==='function')renderPetReaction(today);
}
