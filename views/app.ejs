    view:'discover',
    filter:'all',
    query:'',
    search:[],
    friends:[],
    incoming:[],
    outgoing:[],
    loading:false,
    searchTimer:null,
    pollTimer:null,
    pollMs:8000,
    ready:false,
    summaryLoaded:false,
    profile:null,
    profileStats:null,
    profileOpen:false
};
function friendEsc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;')}
function friendAvatarFor(user){
    var u=String(user&&user.username||'').toLowerCase();
    if(u.length%5===0)return '/assets/nav/avatar.png';
    if(u.length%5===1)return '/assets/nav/account.png';
    if(u.length%5===2)return '/assets/nav/garden.png';
    if(u.length%5===3)return '/assets/nav/chat.png';
    return '/assets/nav/sfriends.png';
}
function friendProfileSlug(user){
    var username=String(user&&user.username||'').trim();
    if(username){
        username=username.replace(/\s+/g,'').replace(/^@*/,'@');
        if(username.length>1)return username;
    }
    return String(user&&user.id||'');
}
function friendProfilePath(user){
    return '/profile/'+friendProfileSlug(user);
}
function friendStatusText(rel){
    if(rel==='self')return 'Ini profil kamu';
    if(rel==='friends')return 'Sudah berteman';
    if(rel==='outgoing_pending')return 'Request menunggu';
    if(rel==='incoming_pending')return 'Request masuk';
    if(rel==='blocked')return 'Diblokir';
    return 'Belum berteman';
}
function friendStatusLabel(rel){
    if(rel==='self')return '<span class="friend-status ok"><i class="fas fa-user-check"></i> Profil kamu</span>';
    if(rel==='friends')return '<span class="friend-status ok"><i class="fas fa-check"></i> Sudah teman</span>';
    if(rel==='outgoing_pending')return '<span class="friend-status warn"><i class="fas fa-clock"></i> Menunggu</span>';
    if(rel==='incoming_pending')return '<span class="friend-status in"><i class="fas fa-inbox"></i> Request masuk</span>';
    return '<span class="friend-status"><i class="fas fa-user-plus"></i> Belum berteman</span>';
}
function friendActions(user,mode){
    var id=friendEsc(user.id),fid=friendEsc(user.friendshipId||''),rel=user.relationship||'none',profileKey=friendEsc(friendProfileSlug(user)),userName=friendEsc(user.name||'Teman');
    if(rel==='self'){
        return '<button class="friend-btn" type="button" disabled>Ini akunmu</button>';
    }
    if(mode==='incoming'||rel==='incoming_pending'){
        return '<button class="friend-btn primary" type="button" data-friend-action="accept" data-friendship-id="'+fid+'">Terima</button><button class="friend-btn danger" type="button" data-friend-action="decline" data-friendship-id="'+fid+'">Tolak</button>';
    }
    if(rel==='friends'){
        return '<button class="friend-btn primary" type="button" data-friend-action="support" data-user-id="'+id+'" data-user-name="'+userName+'">Dukung</button><button class="friend-btn" type="button" data-friend-action="profile" data-profile-key="'+profileKey+'">Profil</button><button class="friend-btn danger" type="button" data-friend-action="remove" data-friendship-id="'+fid+'">Hapus</button>';
    }
    if(rel==='outgoing_pending'){
        return '<button class="friend-btn" type="button" disabled>Request terkirim</button><button class="friend-btn danger" type="button" data-friend-action="remove" data-friendship-id="'+fid+'">Batalkan</button>';
    }
    return '<button class="friend-btn primary" type="button" data-friend-action="request" data-user-id="'+id+'">Tambah teman</button><button class="friend-btn" type="button" data-friend-action="profile" data-profile-key="'+profileKey+'">Profil dulu</button>';
}
function friendModalActions(user){
    var id=friendEsc(user.id),fid=friendEsc(user.friendshipId||''),rel=user.relationship||'none',userName=friendEsc(user.name||'Teman');
    var safety='<button class="friend-btn" type="button" data-friend-action="report" data-user-id="'+id+'" data-user-name="'+userName+'">Report</button><button class="friend-btn danger" type="button" data-friend-action="block" data-user-id="'+id+'">Block</button>';
    if(rel==='self')return '<button class="friend-btn" type="button" disabled>Ini profil kamu</button>';
    if(rel==='incoming_pending')return '<button class="friend-btn primary" type="button" data-friend-action="accept" data-friendship-id="'+fid+'">Terima request</button><button class="friend-btn danger" type="button" data-friend-action="decline" data-friendship-id="'+fid+'">Tolak</button>'+safety;
    if(rel==='friends')return '<button class="friend-btn primary" type="button" data-friend-action="support" data-user-id="'+id+'" data-user-name="'+userName+'">Kirim dukungan</button><button class="friend-btn danger" type="button" data-friend-action="remove" data-friendship-id="'+fid+'">Hapus teman</button>'+safety;
    if(rel==='outgoing_pending')return '<button class="friend-btn" type="button" disabled>Menunggu diterima</button><button class="friend-btn danger" type="button" data-friend-action="remove" data-friendship-id="'+fid+'">Batalkan request</button>'+safety;
    return '<button class="friend-btn primary" type="button" data-friend-action="request" data-user-id="'+id+'">Tambah teman</button>'+safety;
}
function friendCard(user,mode){
    var tags=[];
    var bio=String(user.bio||'').toLowerCase();
    ['healing','gaming','musik','desain','curhat'].forEach(function(t){if(bio.indexOf(t)>-1)tags.push(t.charAt(0).toUpperCase()+t.slice(1));});
    if(!tags.length)tags=['VokaMon','Supportive'];
    var level=user.friendshipLevel||null;
    var levelHtml=(user.relationship==='friends'&&level)?'<div class="friend-level"><strong>'+friendEsc(level.icon||'🌱')+' '+friendEsc(level.name||'Kenalan')+'</strong><span>XP '+friendEsc(user.friendshipXp||0)+' · Support '+friendEsc(user.supportCount||0)+'x</span><i style="width:'+Math.max(0,Math.min(100,Number(level.progress||0)))+'%"></i></div>':'';
    return '<article class="friend-card" data-user-id="'+friendEsc(user.id)+'">'+
        '<div class="friend-card-head"><div class="friend-avatar"><img src="'+friendAvatarFor(user)+'" alt=""></div><div class="friend-meta"><strong>'+friendEsc(user.name)+'</strong><span>'+friendEsc(user.username)+' · '+(user.lastLoginAt?'Pernah login':'User baru')+'</span><button class="friend-profile-link" type="button" data-friend-action="profile" data-profile-key="'+friendEsc(friendProfileSlug(user))+'"><i class="fas fa-eye"></i> Lihat profil</button></div></div>'+
        '<div class="friend-tags">'+tags.slice(0,3).map(function(t){return '<span>'+friendEsc(t)+'</span>'}).join('')+'</div>'+
        '<p class="friend-bio">'+friendEsc(user.bio||'Belum menulis bio.')+'</p>'+friendStatusLabel(user.relationship)+levelHtml+
        '<div class="friend-card-actions">'+friendActions(user,mode)+'</div>'+
    '</article>';
}
function setFriendView(view){
    friendState.view=view||'discover';
    document.querySelectorAll('.friend-tab').forEach(function(b){b.classList.toggle('active',b.dataset.friendView===friendState.view)});
    document.querySelectorAll('.friend-panel').forEach(function(p){p.classList.toggle('active',p.dataset.friendPanel===friendState.view)});
    renderFriendFinder();
}
function updateFriendBadges(){
    var ib=document.getElementById('friend-incoming-badge'),ob=document.getElementById('friend-outgoing-badge'),tb=document.getElementById('friend-total-badge'),nb=document.getElementById('friend-nav-badge');
    var hi=document.getElementById('friend-hero-incoming'),ho=document.getElementById('friend-hero-outgoing'),ht=document.getElementById('friend-hero-total');
    var incoming=friendState.incoming.length,outgoing=friendState.outgoing.length,total=friendState.friends.length;
    if(ib)ib.textContent=incoming;
    if(ob)ob.textContent=outgoing;
    if(tb)tb.textContent=total;
    if(hi)hi.textContent=incoming;
    if(ho)ho.textContent=outgoing;
    if(ht)ht.textContent=total;
    if(nb){
        nb.textContent=incoming>99?'99+':incoming;
        nb.classList.toggle('show',incoming>0);
    }
}
function setFriendLastSync(){
    var el=document.getElementById('friend-last-sync');
    if(!el)return;
    var now=new Date();
    el.textContent='Terakhir dicek '+now.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
}
function renderFriendList(targetId,emptyId,countId,list,mode){
    var grid=document.getElementById(targetId),empty=document.getElementById(emptyId),count=document.getElementById(countId);
    if(!grid)return;
    grid.innerHTML=(list||[]).map(function(u){return friendCard(u,mode)}).join('');
    if(empty)empty.classList.toggle('show',!list||!list.length);
    var noun=mode==='friends'?' teman':' request';
    if(count)count.textContent=(list?list.length:0)+noun;
}
function renderFriendFinder(){
    updateFriendBadges();
    var loading=document.getElementById('friend-loading'),grid=document.getElementById('friend-grid'),empty=document.getElementById('friend-empty'),count=document.getElementById('friend-count');
    if(loading)loading.classList.toggle('show',!!friendState.loading);
    if(grid)grid.innerHTML=friendState.search.map(function(u){return friendCard(u,'discover')}).join('');
    if(empty)empty.classList.toggle('show',!friendState.loading&&friendState.search.length===0);
    if(count)count.textContent=friendState.loading?'Memuat...':(friendState.search.length+' user ditemukan');
    renderFriendList('friend-incoming-grid','friend-incoming-empty','friend-incoming-count',friendState.incoming,'incoming');
    renderFriendList('friend-outgoing-grid','friend-outgoing-empty','friend-outgoing-count',friendState.outgoing,'outgoing');
    renderFriendList('friend-list-grid','friend-list-empty','friend-list-count',friendState.friends,'friends');
}
async function loadFriendSummary(options){
    options=options||{};
    if(!authToken)return;
    var previousIncoming=friendState.incoming.length;
    try{
        var r=await apiFetch('/api/friends');
        var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Gagal memuat teman.');
        friendState.friends=d.friends||[];
        friendState.incoming=d.incoming||[];
        friendState.outgoing=d.outgoing||[];
        if(friendState.summaryLoaded&&options.silent&&friendState.incoming.length>previousIncoming){
            toast('Ada request pertemanan baru masuk.',3600);
        }
        friendState.summaryLoaded=true;
        setFriendLastSync();
        renderFriendFinder();
    }catch(e){
        if(!options.silent)toast(e.message||'Gagal memuat data teman.');
    }
}
async function searchFriends(silent){
    if(!authToken){friendState.search=[];friendState.loading=false;renderFriendFinder();if((window.__VKM_PAGE_ID||'')==='pg-friends')showAuth('Silakan login dulu untuk mencari teman.');return;}
    var input=document.getElementById('friend-search');
    friendState.query=input?input.value.trim():'';
    if(!silent){friendState.loading=true;renderFriendFinder();}
    var url='/api/friends/search?limit=30&q='+encodeURIComponent(friendState.query)+'&filter='+encodeURIComponent(friendState.filter||'all');
    try{
        var r=await apiFetch(url);
        var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Gagal mencari teman.');
        friendState.search=d.users||[];
    }catch(e){
        if(!silent)toast(e.message||'Gagal mencari teman.');
        friendState.search=[];
    }
    friendState.loading=false;renderFriendFinder();
}
function scheduleFriendSearch(){clearTimeout(friendState.searchTimer);friendState.searchTimer=setTimeout(function(){searchFriends(false)},260)}
async function refreshFriendData(options){
    options=options||{};
    await loadFriendSummary({silent:!!options.silent});
    if((window.__VKM_PAGE_ID||'')==='pg-friends')await searchFriends(!!options.silent);
}
function showFriendProfileShell(){
    var modal=document.getElementById('friend-profile-modal');
    if(!modal)return;
    modal.classList.add('show');
    modal.setAttribute('aria-hidden','false');
    friendState.profileOpen=true;
}
function closeFriendProfile(){
    var modal=document.getElementById('friend-profile-modal');
    if(!modal)return;
    modal.classList.remove('show');
    modal.setAttribute('aria-hidden','true');
    friendState.profileOpen=false;
    friendState.profile=null;
    friendState.profileStats=null;
}
function setFriendProfileLoading(){
    showFriendProfileShell();
    var avatar=document.getElementById('friend-profile-avatar'),status=document.getElementById('friend-profile-status'),name=document.getElementById('friend-profile-name'),username=document.getElementById('friend-profile-username'),bio=document.getElementById('friend-profile-bio'),friends=document.getElementById('friend-profile-friends'),joined=document.getElementById('friend-profile-joined'),actions=document.getElementById('friend-profile-actions');
    if(avatar)renderUserAvatarInto(avatar,defaultUserAvatar());
    if(status)status.textContent='Memuat profil...';
    if(name)name.textContent='Profil';
    if(username)username.textContent='@username';
    if(bio)bio.textContent='Sebentar ya, data profil sedang dimuat.';
    if(friends)friends.textContent='-';
    if(joined)joined.textContent='-';
    if(actions)actions.innerHTML='<button class="friend-btn" type="button" disabled>Memuat...</button>';
}
function renderFriendProfile(user,stats){
    var avatar=document.getElementById('friend-profile-avatar'),status=document.getElementById('friend-profile-status'),name=document.getElementById('friend-profile-name'),username=document.getElementById('friend-profile-username'),bio=document.getElementById('friend-profile-bio'),friends=document.getElementById('friend-profile-friends'),joined=document.getElementById('friend-profile-joined'),actions=document.getElementById('friend-profile-actions');
    if(avatar)renderUserAvatarInto(avatar,user.userAvatar||defaultUserAvatar());
    if(status)status.textContent=friendStatusText(user.relationship);
    if(name)name.textContent=user.name||'VokaMon User';
    if(username)username.textContent=user.username||'@vokamon.user';
    if(bio)bio.textContent=user.bio||'Belum menulis bio.';
    if(friends)friends.textContent=String((stats&&stats.friends)||0);
    if(joined){
        var d=user.createdAt?new Date(user.createdAt):null;
        joined.textContent=(d&&!isNaN(d.getTime()))?d.toLocaleDateString('id-ID',{month:'short',year:'numeric'}):'-';
    }
    if(actions)actions.innerHTML=friendModalActions(user);
}
function renderFriendProfilePage(user,stats){
    var avatar=document.getElementById('friend-page-avatar'),status=document.getElementById('friend-page-status'),name=document.getElementById('friend-page-name'),username=document.getElementById('friend-page-username'),bio=document.getElementById('friend-page-bio'),friends=document.getElementById('friend-page-friends'),joined=document.getElementById('friend-page-joined'),actions=document.getElementById('friend-page-actions');
    if(avatar)renderUserAvatarInto(avatar,user.userAvatar||defaultUserAvatar());
    if(status)status.textContent=friendStatusText(user.relationship);
    if(name)name.textContent=user.name||'VokaMon User';
    if(username)username.textContent=user.username||'@vokamon.user';
    if(bio)bio.textContent=user.bio||'Belum menulis bio.';
    if(friends)friends.textContent=String((stats&&stats.friends)||0);
    if(joined){
        var d=user.createdAt?new Date(user.createdAt):null;
        joined.textContent=(d&&!isNaN(d.getTime()))?d.toLocaleDateString('id-ID',{month:'short',year:'numeric'}):'-';
    }
    if(actions)actions.innerHTML=friendModalActions(user);
}
function setFriendProfilePageLoading(){
    var avatar=document.getElementById('friend-page-avatar'),status=document.getElementById('friend-page-status'),name=document.getElementById('friend-page-name'),username=document.getElementById('friend-page-username'),bio=document.getElementById('friend-page-bio'),friends=document.getElementById('friend-page-friends'),joined=document.getElementById('friend-page-joined'),actions=document.getElementById('friend-page-actions');
    if(avatar)renderUserAvatarInto(avatar,defaultUserAvatar());
    if(status)status.textContent='Memuat profil...';
    if(name)name.textContent='Profil';
    if(username)username.textContent='@username';
    if(bio)bio.textContent='Data profil sedang dimuat.';
    if(friends)friends.textContent='-';
    if(joined)joined.textContent='-';
    if(actions)actions.innerHTML='<button class="friend-btn" type="button" disabled>Memuat...</button>';
}
async function loadFriendProfilePage(userId,silent){
    if(!userId)return;
    if(!authToken){showAuth('Silakan login dulu untuk melihat profil.');return;}
    setFriendProfilePageLoading();
    try{
        var r=await apiFetch('/api/friends/profile/'+encodeURIComponent(userId));
        var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Gagal memuat profil.');
        friendState.profile=d.user;
        friendState.profileStats=d.stats||{};
        renderFriendProfilePage(d.user,d.stats||{});
    }catch(e){
        if(!silent)toast(e.message||'Gagal memuat profil.');
        var bio=document.getElementById('friend-page-bio'),status=document.getElementById('friend-page-status'),actions=document.getElementById('friend-page-actions');
        if(status)status.textContent='Profil tidak tersedia';
        if(bio)bio.textContent=e.message||'Profil tidak bisa dimuat.';
        if(actions)actions.innerHTML='<button class="friend-btn" type="button" data-page="pg-friends">Kembali cari teman</button>';
    }
}
async function openFriendProfile(userId,silent){
    if(!authToken){showAuth('Silakan login dulu.');return;}
    if(!userId)return;
    setFriendProfileLoading();
    try{
        var r=await apiFetch('/api/friends/profile/'+encodeURIComponent(userId));
        var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Gagal memuat profil.');
        friendState.profile=d.user;
        friendState.profileStats=d.stats||{};
        renderFriendProfile(d.user,d.stats||{});
    }catch(e){
        if(!silent)toast(e.message||'Gagal memuat profil.');
        closeFriendProfile();
    }
}
async function friendAction(action,btn){
    if(!authToken){showAuth('Silakan login dulu.');return;}
    if(action==='profile'){var key=btn.dataset.profileKey||btn.dataset.userId;if(key)navigateWithLoader('/profile/'+key);return;}
    if(action==='support'){openSupportModal(btn.dataset.userId,btn.dataset.userName||'Teman');return;}
    if(action==='report'){openReportModal(btn.dataset.userId,btn.dataset.userName||'User');return;}
    if(action==='block'){blockUser(btn.dataset.userId);return;}
    var card=btn.closest('.friend-card')||btn.closest('.friend-profile-card');if(card)card.dataset.busy='1';
    var url='',opts={method:'POST',headers:{'Content-Type':'application/json'}};
    if(action==='request'){url='/api/friends/request';opts.body=JSON.stringify({userId:btn.dataset.userId});}
    else if(action==='accept'){url='/api/friends/'+btn.dataset.friendshipId+'/accept';}
    else if(action==='decline'){url='/api/friends/'+btn.dataset.friendshipId+'/decline';}
    else if(action==='remove'){url='/api/friends/'+btn.dataset.friendshipId;opts.method='DELETE';}
    else {if(card)card.dataset.busy='0';return;}
    try{
        var r=await apiFetch(url,opts);var d=await r.json();
        if(!r.ok||!d.ok)throw new Error(d.error||'Aksi gagal.');
        toast(d.message||'Berhasil.');
        var profileKey=friendState.profile&&friendProfileSlug(friendState.profile);
        await refreshFriendData({silent:true});
        if(friendState.profileOpen&&profileKey)await openFriendProfile(profileKey,true);
        if((window.__VKM_PAGE_ID||'')==='pg-profile'&&window.__VKM_PROFILE_KEY)await loadFriendProfilePage(window.__VKM_PROFILE_KEY,true);
    }catch(e){toast(e.message||'Aksi gagal.');}
    if(card)card.dataset.busy='0';
}
function startFriendRealtime(){
    if(friendState.pollTimer)clearInterval(friendState.pollTimer);
    if(!authToken)return;
    friendState.pollTimer=setInterval(function(){
        if(document.hidden)return;
        refreshFriendData({silent:true});
    },friendState.pollMs);
}
function initFriendFinder(){
    if(friendState.ready)return;friendState.ready=true;
    var input=document.getElementById('friend-search'),clear=document.getElementById('friend-search-clear');
    if(input)input.addEventListener('input',scheduleFriendSearch);
    if(clear)clear.addEventListener('click',function(){if(input)input.value='';searchFriends(false);});
    document.querySelectorAll('.friend-chip').forEach(function(chip){chip.addEventListener('click',function(){document.querySelectorAll('.friend-chip').forEach(function(x){x.classList.remove('active')});chip.classList.add('active');friendState.filter=chip.dataset.filter||'all';searchFriends(false);});});
    document.querySelectorAll('.friend-tab').forEach(function(tab){tab.addEventListener('click',function(){setFriendView(tab.dataset.friendView||'discover')});});
    document.addEventListener('click',function(e){
        var close=e.target.closest('[data-friend-profile-close]');
        if(close){closeFriendProfile();return;}
        var btn=e.target.closest('[data-friend-action]');
        if(btn)friendAction(btn.dataset.friendAction,btn);
    });
    document.addEventListener('keydown',function(e){if(e.key==='Escape'&&friendState.profileOpen)closeFriendProfile();});
    document.addEventListener('visibilitychange',function(){if(!document.hidden)refreshFriendData({silent:true});});
    window.addEventListener('focus',function(){refreshFriendData({silent:true});});
    refreshFriendData({silent:true});
    if((window.__VKM_PAGE_ID||'')==='pg-profile'&&window.__VKM_PROFILE_KEY)loadFriendProfilePage(window.__VKM_PROFILE_KEY,true);
    startFriendRealtime();
}

