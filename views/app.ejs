                .feature-shell{gap:12px}
                .feature-hero{border-radius:28px;padding:18px}
                .feature-hero h1{font-size:29px}
                .feature-toolbar{align-items:flex-start;flex-direction:column;border-radius:24px;padding:14px}
                .feature-toolbar-actions{width:100%;display:grid;grid-template-columns:1fr}
                .feature-card{border-radius:23px;padding:14px}
                .feature-card-head{align-items:flex-start;flex-direction:column}
                .mood-options{grid-template-columns:repeat(2,minmax(0,1fr))}
                .emotion-profile-grid{grid-template-columns:1fr 1fr}
                .emotion-bar{grid-template-columns:74px 1fr 36px}
                .calm-orb{width:180px;height:180px}
                .support-modal{align-items:flex-end;padding:12px}
                .support-card{border-radius:26px}
                .support-templates{grid-template-columns:1fr}
                .friend-card-actions{grid-template-columns:1fr 1fr!important}
            }
            @supports(-webkit-touch-callout:none){
                .feature-page{min-height:-webkit-fill-available}
                #mood-note,#support-message,#friend-search{font-size:16px!important}
                .feature-btn,.mood-option,.calm-duration-btn,.support-templates button{touch-action:manipulation;-webkit-user-select:none;user-select:none}
            }


            /* ===== Growth Pack: safety, quests, onboarding, garden economy, AI summary ===== */
            .safety-hero{background:linear-gradient(135deg,#ecfeff,#f8fafc 55%,#fff7ed)}
            .quest-hero{background:linear-gradient(135deg,#f0fdf4,#eff6ff 55%,#fff7ed)}
            .summary-hero{background:linear-gradient(135deg,#f5f3ff,#eff6ff 55%,#fff7ed)}
            .safety-layout,.summary-layout{
                display:grid;
                grid-template-columns:minmax(0,1fr) minmax(320px,.9fr);
                gap:16px;
            }
            .safety-select{
                width:100%;
                min-height:46px;
                border-radius:16px;
                border:1px solid #dce7fb;
                background:#f8fbff;
                color:#1d2d4d;
                padding:0 12px;
                font-family:inherit;
                font-size:14px;
                outline:0;
                margin-top:10px;
            }
            .safety-toggle{
                display:flex;
                align-items:center;
                gap:10px;
                margin-top:12px;
                padding:12px;
                border-radius:18px;
                background:#f8fbff;
                border:1px solid #e7eefc;
                color:#52627f;
                font-size:13px;
                font-weight:900;
            }
            .safety-toggle input{width:18px;height:18px;accent-color:#ff9349}
            .blocked-list{display:flex;flex-direction:column;gap:10px;margin-top:12px}
            .blocked-item{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px;border-radius:18px;background:#f8fbff;border:1px solid #e7eefc}
            .blocked-item strong{display:block;color:#1d2d4d;font-size:14px}
            .blocked-item span{display:block;color:#6f7e9c;font-size:11px;margin-top:3px}
            .quest-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,250px),1fr));gap:12px}
            .quest-card{padding:16px;border-radius:24px;background:#fff;border:1px solid #e7eefc;box-shadow:0 10px 22px rgba(84,106,160,.06);display:flex;flex-direction:column;gap:10px;min-height:190px}
            .quest-card.done{border-color:#bbf7d0;background:linear-gradient(180deg,#fff,#f0fdf4)}
            .quest-card.claimed{opacity:.72}
            .quest-card .quest-icon{width:50px;height:50px;border-radius:18px;display:grid;place-items:center;background:#fff7ed;border:1px solid #fed7aa;font-size:24px}
            .quest-card strong{color:#1d2d4d;font-size:15px}
            .quest-card p{margin:0;color:#66728d;font-size:12.5px;line-height:1.55}
            .quest-card small{margin-top:auto;color:#8a97b7;font-size:11px;font-weight:900}
            .quest-card button{width:100%}
            .garden-economy-card{margin-top:14px!important}
            .garden-economy-items{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin:12px 0}
            .garden-economy-item{padding:12px;border-radius:18px;background:#f8fbff;border:1px solid #e7eefc;text-align:center}
            .garden-economy-item strong{display:block;color:#1d2d4d;font-size:17px}
            .garden-economy-item span{display:block;margin-top:4px;color:#6f7e9c;font-size:11px;font-weight:900}
            .pet-reaction-card{align-self:stretch}
            .pet-reaction-box{margin-top:12px;padding:16px;border-radius:22px;background:linear-gradient(135deg,#fff7ed,#f0fdf4);border:1px solid #e7eefc;color:#1d2d4d;font-size:15px;line-height:1.65;font-weight:800}
            #summary-input,#report-detail{
                width:100%;
                resize:none;
                margin-top:12px;
                border:1px solid #dce7fb;
                background:#f8fbff;
                color:#1d2d4d;
                outline:0;
                border-radius:18px;
                padding:12px;
                font-size:15px;
                line-height:1.65;
            }
            .summary-result{margin-top:10px;color:#52627f;font-size:13px;line-height:1.7}
            .summary-result strong{display:block;color:#1d2d4d;font-size:16px;margin-bottom:8px}
            .summary-result ul{margin:10px 0 0 18px}
            .summary-history{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,260px),1fr));gap:10px}
            .summary-history-item{padding:13px;border-radius:20px;background:#f8fbff;border:1px solid #e7eefc}
            .summary-history-item strong{display:block;color:#1d2d4d;font-size:14px}
            .summary-history-item p{margin:8px 0 0;color:#66728d;font-size:12px;line-height:1.55}

            @media(max-width:900px){.safety-layout,.summary-layout{grid-template-columns:1fr}}
            @media(max-width:599px){
                .garden-economy-items{grid-template-columns:1fr}
            }


            /* ===== Life Loop Pack: pet routine, journey, event, recap, surprise ===== */
            .life-loop-grid{
                display:grid;
                grid-template-columns:1.05fr 1fr .9fr;
                gap:14px;
                margin:0 0 16px;
            }
            .life-wide-grid{
                display:grid;
                grid-template-columns:1fr 1.15fr;
                gap:14px;
                margin:0 0 16px;
            }
            .life-card,.life-wide-card{
                position:relative;
                overflow:hidden;
                border-radius:30px;
                border:1px solid rgba(255,255,255,.92);
                background:rgba(255,255,255,.95);
                box-shadow:0 20px 60px rgba(39,79,156,.10);
            }
            .life-card{
                min-height:190px;
                padding:18px;
                display:flex;
                flex-direction:column;
                justify-content:space-between;
                gap:14px;
            }
            .life-card:before,.life-wide-card:before{
                content:"";
                position:absolute;
                inset:-40% -20% auto auto;
                width:160px;
                height:160px;
                border-radius:50%;
                background:rgba(255,180,109,.18);
                filter:blur(2px);
            }
            .life-pet-pulse{background:linear-gradient(135deg,#fff,#f0fdf4)}
            .life-journey-card{background:linear-gradient(135deg,#fff7ed,#eff6ff)}
            .life-surprise-card{background:linear-gradient(135deg,#f5f3ff,#fff7ed)}
            .life-card-top{
                position:relative;
                z-index:1;
            }
            .life-card-top span,.life-wide-card span{
                display:inline-flex;
                align-items:center;
                gap:6px;
                color:#607092;
                font-size:11px;
                font-weight:900;
                text-transform:uppercase;
                letter-spacing:.3px;
            }
            .life-card-top strong,.life-wide-card strong{
                display:block;
                margin-top:6px;
                color:#16233f;
                font-size:20px;
                line-height:1.18;
                letter-spacing:-.25px;
            }
            .life-card p,.life-wide-card p{
                position:relative;
                z-index:1;
                margin:0;
                color:#5f6f8d;
                font-size:13px;
                line-height:1.65;
            }
            .life-chip-row{
                position:relative;
                z-index:1;
                display:flex;
                flex-wrap:wrap;
                gap:8px;
            }
            .life-action-chip,.life-primary{
                min-height:40px;
                border-radius:14px;
                border:1px solid #dce7fb;
                background:#fff;
                color:#4268df;
                padding:0 12px;
                font-size:12px;
                font-weight:900;
                display:inline-flex;
                align-items:center;
                justify-content:center;
                gap:7px;
                touch-action:manipulation;
            }
            .life-primary{
                position:relative;
                z-index:1;
                width:max-content;
                max-width:100%;
                background:linear-gradient(180deg,#ffb46d,#ff9349);
                border-color:#ff9349;
                color:#fff;
                box-shadow:0 10px 18px rgba(255,147,73,.18);
            }
            .life-primary[disabled]{
                opacity:.7;
                filter:grayscale(.15);
                cursor:not-allowed;
            }
            .life-wide-card{
                min-height:156px;
                padding:18px;
                display:grid;
                grid-template-columns:70px minmax(0,1fr);
                gap:14px;
                align-items:center;
            }
            .event-card{background:linear-gradient(135deg,#fff7ed,#f0fdf4)}
            .recap-card{background:linear-gradient(135deg,#eff6ff,#fff)}
            .life-wide-icon{
                width:66px;
                height:66px;
                border-radius:24px;
                display:grid;
                place-items:center;
                font-size:32px;
                background:rgba(255,255,255,.68);
                border:1px solid rgba(255,255,255,.88);
                box-shadow:0 14px 30px rgba(84,106,160,.10);
            }
            .life-wide-card small{
                display:inline-flex;
                margin-top:8px;
                padding:6px 10px;
                border-radius:999px;
                background:rgba(255,255,255,.72);
                color:#4f6389;
                font-size:11px;
                font-weight:900;
            }
            .life-recap-stats{
                margin-top:12px;
                display:grid;
                grid-template-columns:repeat(4,minmax(0,1fr));
                gap:8px;
            }
            .life-recap-stats b{
                padding:9px 7px;
                border-radius:16px;
                background:rgba(255,255,255,.74);
                border:1px solid rgba(226,232,240,.85);
                text-align:center;
                color:#1d2d4d;
            }
            .life-recap-stats span{
                display:block;
                color:#1d2d4d;
                font-size:17px;
                font-weight:900;
                text-transform:none;
                letter-spacing:0;
            }
            .life-recap-stats small{
                display:block;
                margin:3px 0 0;
                padding:0;
                background:transparent;
                border-radius:0;
                color:#7b88a6;
                font-size:10px;
            }
            @media(max-width:1100px){
                .life-loop-grid{grid-template-columns:1fr 1fr}
                .life-surprise-card{grid-column:1/-1}
                .life-wide-grid{grid-template-columns:1fr}
            }
            @media(max-width:599px){
                .life-loop-grid,.life-wide-grid{grid-template-columns:1fr;gap:10px;margin-bottom:12px}
                .life-card{min-height:155px;border-radius:24px;padding:15px}
                .life-wide-card{grid-template-columns:52px minmax(0,1fr);border-radius:24px;padding:14px}
                .life-wide-icon{width:50px;height:50px;border-radius:18px;font-size:25px}
                .life-card-top strong,.life-wide-card strong{font-size:18px}
                .life-recap-stats{grid-template-columns:repeat(2,minmax(0,1fr))}
            }


            /* ===== Dashboard stats + separated pet page ===== */
            .dashboard-stats-page{
                background:linear-gradient(180deg,#f8fbff,#f7f8fb);
            }
            .dash-shell{
                gap:16px;
            }
            .dash-topbar .foku-greet strong{
                letter-spacing:-.5px;
            }
            .dash-hero-stats{
                display:grid;
                grid-template-columns:1.1fr .9fr;
                gap:14px;
            }
            .dash-profile-card,.dash-focus-card,.dash-stat-card,.dash-action-card{
                position:relative;
                overflow:hidden;
                border-radius:30px;
                border:1px solid rgba(255,255,255,.92);
                background:rgba(255,255,255,.95);
                box-shadow:0 20px 60px rgba(39,79,156,.10);
            }
            .dash-profile-card{
                min-height:210px;
                display:grid;
                grid-template-columns:96px minmax(0,1fr) auto;
                gap:16px;
                align-items:center;
                padding:22px;
            }
            .dash-profile-bg{
                position:absolute;
                inset:0;
                background:
                  radial-gradient(circle at 18% 15%,rgba(255,180,109,.24),transparent 34%),
                  radial-gradient(circle at 85% 12%,rgba(118,169,255,.24),transparent 38%),
                  linear-gradient(135deg,#fff7ed,#eff6ff 56%,#f0fdf4);
                opacity:.96;
            }
            .dash-profile-avatar{
                position:relative;
                z-index:1;
                width:92px;
                height:92px;
                border-radius:50%;
                display:grid;
                place-items:center;
                background:#fff;
                border:5px solid rgba(255,255,255,.85);
                box-shadow:0 16px 34px rgba(39,79,156,.12);
                overflow:hidden;
            }
            .dash-profile-avatar img{width:68%;height:68%;object-fit:contain}
            .dash-profile-card>div:not(.dash-profile-bg),.dash-profile-card button{position:relative;z-index:1}
            .dash-profile-card span,.dash-focus-card span{
                display:block;
                color:#61708f;
                font-size:12px;
                font-weight:900;
                text-transform:uppercase;
                letter-spacing:.35px;
            }
            .dash-profile-card strong,.dash-focus-card strong{
                display:block;
                margin-top:5px;
                color:#16233f;
                font-size:clamp(24px,3vw,36px);
                line-height:1.1;
                letter-spacing:-.7px;
            }
            .dash-profile-card p,.dash-focus-card p{
                margin:8px 0 0;
                color:#5f6f8d;
                font-size:13px;
                line-height:1.65;
            }
            .dash-focus-card{
                padding:22px;
                display:flex;
                flex-direction:column;
                align-items:flex-start;
                justify-content:space-between;
                gap:14px;
                background:linear-gradient(135deg,#f5f3ff,#fff 58%,#fff7ed);
            }
            .dash-stat-grid{
                display:grid;
                grid-template-columns:repeat(4,minmax(0,1fr));
                gap:12px;
            }
            .dash-stat-card{
                min-height:150px;
                padding:16px;
                display:flex;
                flex-direction:column;
                align-items:flex-start;
                justify-content:space-between;
                gap:8px;
            }
            .dash-stat-card i{
                width:46px;
                height:46px;
                border-radius:17px;
                display:grid;
                place-items:center;
                background:#f8fbff;
                border:1px solid #e7eefc;
                color:#4268df;
                font-size:18px;
            }
            .dash-stat-card span{
                color:#61708f;
                font-size:12px;
                font-weight:900;
            }
            .dash-stat-card strong{
                color:#16233f;
                font-size:30px;
                line-height:1;
                letter-spacing:-.7px;
            }
            .dash-stat-card small{
                color:#8a97b7;
                font-size:11px;
                font-weight:800;
            }
            .dash-action-grid{
                display:grid;
                grid-template-columns:repeat(4,minmax(0,1fr));
                gap:12px;
            }
            .dash-action-card{
                min-height:120px;
                padding:16px;
                text-align:left;
                display:flex;
                flex-direction:column;
                align-items:flex-start;
                justify-content:center;
                gap:8px;
                border:1px solid rgba(226,232,240,.9);
                color:#1d2d4d;
                touch-action:manipulation;
            }
            .dash-action-card i{
                width:42px;
                height:42px;
                border-radius:15px;
                display:grid;
                place-items:center;
                background:#fff7ed;
                color:#ea580c;
                font-size:17px;
            }
            .dash-action-card strong{font-size:15px;color:#16233f}
            .dash-action-card span{font-size:12px;color:#6f7e9c;line-height:1.45}
            .pet-page .pet-life-grid{
                margin-bottom:16px;
            }
            @media(max-width:1000px){
                .dash-hero-stats{grid-template-columns:1fr}
                .dash-stat-grid,.dash-action-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
                .dash-profile-card{grid-template-columns:82px minmax(0,1fr)}
                .dash-profile-card button{grid-column:1/-1;width:100%}
            }
            @media(max-width:599px){
                .dash-shell{gap:12px}
                .dash-profile-card,.dash-focus-card,.dash-stat-card,.dash-action-card{border-radius:24px}
                .dash-profile-card{grid-template-columns:1fr;text-align:center;justify-items:center;padding:20px 16px}
                .dash-profile-card strong{font-size:30px}
                .dash-stat-grid{grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
                .dash-stat-card{min-height:132px;padding:14px}
                .dash-stat-card strong{font-size:26px}
                .dash-action-grid{grid-template-columns:1fr}
            }


            /* ===== Pet page scroll fix ===== */
            .pg.pet-page{
                flex:1 1 auto!important;
                min-height:0!important;
                height:auto!important;
                max-height:none!important;
                overflow-y:auto!important;
                overflow-x:hidden!important;
                -webkit-overflow-scrolling:touch!important;
                overscroll-behavior-y:contain;
                padding-bottom:calc(var(--nav-h) + var(--s-b) + 28px)!important;
                border-radius:0!important;
            }
            .pg.pet-page.on{
                display:flex!important;
            }
            .pg.pet-page .foku-shell{
                min-height:auto!important;
                padding-bottom:calc(var(--nav-h) + var(--s-b) + 34px)!important;
            }
            .pg.pet-page .foku-main-grid,
            .pg.pet-page .foku-bottom-grid,
            .pg.pet-page .life-loop-grid{
                flex:0 0 auto;
            }
            @media(min-width:900px){
                .pg.pet-page{
                    padding-bottom:28px!important;
                }
                .pg.pet-page .foku-shell{
                    padding-bottom:34px!important;
                }
            }
            @supports(-webkit-touch-callout:none){
                .pg.pet-page{
                    height:100%!important;
                    max-height:100%!important;
                    overflow-y:scroll!important;
                }
            }


            /* ===== Plong Avatar World: virtual user avatar ===== */
            .avatar-world-page{
                overflow-y:auto!important;
                overflow-x:hidden!important;
                -webkit-overflow-scrolling:touch;
                padding:18px 18px calc(var(--nav-h) + var(--s-b) + 26px)!important;
                background:linear-gradient(180deg,#f8fbff,#f7f8fb);
