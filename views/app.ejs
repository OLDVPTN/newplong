function fmtTimeAgo(v){
    var d=v?new Date(v):null;if(!d||isNaN(d.getTime()))return 'baru saja';
    var s=Math.floor((Date.now()-d.getTime())/1000);
    if(s<60)return 'baru saja';
    if(s<3600)return Math.floor(s/60)+' menit lalu';
    if(s<86400)return Math.floor(s/3600)+' jam lalu';
    return d.toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'});
}
function notifIcon(type){
    if(type==='friend_request')return 'fa-user-plus';
    if(type==='friend_accept')return 'fa-user-check';
    if(type==='support'||type==='support_sent')return 'fa-hands-holding-heart';
    if(type==='achievement')return 'fa-medal';
    if(type==='mood')return 'fa-face-smile';
    if(type==='calm')return 'fa-spa';
    return 'fa-bell';
}
function updateNotifBadges(){
    var sb=document.getElementById('notif-sidebar-badge');
    if(sb){sb.textContent=socialState.unread>99?'99+':socialState.unread;sb.classList.toggle('show',socialState.unread>0);}
}
function renderNotifications(){
    updateNotifBadges();
    var list=document.getElementById('notif-list'),empty=document.getElementById('notif-empty'),summary=document.getElementById('notif-summary');
    if(summary)summary.textContent=socialState.unread+' belum dibaca · '+socialState.notifications.length+' total';
    if(!list)return;
    list.innerHTML=socialState.notifications.map(function(n){
        return '<article class="notif-item '+(!n.isRead?'unread':'')+'">'+
            '<div class="notif-ic"><i class="fas '+notifIcon(n.type)+'"></i></div>'+
            '<div class="notif-body"><strong>'+friendEsc(n.title)+'</strong><p>'+friendEsc(n.body||'')+'</p><span>'+fmtTimeAgo(n.createdAt)+'</span></div>'+
