            var AL={id:{label:"Indonesia santai",welcome:"Hei! Aku Plong 👋 Aku di sini buat nemenin kamu. Mau cerita apa hari ini?"},"id-formal":{label:"Indonesia formal",welcome:"Halo, aku Plong 👋 Aku siap menemanimu. Apa yang ingin kamu ceritakan?"},en:{label:"English",welcome:"Hey, I'm Plong 👋 I'm here with you. What would you like to talk about?"},"jv-ngoko":{label:"Jawa ngoko",welcome:"Hei, aku Plong 👋 Aku neng kene ngancani kowe."},"jv-krama":{label:"Jawa krama",welcome:"Sugeng rawuh, kula Plong 👋 Kula siap ngancani panjenangan."},su:{label:"Sunda",welcome:"Hai, abdi Plong 👋 Abdi aya di dieu kanggo ngadangu."},ms:{label:"Melayu",welcome:"Hai, saya Plong 👋 Saya ada di sini untuk menemani kamu."}};
            var FOLLOWS=["Gimana cara aku bisa lebih tenang?","Ceritakan hal positif dong","Aku bingung mau ngambil keputusan","Bantu aku pahami perasaanku","Bantu aku urai pelan-pelan","Aku butuh kalimat penyemangat"];
            var GARDEN_ASSETS={base:'/assets/garden',petBase:'/assets/pet',plotEmpty:'/assets/garden/premium-plot-empty.svg',plotActive:'/assets/garden/premium-plot-active.svg',plotWet:'/assets/garden/premium-plot-wet.svg',plotReady:'/assets/garden/premium-plot-ready.svg',plotLocked:'/assets/garden/premium-plot-locked.svg'};
            var VEGGIES={carrot:{id:"carrot",name:"Wortel Ceria",icon:"🥕",growNeed:3,hunger:24,happy:7,desc:"Kenyang +24"},lettuce:{id:"lettuce",name:"Selada Tenang",icon:"🥬",growNeed:2,hunger:18,happy:10,desc:"Happy +10"},tomato:{id:"tomato",name:"Tomat Semangat",icon:"🍅",growNeed:4,hunger:28,happy:12,desc:"Kenyang +28"}};

            function gLK(){var k=state.al||"id";return AL[k]?k:"id"}
            function gL(){return AL[gLK()]||AL.id}

            function cleanUserName(name){
                name=String(name||"").trim();
                if(!name)return "";
                if(name.charAt(0)==="@")name=name.slice(1);
                return name.slice(0,32);
            }
            function getStoredUserName(){
                var fallback=cleanUserName(state.account&&state.account.name)||"VokaMon User";
                if(authUser){
                    var fromAuth=cleanUserName(authUser.name||authUser.username);
                    if(fromAuth)return fromAuth;
                }
                try{
                    var vkm=JSON.parse(localStorage.getItem("vkm")||"{}");
                    var fromVkm=cleanUserName(vkm&&vkm.account&&vkm.account.name);
                    if(fromVkm)return fromVkm;
                }catch(e){}
                var keys=["vkm_user","vokamon_user","authUser","currentUser","user"];
                for(var i=0;i<keys.length;i++){
                    try{
                        var raw=localStorage.getItem(keys[i]);
                        if(!raw)continue;
                        var data=JSON.parse(raw);
                        var candidate=cleanUserName(data.name||data.fullName||data.displayName||data.username);
                        if(candidate)return candidate;
                    }catch(e){}
                }
                return fallback;
            }
            function updateHeroGreeting(){
                var el=document.getElementById("hero-greeting");
