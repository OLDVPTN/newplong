            function gardenActivePlantCountLocal(g){
                return (g&&Array.isArray(g.plots)?g.plots:[]).filter(Boolean).length;
            }
            function gardenIdleRateLocal(g){
                var level=Math.max(1,Math.floor(Number(g&&g.level||1)));
                return Math.max(1,gardenActivePlantCountLocal(g)+Math.floor(level/2));
            }
            function gardenIdleCoinsLocal(g){
                if(!g)return 0;
                var last=g.lastIdleAt?Date.parse(g.lastIdleAt):Date.now();
                if(!Number.isFinite(last))last=Date.now();
                var mins=Math.floor(Math.min(Date.now()-last,12*60*60*1000)/60000);
                return Math.max(0,Math.floor(mins*gardenIdleRateLocal(g)));
            }
            function gardenWaterPowerLocal(g){
                var level=Math.max(1,Math.floor(Number(g&&g.level||1)));
                return Math.max(1,1+Math.floor((level-1)/3));
            }
            function gardenUpgradeCostLocal(g){
                var level=Math.max(1,Math.floor(Number(g&&g.level||1)));
                return 24+level*18;
            }
            function renderGarden(){
                var g=ensureGardenLocal(), active=getActivePlotIndex(), plot=g.plots[active]||null;
                g.plot=plot;
                if(typeof g.waterDrops!=="number")g.waterDrops=20;
                if(!g.daily)g.daily={date:new Date().toISOString().slice(0,10),planted:0,watered:0,harvested:0,claimed:false};

                var emoji=document.getElementById('garden-emoji'), status=document.getElementById('garden-status'), pct=document.getElementById('garden-percent'), ring=document.getElementById('st-ring-fill');
                var progress=plot?Math.max(0,Math.min(100,Number(plot.progress||0))):0;
                if(emoji){emoji.innerHTML=gardenMainAssetHtml(plot);emoji.classList.toggle('grow',!!plot&&Number(plot.progress||0)>0);emoji.classList.toggle('ready',!!plot&&!!plot.ready);emoji.classList.toggle('empty',!plot);}
                if(pct)pct.textContent=progress+'%';
                if(ring){
                    var circ=326.7;
                    ring.style.strokeDasharray=circ;
                    ring.style.strokeDashoffset=(circ-(circ*progress/100));
                }

                var coin=document.getElementById('lemo-coin-display'), waterDisplay=document.getElementById('st-water-display');
                if(coin)coin.textContent=state.coins||0;
                if(waterDisplay)waterDisplay.textContent=g.waterDrops;

                if(status){
                    if(!plot)status.textContent='Plot '+(active+1)+' kosong. Pilih bibit untuk mulai tanam.';
                    else{
                        var v=VEGGIES[plot.seed]||VEGGIES.carrot;
                        status.textContent=plot.ready?(v.name+' siap dipanen!'):('Siram '+(plot.waterCount||0)+'/'+(plot.growNeed||v.growNeed)+'x sampai panen.');
                    }
                }

                var plotWrap=document.getElementById('garden-plots');
                if(plotWrap){
                    plotWrap.innerHTML=g.plots.map(function(p,i){
                        var pp=p?Math.max(0,Math.min(100,Number(p.progress||0))):0;
                        var cls='st-plot-btn'+(i===active?' on':'')+(p&&p.ready?' ready':'')+(!p?' empty':'');
                        var label=p?(p.ready?'Siap panen':pp+'%'):'Bibit siap';
                        var plotTitle='Plot '+(i+1), cropLabel='Kosong';
                        if(p){ var veg=VEGGIES[p.seed]||VEGGIES.carrot; cropLabel=veg.name; }
                        return '<button type="button" class="'+cls+'" data-plot="'+i+'">'
                            + '<span class="st-plot-badge">'+plotTitle+'</span>'
                            + gardenPlotAssetHtml(p,i===active)
                            + '<span class="st-plot-meta"><strong class="st-plot-label">'+escH(cropLabel)+'</strong><small class="st-plot-name">'+escH(label)+'</small></span>'
                            + '<span class="st-plot-bar"><span style="width:'+pp+'%"></span></span>'
                            + '</button>';
                    }).join('');
