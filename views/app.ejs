/* ═══════ ACCOUNT PAGE ═══════ */
/* ═══════ ACCOUNT PAGE ═══════ */
            #pg-account{gap:10px;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:8px}
            .acct-card{background:var(--bg2);border:1px solid var(--bd1);border-radius:var(--r);padding:14px;box-shadow:0 1px 3px rgba(0,0,0,.035)}
