            .auth-field{display:flex;flex-direction:column;gap:5px}
            .auth-field label{font-size:11px;font-weight:700;color:var(--t3)}
            .auth-field input{width:100%;border:1px solid var(--bd1);background:var(--bg2);color:var(--t1);border-radius:12px;padding:12px 13px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s}
