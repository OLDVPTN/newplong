            /* ===== Avatar World 3D blocky upgrade ===== */
            .plong-user-avatar{
                --bg1:#dbeafe;
                --bg2:#fff7ed;
                --uav-rx:-10deg;
                --uav-ry:24deg;
                position:relative!important;
                display:grid!important;
                place-items:center!important;
                overflow:visible!important;
                perspective:900px;
                perspective-origin:50% 46%;
                touch-action:none;
                cursor:grab;
                user-select:none;
                -webkit-user-select:none;
            }
            .plong-user-avatar:active{cursor:grabbing}
            .plong-user-avatar.size-xl{width:230px!important;height:270px!important}
            .plong-user-avatar.size-profile{width:270px!important;height:330px!important}
            .plong-user-avatar.size-public{width:144px!important;height:176px!important}

            .uav3d-avatar{
                --skin:#f2b789;
                --hair:#332238;
                --outfit:#ff9349;
                --aura:#14b8a6;
                --cap:#3158d4;
                --pants:#334155;
                --shoe:#1f2937;
                position:absolute;
                inset:0;
                display:grid;
                place-items:center;
                transform-style:preserve-3d;
                border-radius:34px;
            }
            .uav3d-bg{
                position:absolute;
                inset:0;
                border-radius:34px;
                background:
                    radial-gradient(circle at 50% 20%,rgba(255,255,255,.88),transparent 112px),
                    radial-gradient(circle at 28% 78%,rgba(255,180,109,.20),transparent 82px),
                    linear-gradient(135deg,var(--bg1),var(--bg2));
                box-shadow:inset 0 1px 0 rgba(255,255,255,.8);
                z-index:0;
            }
            .uav3d-aura{
                position:absolute;
                left:50%;
                top:22%;
                width:62%;
                height:52%;
                transform:translateX(-50%);
                border-radius:999px;
                background:var(--aura);
                opacity:.24;
                filter:blur(24px);
                animation:uav3dPulse 4s ease-in-out infinite;
                z-index:1;
            }
            @keyframes uav3dPulse{
                0%,100%{transform:translateX(-50%) scale(.92);opacity:.18}
                50%{transform:translateX(-50%) scale(1.08);opacity:.28}
            }
            .uav3d-ground{
                position:absolute;
                left:50%;
                bottom:15%;
                width:58%;
                height:13%;
                transform:translateX(-50%) rotateX(68deg);
                border-radius:50%;
                background:radial-gradient(ellipse at center,rgba(17,24,39,.25),rgba(17,24,39,.03) 68%,transparent 72%);
                z-index:1;
            }
            .uav3d-scene{
                position:absolute;
                inset:0;
                display:grid;
                place-items:center;
                transform-style:preserve-3d;
                z-index:3;
            }
            .uav3d-inner{
                position:relative;
                width:220px;
                height:250px;
                transform-style:preserve-3d;
                transform:translateY(6px) rotateX(var(--uav-rx)) rotateY(var(--uav-ry));
                transition:transform .25s ease;
            }
            .plong-user-avatar.is-dragging .uav3d-inner{transition:none}
            .plong-user-avatar.size-public .uav3d-inner{transform:translateY(2px) scale(.66) rotateX(var(--uav-rx)) rotateY(var(--uav-ry))}
            .plong-user-avatar.size-xl .uav3d-inner{transform:translateY(3px) scale(.88) rotateX(var(--uav-rx)) rotateY(var(--uav-ry))}
            .plong-user-avatar.size-profile .uav3d-inner{transform:translateY(6px) scale(1.05) rotateX(var(--uav-rx)) rotateY(var(--uav-ry))}

            .uav3d-cube{
                position:absolute;
                left:50%;
                top:50%;
                width:var(--w);
                height:var(--h);
                transform-style:preserve-3d;
                transform:translate3d(calc(-50% + var(--x)),calc(-50% + var(--y)),var(--z));
            }
            .uav3d-face{
                position:absolute;
                left:50%;
                top:50%;
                width:var(--w);
                height:var(--h);
                transform-style:preserve-3d;
                background:var(--c);
                border:1px solid rgba(255,255,255,.28);
                box-shadow:inset 0 1px 0 rgba(255,255,255,.22);
                backface-visibility:hidden;
            }
            .uav3d-front{transform:translate(-50%,-50%) translateZ(calc(var(--d)/2));background:linear-gradient(145deg,rgba(255,255,255,.16),transparent 42%),var(--c)}
            .uav3d-back{transform:translate(-50%,-50%) rotateY(180deg) translateZ(calc(var(--d)/2));filter:brightness(.75)}
            .uav3d-left{width:var(--d);height:var(--h);transform:translate(-50%,-50%) rotateY(-90deg) translateZ(calc(var(--w)/2));filter:brightness(.72)}
            .uav3d-right{width:var(--d);height:var(--h);transform:translate(-50%,-50%) rotateY(90deg) translateZ(calc(var(--w)/2));filter:brightness(.88)}
            .uav3d-top{width:var(--w);height:var(--d);transform:translate(-50%,-50%) rotateX(90deg) translateZ(calc(var(--h)/2));filter:brightness(1.16)}
            .uav3d-bottom{width:var(--w);height:var(--d);transform:translate(-50%,-50%) rotateX(-90deg) translateZ(calc(var(--h)/2));filter:brightness(.58)}

