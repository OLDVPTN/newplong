            .garden-mini-progress{
                height:7px;
                border-radius:999px;
                background:rgba(229,231,235,.9);
                overflow:hidden;
                margin-top:7px;
            }
            .garden-mini-progress span{
                display:block;
                height:100%;
                border-radius:999px;
                background:linear-gradient(90deg,#F59E0B,#84CC16);
                transition:width .25s;
            }
            @media(min-width:900px){
                .garden-tycoon-actions{grid-template-columns:1fr 1fr}
                .garden-claim-card{grid-column:1/-1}
            }
            @media(max-width:420px){
                .garden-tycoon{grid-template-columns:1fr 1fr}
                .garden-tycoon-stat:last-child{grid-column:1/-1}
            }


            /* ═══════ CLEAN MOBILE GARDEN UI ═══════ */
            @media(max-width:640px){
                #pg-garden{
                    gap:8px!important;
                    padding:12px 12px calc(var(--nav-h) + var(--s-b) + 14px)!important;
                }
                #pg-garden .ph{
                    margin-bottom:4px!important;
                }
                #pg-garden .pt{
                    font-size:19px!important;
                }
                #pg-garden .ps{
                    font-size:10px!important;
                    max-width:280px;
                }
                .garden-layout{
                    gap:8px!important;
                }
                .garden-card{
                    border-radius:18px!important;
                    padding:11px!important;
                    box-shadow:0 6px 18px rgba(15,23,42,.045)!important;
                }
                .garden-card::after{
                    display:none!important;
                }
                .garden-hero-card{
                    padding:0!important;
