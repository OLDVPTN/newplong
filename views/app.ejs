<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <title>Plong - <%= title %></title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
        <style>
            :root{
            --bg:#F7F7F8;--bg2:#FFFFFF;--bg3:#F0F0F2;--bg4:#E8E8EB;--bg5:#DDDDDF;
            --t1:#111113;--t2:#3F3F46;--t3:#71717A;--t4:#A1A1AA;
            --bd1:#E4E4E7;--bd2:#D4D4D8;--bd3:#A1A1AA;
            --ac:#E84D1A;--ac2:#D4430F;--ac-bg:#FEF2EE;--ac-bg2:#FDDFD4;--ac-bd:#F5B8A4;
            --tl:#0D9488;--tl-bg:#F0FDFA;--tl-bd:#99F6E4;
            --marah:#DC2626;--sedih:#2563EB;--galau:#9333EA;--stres:#D97706;--excited:#CA8A04;--tenang:#0D9488;
            --nav-h:60px;--side-w:240px;
            --r:12px;--r2:10px;--r3:8px;--r4:6px;
            --s-t:env(safe-area-inset-top,0px);--s-b:env(safe-area-inset-bottom,0px);
            }
            *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
            html{scroll-behavior:smooth;height:100%}
            body{font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;background:var(--bg);color:var(--t1);height:100%;min-height:100dvh;overflow-x:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;font-size:15px;line-height:1.6}
            h1,h2,h3,h4{font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;line-height:1.15}
            button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
            input,textarea,select{font-family:inherit}
            a{color:inherit;text-decoration:none}
            ::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:4px}

            /* ── APP SHELL ── */
            #app-shell{display:flex;min-height:100dvh;min-height:-webkit-fill-available;height:100%}

            #sidebar{display:none;width:var(--side-w);flex-shrink:0;position:fixed;top:0;left:0;bottom:0;z-index:200;background:var(--bg2);border-right:1px solid var(--bd1);flex-direction:column;padding:20px 12px}
            #sidebar .logo{display:flex;align-items:center;gap:9px;padding:0 6px;margin-bottom:28px}
            #sidebar .logo-mk{width:28px;height:28px;border-radius:var(--r3);background:linear-gradient(135deg,var(--ac),#ff8c65);display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;flex-shrink:0}
            #sidebar .logo-t{font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;font-size:15px;font-weight:800;letter-spacing:-.2px}
            #sidebar nav{flex:1;display:flex;flex-direction:column;gap:1px}
            .sb{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:var(--r3);color:var(--t3);font-size:13px;font-weight:500;transition:all .12s}
            .sb i{width:16px;text-align:center;font-size:14px}
            .sb:hover{color:var(--t2);background:var(--bg3)}
            .sb.on{color:var(--ac);background:var(--ac-bg);font-weight:600}
            #sidebar .cp{display:flex;align-items:center;gap:7px;padding:9px 10px;border-radius:var(--r3);background:var(--ac-bg);border:1px solid var(--ac-bd);margin-top:auto}
            #sidebar .cp i{color:var(--ac);font-size:12px}
            #sidebar .cp span{font-size:11px;color:var(--t3)}
            #sidebar .cp strong{font-size:13px;color:var(--ac);font-weight:700;margin-left:auto}

            /* ── MAIN ── */
            #main{
                flex:1;min-width:0;
                display:flex;flex-direction:column;
                /* Mobile: bottom nav takes space */
                padding-bottom:calc(var(--nav-h) + var(--s-b));
                /* FIX: needs height for the chat flex chain to work */
                height:100dvh;
                height:-webkit-fill-available;
                overflow:hidden;
            }

            .pg{display:none;flex-direction:column;flex:1;min-height:0;padding:16px;animation:pgI .2s ease}
            .pg.on{display:flex}
            @keyframes pgI{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
            .ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
            .pt{font-size:20px;font-weight:800;letter-spacing:-.3px}
            .ps{font-size:11px;color:var(--t3);margin-top:1px}

            #tbar{display:flex;align-items:center;justify-content:space-between;padding:calc(var(--s-t)+12px) 16px 8px;position:sticky;top:0;z-index:50;background:linear-gradient(var(--bg) 70%,transparent);flex-shrink:0}
            #tbar .lw{font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;font-size:15px;font-weight:800;letter-spacing:-.2px}
            .cpill{display:inline-flex;align-items:center;gap:5px;background:var(--ac-bg);border:1px solid var(--ac-bd);padding:4px 10px;border-radius:16px;font-weight:700;font-size:11px;color:var(--ac)}
            .cpill i{font-size:10px}

            #bnav{position:fixed;bottom:0;left:0;right:0;z-index:200;height:calc(var(--nav-h)+var(--s-b));padding-bottom:var(--s-b);background:rgba(255,255,255,.92);-webkit-backdrop-filter:blur(16px);backdrop-filter:blur(16px);border-top:1px solid var(--bd1);display:flex;align-items:center;justify-content:space-around}
            .nb{display:flex;flex-direction:column;align-items:center;gap:1px;color:var(--t4);font-size:9px;font-weight:600;padding:4px 12px;position:relative;transition:color .12s;min-height:40px;min-width:40px;justify-content:center;letter-spacing:.2px}
            .nb i{font-size:18px;transition:color .12s}
            .nb.on{color:var(--ac)}
            .nb.on::before{content:'';position:absolute;top:-1px;left:50%;transform:translateX(-50%);width:14px;height:2px;background:var(--ac);border-radius:0 0 2px 2px}

            .nav-img{display:block;object-fit:contain;pointer-events:none;user-select:none}
            .sb .nav-img{width:24px;height:24px;flex:0 0 24px;margin-left:-2px;filter:drop-shadow(0 4px 7px rgba(0,0,0,.08));opacity:.82;transition:transform .14s ease,opacity .14s ease,filter .14s ease}
            .sb.on .nav-img,.sb:hover .nav-img{opacity:1;transform:scale(1.07);filter:drop-shadow(0 6px 11px rgba(232,77,26,.18))}
            .nb .nav-img{width:27px;height:27px;margin-bottom:-2px;filter:drop-shadow(0 3px 6px rgba(0,0,0,.10));opacity:.74;transition:transform .14s ease,opacity .14s ease,filter .14s ease}
            .nb.on .nav-img{opacity:1;transform:translateY(-2px) scale(1.08);filter:drop-shadow(0 7px 12px rgba(232,77,26,.22))}
            .foku-quick-btn .nav-img{width:22px;height:22px;margin-bottom:1px;filter:drop-shadow(0 4px 8px rgba(0,0,0,.09));opacity:.95}
            .home-icon-btn .nav-img{width:24px;height:24px;filter:drop-shadow(0 4px 8px rgba(0,0,0,.10))}


            #toast{position:fixed;top:calc(var(--s-t)+16px);left:50%;transform:translateX(-50%) translateY(-90px);z-index:9999;background:var(--t1);color:#fff;border:1px solid rgba(255,255,255,.1);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);padding:9px 18px;border-radius:var(--r);font-size:12px;font-weight:500;transition:transform .3s cubic-bezier(.32,1.3,.58,1);pointer-events:none;white-space:nowrap;max-width:calc(100vw - 24px);overflow:hidden;text-overflow:ellipsis}
            #toast.show{transform:translateX(-50%) translateY(0)}

            #pg-home{gap:10px;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior-y:contain;padding-bottom:calc(var(--nav-h) + var(--s-b) + 18px)}

            /* PET CARD FIX
               Mobile/iOS sometimes clipped the canvas because the avatar was drawn near
               the bottom of a tight card. Give the canvas a stable square size, make the
               card tall enough, and allow aura/accessories to remain visible. */
            .pet-h{
                display:flex;
                flex-direction:column;
                align-items:center;
                justify-content:center;
                min-height:238px;
                padding:18px 14px 16px;
                background:var(--bg2);
                border:1px solid var(--bd1);
                border-radius:var(--r);
                position:relative;
                overflow:visible;
                isolation:isolate;
            }
            .pet-h::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 35% at 50% 0%,rgba(232,77,26,.04) 0%,transparent 70%);pointer-events:none;border-radius:inherit;z-index:-1}
            .pn{font-size:18px;font-weight:800}.pm{font-size:11px;color:var(--t3);margin-top:1px}
            .xptr{width:120px;height:3px;background:var(--bg4);border-radius:2px;margin-top:6px;overflow:hidden}
            .xpf{height:100%;background:linear-gradient(90deg,var(--ac),#ff8c65);border-radius:2px;transition:width .4s}
            #pet-canvas{
                display:block;
                width:clamp(176px,52vw,220px);
                height:clamp(176px,52vw,220px);
                max-width:100%;
                aspect-ratio:1/1;
                flex:0 0 auto;
                margin:-2px auto 4px;
                object-fit:contain;
                transform:translateZ(0);
                contain:layout paint;
            }
            .pet-hi{position:relative;z-index:1;width:100%}
            .sr{display:grid;grid-template-columns:1fr 1fr;gap:6px}
            .sc{background:var(--bg2);border:1px solid var(--bd1);border-radius:var(--r3);padding:10px}
            .sl{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--t3);margin-bottom:5px}
            .sb2{height:3px;background:var(--bg4);border-radius:2px;overflow:hidden}
            .sf{height:100%;border-radius:2px;transition:width .4s}
            .es{background:var(--bg2);border:1px solid var(--bd1);border-radius:var(--r3);padding:10px}
            .et{font-size:9px;color:var(--t4);font-weight:700;text-transform:uppercase;letter-spacing:.7px;margin-bottom:7px}
            .eg{display:flex;flex-wrap:wrap;gap:4px}
            .ei{display:inline-flex;align-items:center;gap:4px;padding:3px 7px;border-radius:var(--r4);font-size:10px;font-weight:500;background:var(--bg3);border:1px solid var(--bd1);color:var(--t2)}
            .ed{width:5px;height:5px;border-radius:50%;flex-shrink:0}

            #pg-vent{align-items:center;justify-content:center;gap:18px;overflow-y:auto;-webkit-overflow-scrolling:touch}
            .leb{text-align:center;min-height:36px;display:flex;align-items:center;justify-content:center}
            .rw{position:relative;width:180px;height:180px;display:flex;align-items:center;justify-content:center}
            #wave-canvas{position:absolute;inset:0}
            #rec-btn{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--ac),#ff8c65);color:#fff;font-size:22px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(232,77,26,.25);transition:transform .12s,box-shadow .25s;position:relative;z-index:2;-webkit-appearance:none}
            #rec-btn:hover{transform:scale(1.03);box-shadow:0 6px 28px rgba(232,77,26,.3)}
            #rec-btn:active{transform:scale(.97)}
            #rec-btn.rec{animation:rP 1.2s ease infinite}
            @keyframes rP{0%,100%{box-shadow:0 0 0 10px rgba(232,77,26,.08),0 4px 20px rgba(232,77,26,.2)}50%{box-shadow:0 0 0 20px rgba(232,77,26,.03),0 4px 28px rgba(232,77,26,.15)}}
            #rec-timer{font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;font-size:22px;font-weight:400;letter-spacing:3px;color:var(--t3);min-height:28px}
            #emo-res{width:100%;max-width:320px;background:var(--bg2);border:1px solid var(--bd1);border-radius:var(--r);padding:18px;text-align:center;animation:pI .35s cubic-bezier(.34,1.4,.64,1);box-shadow:0 2px 12px rgba(0,0,0,.04)}
            @keyframes pI{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}

            #art-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
            .ac2{border-radius:var(--r3);overflow:hidden;border:1px solid var(--bd1);background:var(--bg2);cursor:pointer;transition:transform .12s,box-shadow .12s}
            .ac2:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.06)}
            .ac2 img{width:100%;aspect-ratio:1;object-fit:cover;display:block}
            .ae{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:var(--t4);padding:36px 0}

            #plist{display:flex;flex-direction:column;gap:6px;flex:1}
            .pc{background:var(--bg2);border:1px solid var(--bd1);border-radius:var(--r);padding:12px;display:flex;align-items:center;gap:10px;transition:all .12s}
            .pc:hover{box-shadow:0 2px 8px rgba(0,0,0,.04)}
            .pc-i{width:40px;height:40px;border-radius:var(--r3);flex-shrink:0;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:18px}
            .pc-f{flex:1;min-width:0}
            .pc-n{font-size:12px;font-weight:600}.pc-d{font-size:10px;color:var(--t3);margin-top:1px}
            .pc-p{display:flex;align-items:center;gap:3px;margin-top:2px;font-size:10px;font-weight:700;color:var(--ac)}
            .rb{padding:7px 14px;border-radius:var(--r3);font-size:11px;font-weight:600;transition:all .12s;flex-shrink:0;min-height:36px;-webkit-appearance:none}
            .rb.ok{background:var(--ac);color:#fff;box-shadow:0 1px 4px rgba(232,77,26,.2)}.rb.ok:hover{background:var(--ac2)}
            .rb.no{background:var(--bg3);color:var(--t4);cursor:not-allowed;border:1px solid var(--bd1)}

            /* ══════════════════════════════════════════
               ASSIST PAGE — SCROLL FIX (all devices)
               Strategy: pure flex column, NO fixed position
               input bar sticks to bottom via flex:0 0 auto
               ══════════════════════════════════════════ */
            #pg-assist{
                /* Fills remaining space in #main flex column */
                flex:1;
                min-height:0;
                padding:0;
                overflow:hidden;
                display:none;
                flex-direction:column;
            }
            #pg-assist.on{
                display:flex;
            }

            /* HERO state */
            .pp-hero{
                flex:1;display:flex;flex-direction:column;
                align-items:center;justify-content:center;
                padding:20px 16px;
                overflow-y:auto;-webkit-overflow-scrolling:touch;
                transition:opacity .2s,transform .2s;
            }
            .pp-hero.hide{
                display:none;
            }
            .pp-hero-logo{font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;font-size:28px;font-weight:800;letter-spacing:-.5px;color:var(--t1);margin-bottom:4px}
            .pp-hero-sub{font-size:13px;color:var(--t4);margin-bottom:28px}

            .pp-input-wrap{width:100%;max-width:640px;position:relative}
            .pp-input-box{display:flex;align-items:flex-end;gap:8px;background:var(--bg2);border:1.5px solid var(--bd1);border-radius:16px;padding:8px 8px 8px 16px;transition:border-color .2s,box-shadow .2s;box-shadow:0 1px 3px rgba(0,0,0,.04)}
            .pp-input-box:focus-within{border-color:var(--bd3);box-shadow:0 0 0 3px rgba(232,77,26,.08),0 4px 16px rgba(0,0,0,.06)}
            .pp-input-box textarea{flex:1;background:none;border:none;outline:none;color:var(--t1);font-size:15px;padding:8px 0;min-height:24px;max-height:140px;resize:none;line-height:1.5}
            .pp-input-box textarea::placeholder{color:var(--t4)}
            .pp-send{width:36px;height:36px;border-radius:var(--r3);flex-shrink:0;background:var(--ac);color:#fff;font-size:13px;display:flex;align-items:center;justify-content:center;transition:all .12s;-webkit-appearance:none;appearance:none;margin-bottom:1px;box-shadow:0 1px 4px rgba(232,77,26,.2)}
            .pp-send:hover:not(:disabled){background:var(--ac2)}
            .pp-send:active:not(:disabled){transform:scale(.92)}
            .pp-send:disabled{opacity:.25;cursor:not-allowed}

            .pp-sel-row{display:flex;align-items:center;gap:6px;margin-top:8px;flex-wrap:wrap}
            .pp-sel-btn{display:inline-flex;align-items:center;gap:5px;padding:5px 10px;border-radius:var(--r4);font-size:11px;font-weight:600;color:var(--t3);border:1px solid var(--bd1);background:var(--bg2);transition:all .12s;min-height:30px;-webkit-user-select:none;user-select:none;box-shadow:0 1px 2px rgba(0,0,0,.03)}
            .pp-sel-btn:hover{color:var(--t2);border-color:var(--bd2);background:var(--bg3)}
            .pp-sel-btn.open{color:var(--ac);border-color:var(--ac-bd);background:var(--ac-bg)}
            .pp-sel-btn i.fa-chevron-down{font-size:8px;transition:transform .15s}
            .pp-sel-btn.open i.fa-chevron-down{transform:rotate(180deg)}

            .pp-status{margin-left:auto;display:inline-flex;align-items:center;gap:4px;font-size:10px;color:var(--tl);font-weight:600;padding:4px 8px;border-radius:var(--r4);background:var(--tl-bg);border:1px solid var(--tl-bd);white-space:nowrap}
            .pp-status-dot{width:5px;height:5px;border-radius:50%;background:var(--tl);box-shadow:0 0 6px rgba(13,148,136,.4);animation:sp 2s ease infinite}
            @keyframes sp{0%,100%{opacity:1}50%{opacity:.3}}

            .pp-sugs{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-top:20px;max-width:540px}
            .pp-sug{padding:7px 14px;border-radius:20px;font-size:12px;font-weight:500;color:var(--t3);border:1px solid var(--bd1);background:var(--bg2);transition:all .12s;box-shadow:0 1px 2px rgba(0,0,0,.03);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
            .pp-sug:hover{color:var(--t2);border-color:var(--bd2);background:var(--bg3);box-shadow:0 2px 6px rgba(0,0,0,.05)}

            .pp-drop{position:fixed;z-index:900;min-width:280px;border-radius:var(--r);background:var(--bg2);border:1px solid var(--bd2);box-shadow:0 10px 40px rgba(0,0,0,.1),0 1px 3px rgba(0,0,0,.04);opacity:0;transform:translateY(-3px);pointer-events:none;transition:opacity .15s,transform .15s;overflow:hidden}
            .pp-drop.show{opacity:1;transform:translateY(0);pointer-events:auto}
            .pp-drop-hd{padding:10px 12px 8px;border-bottom:1px solid var(--bd1);display:flex;align-items:center;justify-content:space-between}
            .pp-drop-hd-t{font-size:11px;font-weight:700;color:var(--t2)}
            .pp-drop-hd-b{font-size:9px;font-weight:600;color:var(--t4);padding:2px 6px;border-radius:var(--r4);background:var(--bg3);border:1px solid var(--bd1)}
            .pp-drop-body{padding:4px;max-height:280px;overflow-y:auto;-webkit-overflow-scrolling:touch}
            .pp-drop-body::-webkit-scrollbar{width:3px}
            .pp-drop-body::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:3px}

            .pp-opt{width:100%;display:flex;align-items:center;gap:10px;text-align:left;padding:9px 10px;border-radius:var(--r3);border:1.5px solid transparent;color:var(--t1);min-height:42px;transition:all .1s;-webkit-appearance:none;appearance:none;-webkit-user-select:none;user-select:none}
            .pp-opt:hover:not(:disabled){background:var(--bg3);border-color:var(--bd1)}
            .pp-opt:active:not(:disabled){transform:scale(.99)}
            .pp-opt.on{background:var(--ac-bg);border-color:var(--ac-bd)}
            .pp-opt:disabled{opacity:.35;cursor:not-allowed}

            .pp-opt-ic{width:30px;height:30px;flex-shrink:0;display:flex;align-items:center;justify-content:center;border-radius:var(--r4);background:var(--bg3);border:1px solid var(--bd1);color:var(--ac);font-size:11px;transition:all .1s}
            .pp-opt.on .pp-opt-ic{background:var(--ac-bg2);border-color:var(--ac-bd)}
            .pp-opt-bd{flex:1;min-width:0}
            .pp-opt-nm{font-size:12px;font-weight:700;display:flex;align-items:center;gap:5px}
            .pp-opt-ds{font-size:10px;color:var(--t4);margin-top:1px;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
            .pp-opt-end{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0}
            .pp-ck{width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:1.5px solid var(--bd2);color:#fff;font-size:7px;opacity:0;transition:all .1s}
            .pp-opt.on .pp-ck{opacity:1;background:var(--ac);border-color:var(--ac)}
            .pp-tg{display:inline-flex;align-items:center;white-space:nowrap;padding:2px 6px;border-radius:var(--r4);font-size:9px;font-weight:700}
            .pp-tg--ok{color:var(--tl);background:var(--tl-bg);border:1px solid var(--tl-bd)}
            .pp-tg--wn{color:#D97706;background:#FFFBEB;border:1px solid #FDE68A}

            .pp-lg{display:grid;grid-template-columns:1fr 1fr;gap:3px}
            .pp-lg .pp-opt{padding:7px 8px;gap:7px;min-height:36px}
            .pp-lg .pp-opt-ic{width:26px;height:26px;border-radius:var(--r4);font-size:9px;font-weight:800;color:var(--t3)}
            .pp-lg .pp-opt.on .pp-opt-ic{color:var(--ac)}
            .pp-lg .pp-opt-nm{font-size:11px}

            /* ── CHAT LAYOUT: pure flex, NO fixed position ── */
            .pp-chat{
                display:none;
                flex-direction:column;
                flex:1;
                min-height:0; /* CRITICAL for flex scroll children */
                overflow:hidden;
