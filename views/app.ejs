            /* ===== Premium cute garden assets + watering/harvest animation ===== */
            .st-tree-emoji{display:flex;align-items:center;justify-content:center;min-height:124px;min-width:124px}
            .st-tree-emoji .garden-main-asset{width:min(190px,30vw);max-width:190px;min-width:112px;height:auto;display:block;filter:drop-shadow(0 10px 16px rgba(82,145,74,.18));transform-origin:50% 100%;animation:gardenPlantFloat 3.6s ease-in-out infinite,gardenPlantSway 4.6s ease-in-out infinite}
            .st-tree-emoji .garden-main-asset.ready{animation:gardenPlantFloat 3.1s ease-in-out infinite,gardenPlantBounce 1.65s ease-in-out infinite}
            .st-tree-emoji .garden-main-asset.idle{animation:gardenSeedPulse 3s ease-in-out infinite}
            .st-plot-btn{position:relative;overflow:hidden}
            .st-plot-art{position:relative;display:flex;align-items:flex-end;justify-content:center;width:100%;height:124px;margin:8px 0 6px}
            .st-plot-base{position:absolute;left:50%;bottom:0;transform:translateX(-50%);width:104px;height:auto;filter:drop-shadow(0 9px 13px rgba(92,142,80,.18))}
            .st-plot-plant,.st-plot-sprout{position:relative;z-index:2;max-width:86px;max-height:102px;width:auto;height:auto;transform-origin:50% 100%;filter:drop-shadow(0 8px 10px rgba(100,150,80,.13));animation:gardenPlantSway 4.6s ease-in-out infinite}
            .st-plot-plant.stage-seedling,.st-plot-sprout{max-width:64px;max-height:78px}
            .st-plot-plant.ready{animation:gardenPlantBounce 1.8s ease-in-out infinite}
            .st-plot-btn.on .st-plot-base{animation:gardenPlotGlow 2.4s ease-in-out infinite}
            .st-plot-btn.ready .st-plot-base{animation:gardenPlotShine 1.75s ease-in-out infinite}
            .st-plot-emoji-wrap,.st-plot-emoji{display:none!important}
            .garden-card-art{width:66px;height:66px;display:grid;place-items:center;border-radius:20px;background:linear-gradient(180deg,#fffdf4,#effcff);box-shadow:inset 0 1px 0 rgba(255,255,255,.9),0 8px 16px rgba(90,122,155,.08);margin:0 auto 8px}
            .garden-card-thumb{max-width:54px;max-height:54px;width:auto;height:auto;display:block;transform-origin:50% 100%;filter:drop-shadow(0 7px 8px rgba(94,150,78,.14))}
            .garden-card-thumb.seed{animation:gardenSeedPulse 3.2s ease-in-out infinite}
            .garden-card-thumb.ready{animation:gardenPlantSway 4.3s ease-in-out infinite}
            .garden-water-splash,.garden-harvest-burst{position:absolute;inset:0;z-index:4;pointer-events:none;display:none}
            .garden-water-splash i{position:absolute;top:10px;width:7px;height:18px;border-radius:999px;background:linear-gradient(180deg,#b8f3ff,#38bdf8);box-shadow:0 0 10px rgba(56,189,248,.45);opacity:0}
            .garden-water-splash i:nth-child(1){left:38%;animation-delay:.05s}.garden-water-splash i:nth-child(2){left:49%;animation-delay:.13s}.garden-water-splash i:nth-child(3){left:58%;animation-delay:.2s}.garden-water-splash i:nth-child(4){left:45%;animation-delay:.3s}
            .garden-harvest-burst i{position:absolute;left:50%;bottom:46px;width:24px;height:24px;border-radius:50%;background:radial-gradient(circle,#fff8a8 0 26%,#ffd04a 27% 70%,#ef9f1a 71%);box-shadow:0 0 14px rgba(255,211,73,.55);opacity:0}
            .garden-harvest-burst i:nth-child(1){--x:-32px;--r:-18deg}.garden-harvest-burst i:nth-child(2){--x:0px;--r:8deg}.garden-harvest-burst i:nth-child(3){--x:34px;--r:20deg}
            .garden-anim-water .st-plot-btn.on .garden-water-splash{display:block}
            .garden-anim-water .st-plot-btn.on .garden-water-splash i{animation:gardenWaterDrop .85s ease-out both}
            .garden-anim-water .st-plot-btn.on .st-plot-plant,.garden-anim-water .st-plot-btn.on .st-plot-sprout{animation:gardenWateredWiggle .85s ease-out both}
            .garden-anim-harvest .st-plot-btn.on.ready .garden-harvest-burst{display:block}
            .garden-anim-harvest .st-plot-btn.on.ready .garden-harvest-burst i{animation:gardenCoinPop .95s cubic-bezier(.18,1.15,.32,1) both}
            .garden-anim-harvest .st-plot-btn.on.ready .st-plot-plant{animation:gardenHarvestPop .85s cubic-bezier(.18,1.15,.32,1) both}
            .garden-anim-harvest .st-plot-btn.on.ready .st-plot-base{animation:gardenPlotShine 1s ease-in-out both}
            @keyframes gardenPlantSway{0%,100%{transform:rotate(-2deg)}50%{transform:rotate(2deg)}}
            @keyframes gardenPlantFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
            @keyframes gardenPlantBounce{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-7px) scale(1.045)}}
            @keyframes gardenSeedPulse{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-4px) scale(1.06)}}
            @keyframes gardenPlotGlow{0%,100%{filter:drop-shadow(0 8px 12px rgba(135,199,98,.18))}50%{filter:drop-shadow(0 0 18px rgba(170,255,117,.55))}}
            @keyframes gardenPlotShine{0%,100%{filter:drop-shadow(0 0 10px rgba(255,208,88,.30))}50%{filter:drop-shadow(0 0 22px rgba(255,229,133,.70))}}
            @keyframes gardenWaterDrop{0%{transform:translateY(-48px) scale(.55);opacity:0}15%{opacity:1}80%{opacity:1}100%{transform:translateY(58px) scale(.95);opacity:0}}
            @keyframes gardenWateredWiggle{0%,100%{transform:rotate(0) scale(1)}20%{transform:rotate(-8deg) scale(1.04)}45%{transform:rotate(7deg) scale(1.06)}70%{transform:rotate(-4deg) scale(1.03)}}
            @keyframes gardenCoinPop{0%{transform:translate(-50%,0) scale(.35) rotate(0);opacity:0}20%{opacity:1}75%{opacity:1}100%{transform:translate(calc(-50% + var(--x)),-86px) scale(1.06) rotate(var(--r));opacity:0}}
            @keyframes gardenHarvestPop{0%{transform:translateY(0) scale(1);opacity:1}45%{transform:translateY(-34px) scale(1.12);opacity:1}100%{transform:translateY(8px) scale(.82);opacity:.2}}
            @media(max-width:640px){.st-plot-art{height:108px}.st-plot-base{width:90px}.st-plot-plant{max-width:76px;max-height:90px}.st-tree-emoji .garden-main-asset{width:min(170px,40vw)}}

        
            /* ===== Garden pet helper sprite ===== */
            .st-tree-zone{
                position:relative;
                overflow:visible;
            }
            .garden-pet-helper{
                position:absolute;
                right:clamp(6px,3vw,28px);
                bottom:clamp(8px,2.4vw,24px);
                z-index:8;
                display:flex;
                flex-direction:column;
                align-items:center;
                gap:6px;
                pointer-events:none;
                transform-origin:50% 100%;
                animation:gardenPetIdle 3.4s ease-in-out infinite;
            }
            .garden-pet-helper img{
                width:clamp(70px,15vw,112px);
                height:auto;
                display:block;
                filter:drop-shadow(0 12px 14px rgba(42,82,151,.20));
            }
            .garden-pet-bubble{
                max-width:150px;
                padding:8px 10px;
                border-radius:15px 15px 15px 5px;
                background:rgba(255,255,255,.92);
                border:1px solid rgba(255,255,255,.9);
                box-shadow:0 10px 20px rgba(65,92,145,.12);
                color:#3f5181;
                font-size:10px;
                line-height:1.25;
                font-weight:700;
                text-align:center;
                backdrop-filter:blur(10px);
                -webkit-backdrop-filter:blur(10px);
            }
            .garden-pet-helper.is-watering{
                animation:gardenPetWater .85s ease-out both;
            }
            .garden-pet-helper.is-harvest{
                animation:gardenPetHarvest .95s cubic-bezier(.18,1.15,.32,1) both;
            }
            .garden-pet-helper.is-idle{
                animation:gardenPetIdle 3.4s ease-in-out infinite;
            }
            @keyframes gardenPetIdle{
                0%,100%{transform:translateY(0) rotate(-1deg)}
                50%{transform:translateY(-5px) rotate(1deg)}
            }
            @keyframes gardenPetWater{
                0%,100%{transform:translateY(0) rotate(0) scale(1)}
                25%{transform:translateY(-8px) rotate(-7deg) scale(1.04)}
                55%{transform:translateY(-4px) rotate(6deg) scale(1.03)}
                80%{transform:translateY(-2px) rotate(-3deg) scale(1.01)}
            }
            @keyframes gardenPetHarvest{
                0%{transform:translateY(0) scale(1)}
                35%{transform:translateY(-18px) scale(1.1)}
                65%{transform:translateY(-8px) scale(1.04)}
                100%{transform:translateY(0) scale(1)}
            }
            @media(max-width:640px){
                .garden-pet-helper{
                    right:2px;
                    bottom:4px;
                }
                .garden-pet-helper img{
                    width:74px;
                }
                .garden-pet-bubble{
                    max-width:112px;
                    font-size:9px;
                    padding:7px 8px;
                }
            }
            @media(max-width:420px){
                .garden-pet-helper{
                    position:relative;
                    right:auto;
                    bottom:auto;
                    margin:12px auto 0;
                }
            }

        
