            #pg-vent.vent-clean-ui #vent-avatar-loading{
                position:absolute!important;
                inset:0!important;
                z-index:40!important;
                display:flex!important;
                flex-direction:column!important;
                align-items:center!important;
                justify-content:center!important;
                gap:14px!important;
                color:#fff!important;
                text-align:center!important;
                background:linear-gradient(180deg,rgba(15,23,42,.24),rgba(15,23,42,.42))!important;
                backdrop-filter:blur(6px)!important;
                pointer-events:auto!important;
                opacity:1!important;
                visibility:visible!important;
                transition:opacity .22s ease,visibility .22s ease!important;
            }
            #pg-vent.vent-clean-ui #vent-avatar-loading.hidden{
                opacity:0!important;
                visibility:hidden!important;
                pointer-events:none!important;
            }
            #pg-vent.vent-clean-ui #vent-avatar-loading .spinner{
                width:38px!important;
                height:38px!important;
                border-radius:999px!important;
                border:3px solid rgba(255,255,255,.36)!important;
                border-top-color:#fff!important;
                animation:ventLoadingSpin .8s linear infinite!important;
            }
            #pg-vent.vent-clean-ui #vent-avatar-loading span{
                display:block!important;
                max-width:min(86%,360px)!important;
                padding:9px 14px!important;
                border-radius:999px!important;
                background:rgba(15,23,42,.42)!important;
                border:1px solid rgba(255,255,255,.18)!important;
                font-size:13px!important;
                font-weight:900!important;
                line-height:1.3!important;
                text-shadow:0 2px 12px rgba(0,0,0,.22)!important;
            }
            @keyframes ventLoadingSpin{
                to{transform:rotate(360deg)}
            }

            /* Vent mobile Safari safe layout restore */
            #pg-vent.vent-clean-ui .vent-clean-stage canvas:not(#wave-canvas){
                transform:translateZ(0)!important;
                -webkit-transform:translateZ(0)!important;
                backface-visibility:hidden!important;
                -webkit-backface-visibility:hidden!important;
            }
            @media(max-width:899px){
                #pg-vent.vent-clean-ui.on{
                    display:flex!important;
                    flex:1 1 auto!important;
                    min-height:0!important;
                    padding:0!important;
                    overflow:hidden!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-stage{
                    height:calc(100svh - var(--nav-h) - var(--s-b))!important;
                    min-height:0!important;
                    max-height:calc(100svh - var(--nav-h) - var(--s-b))!important;
                    overflow:hidden!important;
                    background-position:center!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-bottom{
                    position:absolute!important;
                    left:50%!important;
                    bottom:calc(10px + var(--s-b))!important;
                    transform:translateX(-50%)!important;
                    width:min(90%,720px)!important;
                    z-index:260!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-listen-card{
                    min-height:64px!important;
                    border-radius:24px!important;
                    padding:9px 13px 9px 9px!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-listen-copy strong{
                    font-size:17px!important;
                }
                #pg-vent.vent-clean-ui .vent-subtitle-container{
                    font-size:13px!important;
                    line-height:1.25!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-controls{
                    grid-template-columns:1fr 96px!important;
                    gap:8px!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-controls:not(.is-recording){
                    grid-template-columns:1fr!important;
                }
                #pg-vent.vent-clean-ui .vent-rec-wrap.vent-clean-mic-pill{
                    height:54px!important;
                }
                #pg-vent.vent-clean-ui #rec-btn{
                    width:50px!important;
                    height:50px!important;
                    font-size:24px!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-stop{
                    height:52px!important;
                    font-size:13px!important;
                }
                #pg-vent.vent-clean-ui .vent-clean-meta{
                    display:none!important;
                }
            }
            @supports(-webkit-touch-callout:none){
                #pg-vent.vent-clean-ui .vent-clean-stage{
                    height:calc(100svh - var(--nav-h) - var(--s-b))!important;
                    max-height:calc(100svh - var(--nav-h) - var(--s-b))!important;
                }
            }

</style>

